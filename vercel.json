{
  "version": 2,
  "images": {
    "sizes": [640, 1080],
    "domains": [
      "raw.githubusercontent.com",
      "res.cloudinary.com",
      "prod-files-secure.s3.us-west-2.amazonaws.com"
    ],
    "minimumCacheTTL": 31536000
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
