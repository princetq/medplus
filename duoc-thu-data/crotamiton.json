          "italic": false
        }
      ]
    },
    {
      "id": "b0037",
      "type": "paragraph",
      "text": "Ngừng thuốc nếu người bệnh bị kích ứng da nặng hoặc có biểu hiện của quá mẫn do bôi thuốc.",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        711.81,
        561.72,
        736.82
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0038",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        739.08,
        407.56,
        752.23
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng và cách dùng",
          "bbox": [
            307.39,
            739.08,
            407.56,
            752.23
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0039",
      "type": "paragraph",
      "text": "Cách dùng: Thuốc chỉ được dùng ngoài. Không bôi thuốc lên mặt, mắt hoặc miệng. Hỗn dịch crotamiton cần được lắc kỹ trước khi dùng.",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        751.44,
        561.74,
        776.45
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0040",
      "type": "subheading",
      "level": 3,
      "text": "Điều trị ghẻ:",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        776.02,
        356.46,
        788.66
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 0.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-ItalicMT"
        ]
      },
      "spans": [
        {
          "text": "Điều trị ghẻ:",
          "bbox": [
            307.39,
            776.02,
            356.46,
            788.66
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        }
      ]
    },
    {
      "id": "b0041",
      "type": "paragraph",
      "text": "Bệnh nhân cần được tắm sạch bằng xà phòng, rửa sạch hết các vảy da, sau đó lau khô người. Bôi một lớp mỏng kem hoặc hỗn dịch dùng ngoài crotamiton 10% lên toàn bộ bề mặt da của cơ thể từ cổ tới chân, bao gồm cả gan bàn chân của trẻ chưa biết đi, chú ý đặc biệt đến các nếp gấp da (nách, bẹn, kẽ ngón chân, ngón tay…) và xoa nhẹ nhàng. Không được bôi thuốc vào mặt, mắt, miệng, niêm mạc và lỗ niệu đạo. Người lớn mỗi lần bôi khoảng 30 g kem là đủ.",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        788.07,
        561.72,
        800.87
      ],
      "source": {
        "line_count": 7
      },
      "spans": [
        {
          "text": "Bệnh nhân cần được tắm sạch bằng xà phòng, rửa sạch hết các \n",
          "bbox": [
            307.39,
            788.07,
            561.72,
            800.87
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0043",
      "type": "paragraph",
      "text": "Trẻ em cần dùng ít hơn.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        135.64,
        126.14,
        148.44
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Trẻ em cần dùng ít hơn.",
          "bbox": [
            35.43,
            135.64,
            126.14,
            148.44
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0044",
      "type": "paragraph",
      "text": "Bôi thuốc lần thứ 2 sau 24 giờ. 48 giờ sau lần bôi thuốc cuối cùng, người bệnh tắm để loại bỏ hết thuốc. Nên bôi thuốc vào buổi tối.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        147.7,
        289.76,
        172.55
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Có thể nhắc lại điều trị sau 7 - 10 ngày nếu xuất hiện thấy rõ có con ghẻ sống.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        171.8,
        289.76,
        196.65
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Cần chú ý là sau khi điều trị bằng crotamiton, người bệnh có thể còn bị ngứa kéo dài thêm một đến vài tuần do mẫn cảm với con ghẻ. Triệu chứng này không có nghĩa là điều trị thất bại và không nên dùng lại thuốc. Có thể dùng kháng histamin uống và bôi corticosteroid tại chỗ để đỡ ngứa.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        195.91,
        289.76,
        256.92
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0047",
      "type": "paragraph",
      "text": "Quần áo và chăn màn, giường của người bệnh cần được vệ sinh sạch sẽ để tránh tái nhiễm bệnh. Không nhất thiết phải tẩy trùng khu vực sinh sống của người bệnh.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        256.18,
        289.77,
        293.08
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0048",
      "type": "subheading",
      "level": 3,
      "text": "Điều trị ngứa:",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        292.5,
        90.22,
        305.14
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 0.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-ItalicMT"
        ]
      },
      "spans": [
        {
          "text": "Điều trị ngứa:",
          "bbox": [
            35.43,
            292.5,
            90.22,
            305.14
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        }
      ]
    },
    {
      "id": "b0049",
      "type": "paragraph",
      "text": "Bôi thuốc vào vùng da bị tổn thương và xoa nhẹ nhàng cho tới khi thuốc ngấm hết. Có thể lặp lại nếu cần. Với trẻ em dưới 3 tuổi, bôi thuốc 1 lần/ngày.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        304.39,
        289.77,
        341.3
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0050",
      "type": "heading",
      "level": 2,
      "text": "Quá liều và xử trí",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        343.4,
        107.11,
        356.55
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Quá liều và xử trí",
          "bbox": [
            35.43,
            343.4,
            107.11,
            356.55
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0051",
      "type": "paragraph",
      "text": "Chưa có thông tin về quá liều crotamiton khi dùng bôi ngoài da, tuy nhiên đã có báo cáo 1 trường hợp bị xanh tím sau khi bôi quá nhiều kem crotamiton.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        355.61,
        289.77,
        392.51
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0052",
      "type": "paragraph",
      "text": "Nếu uống crotamiton có thể gây đau rát như bỏng, kích ứng ở miệng, thực quản, niêm mạc dạ dày cùng các triệu chứng như nôn, buồn nôn, đau bụng. Đã có 1 trường hợp người bệnh 23 tuổi bị co giật sau khi uống crotamiton, phải điều trị bằng diazepam.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        391.77,
        289.77,
        440.73
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0053",
      "type": "paragraph",
      "text": "Xử trí: Loại bỏ phần thuốc còn chưa được hấp thu ở ống tiêu hóa như rửa dạ dày, uống than hoạt… Điều trị hỗ trợ và điều trị triệu chứng.",
      "page": 519,
      "printed_page": 525,
      "column": 0,
      "bbox": [
        35.43,
        439.98,
        289.79,
        464.83
      ],
      "source": {
        "line_count": 2
      }
    },
    {
