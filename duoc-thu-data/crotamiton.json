        }
      ]
    },
    {
      "id": "b0035",
      "type": "paragraph",
      "text": "Dùng kéo dài có thể gây dị ứng da nhạy cảm.",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        684.39,
