    {
      "id": "b0032",
      "type": "paragraph",
      "text": "Khi bôi ngoài với liều phù hợp, thuốc có độc tính rất thấp.",
      "page": 518,
      "printed_page": 524,
      "column": 1,
      "bbox": [
        307.39,
        647.76,
        530.91,
        660.56
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Khi bôi ngoài với liều phù hợp, thuốc có độc tính rất thấp. ",
