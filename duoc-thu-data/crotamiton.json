    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Các biểu hiện kích ứng nhẹ tại chỗ như mẩn ngứa, viêm kết mạc.",
      "page": 518,
      "printed_page": 524,
      "column": 1,
