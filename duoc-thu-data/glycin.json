    },
    {
      "id": "b0006",
      "type": "paragraph",
      "text": "Viên nén có nhiều thành phần hoạt chất khác nhau, trong đó có glycin.",
      "page": 834,
      "printed_page": 840,
      "column": 0,
      "bbox": [
        43.94,
        430.12,
        298.27,
        455.05
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0007",
      "type": "paragraph",
      "text": "Dung dịch để truyền tĩnh mạch (phối hợp với các acid amin khác, sorbitol, các chất điện giải).",
      "page": 834,
      "printed_page": 840,
      "column": 0,
      "bbox": [
        43.94,
        454.39,
        298.27,
        479.32
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0008",
      "type": "paragraph",
      "text": "Dung dịch glycin 1,5% để tưới, rửa.",
      "page": 834,
      "printed_page": 840,
      "column": 0,
      "bbox": [
        43.94,
        478.67,
        180.9,
        491.46
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
