  "sections": [
    {
      "id": "dang-thuoc-va-ham-luong",
      "title": "Dạng thuốc và hàm lượng",
      "heading_block": "b0005",
      "blocks": [
        {
          "type": "text",
          "text": "Thuốc bột pha hỗn dịch: Gói 3 g.",
          "block_id": "b0006"
        }
      ]
    },
    {
      "id": "duoc-luc-hoc",
      "title": "Dược lực học",
      "heading_block": "b0007",
      "blocks": [
        {
          "type": "text",
          "text": "Diosmectit là silicat nhôm và magnesi tự nhiên có cấu trúc từng lớp lá mỏng xếp song song với nhau và có độ quánh dẻo cao, nên có khả năng rất lớn bao phủ niêm mạc đường tiêu hóa. Diosmectit tương tác với glycoprotein của niêm dịch bao phủ đường tiêu hóa nên làm tăng tác dụng bảo vệ lớp niêm mạc đường tiêu hóa khi bị các tác nhân lạ xâm hại. Thuốc có khả năng bám dính và hấp phụ cao tạo hàng rào bảo vệ niêm mạc tiêu hóa. Thuốc có khả năng gắn vào độc tố vi khuẩn ở ruột, nhưng đồng thời cũng có khả năng gắn vào các thuốc khác làm chậm hấp thu hoặc làm mất tác dụng, đặc biệt tetracyclin và trimethoprim (là những kháng sinh có thể được chỉ định ở trẻ em bị ỉa chảy).",
          "block_id": "b0008"
        },
        {
          "type": "text",
          "text": "Diosmectit không cản quang, không làm phân biến màu và với liều thường dùng thuốc không làm thay đổi thời gian chuyển vận sinh lý các chất qua ruột.",
          "block_id": "b0010"
        }
      ]
    },
    {
      "id": "duoc-dong-hoc",
      "title": "Dược động học",
      "heading_block": "b0011",
      "blocks": [
        {
          "type": "text",
          "text": "Diosmectit không hấp thu vào máu qua đường tiêu hóa và bị thải trừ hoàn toàn theo phân.",
          "block_id": "b0012"
        }
      ]
    },
    {
      "id": "chi-dinh",
      "title": "Chỉ định",
      "heading_block": "b0013",
      "blocks": [
        {
          "type": "text",
          "text": "Điều trị triệu chứng đau do viêm thực quản - dạ dày - tá tràng và đại tràng.",
          "block_id": "b0014"
        },
        {
          "type": "text",
          "text": "Điều trị triệu chứng tiêu chảy cấp và mạn tính sau khi đã bồi phụ đủ nước và điện giải mà còn ỉa chảy kéo dài.",
          "block_id": "b0015"
        }
      ]
    },
    {
      "id": "chong-chi-dinh",
      "title": "Chống chỉ định",
      "heading_block": "b0016",
      "blocks": [
        {
          "type": "text",
          "text": "Mẫn cảm với diosmectit.",
          "block_id": "b0017"
        },
        {
          "type": "text",
          "text": "Bệnh nhân không dung nạp fructose.",
          "block_id": "b0018"
        },
        {
          "type": "text",
          "text": "Không dùng chữa ỉa chảy cấp mất nước và điện giải nặng cho trẻ em, khi chưa bồi phụ đủ nước và điện giải.",
          "block_id": "b0019"
        }
      ]
    },
    {
      "id": "than-trong",
      "title": "Thận trọng",
      "heading_block": "b0020",
      "blocks": [
        {
          "type": "text",
          "text": "Nếu tiêu chảy mất nước cần bù nước kết hợp dùng thuốc bằng đường uống hoặc tiêm truyền dịch tĩnh mạch, số lượng nước cần bù tùy theo tuổi, cơ địa người bệnh và mức độ bị tiêu chảy. Cần thận trọng khi dùng diosmectit để điều trị tiêu chảy nặng, vì thuốc có thể làm thay đổi độ đặc của phân và chưa biết có ngăn được mất nước và điện giải còn tiếp tục trong ỉa chảy cấp.",
          "block_id": "b0021"
        },
        {
          "type": "text",
          "text": "Cần thận trọng khi dùng diosmectit để điều trị tiêu chảy cấp cho người bệnh có tiền sử táo bón nặng vì dễ làm táo bón nặng thêm.",
          "block_id": "b0022"
        },
        {
          "type": "text",
          "text": "Cần thông báo cho người bệnh tự bổ sung nước như nước muối, nước đường để bù lại lượng nước đã mất do ỉa chảy. Lượng nước uống trung bình 1 ngày là 2 lít ở người lớn. Duy trì dinh dưỡng trong thời gian ỉa chảy, không ăn đồ ăn sống, đồ uống lạnh có đá.",
          "block_id": "b0023"
        }
      ]
    },
    {
      "id": "thoi-ky-mang-thai",
      "title": "Thời kỳ mang thai",
      "heading_block": "b0024",
      "blocks": [
        {
          "type": "text",
          "text": "Không có ghi nhận quái thai khi dùng thuốc ở động vật. Chỉ dùng thuốc khi thật cần thiết.",
          "block_id": "b0025"
        }
      ]
    },
    {
      "id": "thoi-ky-cho-con-bu",
      "title": "Thời kỳ cho con bú",
      "heading_block": "b0026",
      "blocks": [
        {
          "type": "text",
          "text": "Không có chống chỉ định với phụ nữ thời kỳ cho con bú. Chỉ dùng thuốc khi thật cần thiết",
          "block_id": "b0027"
        }
      ]
    },
    {
      "id": "tac-dung-khong-mong-muon-adr",
      "title": "Tác dụng không mong muốn (ADR)",
      "heading_block": "b0028",
      "blocks": [
        {
          "type": "text",
          "text": "Các ADR phần lớn xảy ra ở đường tiêu hóa.",
          "block_id": "b0029"
        },
        {
          "type": "text",
          "text": "Thường gặp: táo bón.",
          "block_id": "b0030"
        },
        {
          "type": "text",
          "text": "Ít gặp: đầy hơi, nôn.",
          "block_id": "b0031"
        }
      ]
    },
    {
      "id": "huong-dan-cach-xu-tri-adr",
      "title": "Hướng dẫn cách xử trí ADR",
      "heading_block": "b0032",
      "blocks": [
        {
          "type": "text",
          "text": "Cần giảm liều khi bị táo bón.",
          "block_id": "b0033"
        }
      ]
    },
    {
      "id": "lieu-luong-va-cach-dung",
      "title": "Liều lượng và cách dùng",
      "heading_block": "b0034",
      "blocks": [
        {
          "type": "text",
          "text": "Cách dùng: Pha gói thuốc thành dịch treo trước khi dùng. Trẻ em:",
          "block_id": "b0035"
        },
        {
          "type": "text",
          "text": "Hòa mỗi gói thuốc với khoảng 50 ml nước, trước mỗi lần dùng thuốc cần lắc hoặc khuấy đều. Có thể thay nước bằng dịch thức ăn như cháo, nước canh, nước rau hoặc trộn kỹ với thức ăn nửa lỏng như món nghiền rau - quả. Người lớn: Pha 1 gói vào 1/4 cốc nước ấm, khuấy đều. Uống sau bữa ăn với người bệnh viêm thực quản.",
          "block_id": "b0036"
        },
        {
          "type": "text",
          "text": "Uống xa bữa ăn với các chỉ định khác.",
          "block_id": "b0037"
        },
        {
          "type": "subheading",
          "text": "Liều lượng",
          "block_id": "b0038"
        },
        {
          "type": "subheading",
          "text": "Trẻ em:",
          "block_id": "b0039"
        },
        {
          "type": "text",
          "text": "Dưới 1 tuổi: 1 gói/ngày. Trường hợp tiêu chảy cấp: 2 gói/ngày trong 3 ngày, sau đó giảm xuống 1 gói/ngày. Từ 1 - 2 tuổi: 2 gói/ ngày. Trường hợp tiêu chảy cấp: 4 gói/ngày trong 3 ngày sau đó giảm xuống 2 gói/ngày.",
          "block_id": "b0040"
        },
        {
          "type": "text",
          "text": "Trên 2 tuổi: 2 - 3 gói/ngày. Trường hợp tiêu chảy cấp: 4 gói/ngày trong 3 ngày, sau đó giảm xuống 2 gói/ngày.",
          "block_id": "b0041"
        },
        {
          "type": "subheading",
          "text": "Người lớn:",
          "block_id": "b0042"
        },
        {
          "type": "text",
          "text": "Mỗi lần 1 gói, 3 gói/ngày. Trường hợp tiêu chảy cấp liều khởi đầu có thể tới ngày 6 gói.",
          "block_id": "b0043"
        },
        {
          "type": "text",
          "text": "Riêng viêm loét trực tràng dùng cách thụt.",
          "block_id": "b0044"
        },
        {
          "type": "subheading",
          "text": "Thụt trực tràng:",
          "block_id": "b0045"
        },
        {
          "type": "text",
          "text": "Mỗi lần 1 - 3 gói hòa với 50 - 100 ml nước ấm, rồi thụt. Ngày 1 - 3 lần.",
          "block_id": "b0046"
        }
      ]
    },
    {
      "id": "tuong-tac-thuoc",
      "title": "Tương tác thuốc",
      "heading_block": "b0047",
      "blocks": [
        {
          "type": "text",
          "text": "Diosmectit có thể hấp phụ một số thuốc khác, do đó có thể ảnh hưởng đến thời gian và tỷ lệ hấp thu của các thuốc đó, nên uống diosmectit sau khi uống thuốc cần hấp thu khoảng 2 - 3 giờ.",
          "block_id": "b0048"
        }
      ]
    },
    {
      "id": "tuong-ky",
      "title": "Tương kỵ",
      "heading_block": "b0049",
      "blocks": [
        {
          "type": "text",
          "text": "Cần tránh ẩm.",
          "block_id": "b0050"
        }
      ]
    },
    {
      "id": "qua-lieu-va-xu-tri",
      "title": "Quá liều và xử trí",
      "heading_block": "b0051",
      "blocks": [
        {
          "type": "text",
          "text": "Triệu chứng: Dùng thuốc quá liều có thể dẫn đến táo bón hoặc ỉa chảy.",
          "block_id": "b0052"
        },
        {
          "type": "text",
          "text": "Xử trí: Cần ngừng dùng thuốc và điều trị triệu chứng.",
          "block_id": "b0053"
        }
      ]
    },
    {
      "id": "cap-nhat-lan-cuoi",
      "title": "Cập nhật lần cuối",
      "heading_block": "b0054",
      "blocks": [
        {
          "type": "text",
          "text": "2018.",
          "block_id": "b0054"
        }
      ]
    }
  ],
