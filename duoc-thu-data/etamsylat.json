    {
      "id": "b0009",
      "type": "paragraph",
      "text": "Etamsylat là một thuốc cầm máu. Thuốc duy trì sự ổn định của thành mao mạch và hiệu chỉnh sự kết dính bất thường của tiểu cầu.",
      "page": 700,
      "printed_page": 706,
      "column": 0,
      "bbox": [
        43.94,
        254.73,
        298.27,
        279.58
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0010",
      "type": "paragraph",
      "text": "Etamsylat được dùng để phòng và kiểm soát chảy máu ở các mạch máu nhỏ.",
      "page": 700,
      "printed_page": 706,
      "column": 0,
      "bbox": [
        43.94,
        278.84,
        298.27,
        303.69
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0011",
      "type": "heading",
      "level": 2,
      "text": "Dược động học",
      "page": 700,
      "printed_page": 706,
      "column": 0,
      "bbox": [
        43.94,
        305.79,
        105.04,
        318.94
      ],
      "style": {
