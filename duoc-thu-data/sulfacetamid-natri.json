        }
      ]
    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Mụn trứng cá: Bôi một lớp mỏng lên vùng da bị bệnh, 2 lần/ngày.",
      "page": 1509,
      "printed_page": 1514,
      "column": 0,
      "bbox": [
        43.43,
        610.94,
        293.36,
        623.74
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Mụn trứng cá: Bôi một lớp mỏng lên vùng da bị bệnh, 2 lần/ngày.",
