    {
      "id": "b0014",
      "type": "paragraph",
      "text": "Natri thiosulfat hấp thu kém qua đường tiêu hóa.",
      "page": 1176,
      "printed_page": 1182,
      "column": 0,
      "bbox": [
        35.43,
        387.18,
        222.93,
        399.98
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Natri thiosulfat hấp thu kém qua đường tiêu hóa. ",
          "bbox": [
            35.43,
            387.18,
            222.93,
            399.98
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
