  "sections": [
    {
      "id": "dang-thuoc-va-ham-luong",
      "title": "Dạng thuốc và hàm lượng",
      "heading_block": "b0005",
      "blocks": [
        {
          "type": "text",
          "text": "Thuốc dùng dưới dạng muối ambroxol hydroclorid:",
          "block_id": "b0006"
        },
        {
          "type": "text",
          "text": "Viên nén: 30 mg.",
          "block_id": "b0007"
        },
        {
          "type": "text",
          "text": "Dung dịch uống: 30 mg/5 ml, lọ 50 ml.",
          "block_id": "b0008"
        },
        {
          "type": "text",
          "text": "Khí dung: 15 mg/2 ml.",
          "block_id": "b0009"
        },
        {
          "type": "text",
          "text": "Sirô: 15 mg/5 ml, 30 mg/5 ml.",
          "block_id": "b0010"
        },
        {
          "type": "text",
          "text": "Nang giải phóng kéo dài: 75 mg.",
          "block_id": "b0011"
        }
      ]
    },
    {
      "id": "duoc-luc-hoc",
      "title": "Dược lực học",
      "heading_block": "b0012",
      "blocks": [
        {
          "type": "text",
          "text": "Ambroxol là một chất chuyển hóa của bromhexin, có tác dụng và công dụng tương tự như bromhexin. Ambroxol có tác dụng làm đờm lỏng hơn, ít quánh hơn nên dễ bị tống ra ngoài, vì vậy thuốc có tác dụng long đờm.",
          "block_id": "b0013"
        },
        {
          "type": "text",
          "text": "Ambroxol có thể kích thích tổng hợp và bài tiết chất diện hoạt phế nang. Thuốc đã được coi là một chất hoạt hóa bề mặt. Tuy vậy, thuốc không có hiệu quả khi dùng cho người mẹ để phòng hội chứng suy hô hấp ở trẻ sơ sinh, nhưng thuốc có hiệu quả khiêm tốn khi điều trị sớm cho trẻ nhỏ phát bệnh.",
          "block_id": "b0014"
        }
      ]
    },
    {
      "id": "duoc-dong-hoc",
      "title": "Dược động học",
      "heading_block": "b0015",
      "blocks": [
        {
          "type": "text",
          "text": "Ambroxol hấp thu nhanh sau khi uống, thuốc khuếch tán nhanh từ máu đến mô với nồng độ thuốc cao nhất trong phổi. Sinh khả dụng khoảng 70%. Nồng độ tối đa trong huyết tương đạt được trong vòng 0,5 - 3 giờ sau khi dùng thuốc. Với liều điều trị, thuốc liên kết với protein huyết tương xấp xỉ 90%. Ambroxol được chuyển hóa chủ yếu ở gan. Nửa đời thải trừ cuối khoảng 10 giờ. Thuốc bài tiết qua thận khoảng 83%.",
          "block_id": "b0016"
        }
      ]
    },
    {
      "id": "chi-dinh",
      "title": "Chỉ định",
      "heading_block": "b0017",
      "blocks": [
        {
          "type": "text",
          "text": "Ðiều trị các rối loạn tiết dịch phế quản, đặc biệt trong các giai đoạn của viêm phế quản cấp tính, giai đoạn cấp tính của các bệnh phế quản - phổi mạn tính.",
          "block_id": "b0018"
        }
      ]
    },
    {
      "id": "chong-chi-dinh",
      "title": "Chống chỉ định",
      "heading_block": "b0019",
      "blocks": [
        {
          "type": "text",
          "text": "Quá mẫn với ambroxol.",
          "block_id": "b0020"
        },
        {
          "type": "text",
          "text": "Loét dạ dày - tá tràng tiến triển.",
          "block_id": "b0021"
        }
      ]
    },
    {
      "id": "than-trong",
      "title": "Thận trọng",
      "heading_block": "b0022",
      "blocks": [
        {
          "type": "text",
          "text": "Cần chú ý với người bị loét đường tiêu hóa và các trường hợp ho ra máu, vì ambroxol có thể làm tan các cục đông fibrin và làm xuất huyết trở lại. Chỉ điều trị ambroxol một đợt ngắn, nếu không đỡ phải thăm khám lại.",
          "block_id": "b0023"
        }
      ]
    },
    {
      "id": "thoi-ky-mang-thai",
      "title": "Thời kỳ mang thai",
      "heading_block": "b0024",
      "blocks": [
        {
          "type": "text",
          "text": "Chưa có đủ số liệu lâm sàng dùng thuốc trong thời kỳ mang thai.",
          "block_id": "b0025"
        },
        {
          "type": "text",
          "text": "Khuyến cáo không nên dùng thuốc trong thời kỳ mang thai.",
          "block_id": "b0026"
        }
      ]
    },
    {
      "id": "thoi-ky-cho-con-bu",
      "title": "Thời kỳ cho con bú",
      "heading_block": "b0027",
      "blocks": [
        {
          "type": "text",
          "text": "Không dùng thuốc trong thời kỳ cho con bú.",
          "block_id": "b0028"
        }
      ]
    },
    {
      "id": "tac-dung-khong-mong-muon-adr",
      "title": "Tác dụng không mong muốn (ADR)",
      "heading_block": "b0029",
      "blocks": [
        {
          "type": "subheading",
          "text": "Thường gặp",
          "block_id": "b0030"
        },
        {
          "type": "text",
          "text": "Tiêu hóa: ỉa chảy, sau khi tiêm gây ợ nóng, khó tiêu, đôi khi buồn nôn, nôn.",
          "block_id": "b0031"
        },
        {
          "type": "subheading",
          "text": "Ít gặp",
          "block_id": "b0032"
        },
        {
          "type": "text",
          "text": "Dị ứng, chủ yếu phát ban.",
          "block_id": "b0033"
        },
        {
          "type": "subheading",
          "text": "Hiếm gặp",
          "block_id": "b0034"
        },
        {
          "type": "text",
          "text": "Phản ứng kiểu phản vệ và phản ứng nặng ở da (hồng ban đa dạng, hội chứng Stevens-Johnson, nhiễm độc hoại tử biểu bì), miệng khô và tăng các transaminase.",
          "block_id": "b0035"
        }
      ]
    },
    {
      "id": "huong-dan-cach-xu-tri-adr",
      "title": "Hướng dẫn cách xử trí ADR",
      "heading_block": "b0036",
      "blocks": [
        {
          "type": "text",
          "text": "Ngừng điều trị nếu cần thiết.",
          "block_id": "b0037"
        }
      ]
    },
    {
      "id": "lieu-luong-va-cach-dung",
      "title": "Liều lượng và cách dùng",
      "heading_block": "b0038",
      "blocks": [
        {
          "type": "text",
          "text": "Uống: Uống sau khi ăn.",
          "block_id": "b0039"
        },
        {
          "type": "text",
          "text": "Người lớn và trẻ em > 10 tuổi: 30 - 60 mg/lần, 2 lần/ngày. Dạng nang giải phóng kéo dài: 1 viên 75 mg/ngày.",
          "block_id": "b0040"
        },
        {
          "type": "text",
          "text": "Trẻ em 6 - 10 tuổi: 15 - 30 mg/lần, ngày 2 lần.",
          "block_id": "b0041"
        },
        {
          "type": "subheading",
          "text": "Khí dung:",
          "block_id": "b0042"
        },
        {
          "type": "text",
          "text": "Người lớn và trẻ em > 10 tuổi: 15 mg/lần, ngày 1 - 2 lần.",
          "block_id": "b0043"
        },
        {
          "type": "text",
          "text": "Trẻ em 6 - 10 tuổi: 7,5 mg/lần, ngày 2 - 3 lần.",
          "block_id": "b0044"
        }
      ]
    },
    {
      "id": "tuong-tac-thuoc",
      "title": "Tương tác thuốc",
      "heading_block": "b0045",
      "blocks": [
        {
          "type": "text",
          "text": "Dùng ambroxol với kháng sinh (amoxicilin, cefuroxim, erythromycin, doxycyclin) làm tăng nồng độ kháng sinh trong nhu mô phổi.",
          "block_id": "b0046"
        },
        {
          "type": "text",
          "text": "Không phối hợp ambroxol với thuốc chống ho (thí dụ codein) hoặc thuốc làm khô đờm (thí dụ atropin).",
          "block_id": "b0047"
        }
      ]
    },
    {
      "id": "qua-lieu-va-xu-tri",
      "title": "Quá liều và xử trí",
      "heading_block": "b0048",
      "blocks": [
        {
          "type": "text",
          "text": "Chưa có báo cáo về dấu hiệu quá liều. Nếu xảy ra, cần ngừng thuốc và điều trị triệu chứng.",
          "block_id": "b0049"
        }
      ]
    },
    {
      "id": "cap-nhat-lan-cuoi",
      "title": "Cập nhật lần cuối",
      "heading_block": "b0050",
      "blocks": [
        {
          "type": "text",
          "text": "2016.",
          "block_id": "b0050"
        }
      ]
    }
