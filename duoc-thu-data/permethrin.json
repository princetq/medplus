        }
      ]
    },
    {
      "id": "b0039",
      "type": "paragraph",
      "text": "Trường hợp có viêm da, ngứa, bỏng rát da, có thể dùng corticoid bôi tại chỗ hoặc uống kháng histamin để làm giảm các triệu chứng.",
      "page": 1291,
      "printed_page": 1297,
      "column": 0,
      "bbox": [
        43.43,
        712.22,
        297.77,
        737.16
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0040",
      "type": "paragraph",
      "text": "Trường hợp nghi ngờ phản ứng quá mẫn với thuốc, cần dừng thuốc.",
      "page": 1291,
      "printed_page": 1297,
      "column": 0,
      "bbox": [
        43.43,
        736.5,
        295.39,
        749.3
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Trường hợp nghi ngờ phản ứng quá mẫn với thuốc, cần dừng thuốc.",
          "bbox": [
            43.43,
            736.5,
