    {
      "id": "b0023",
      "type": "paragraph",
      "text": "Hiệu quả và an toàn của permethrin dùng ngoài da chưa được chứng minh ở trẻ dưới 2 tháng tuổi.",
      "page": 1291,
      "printed_page": 1297,
      "column": 0,
      "bbox": [
        43.43,
