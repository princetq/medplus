      "title": "Dạng thuốc và hàm lượng",
      "heading_block": "b0005",
      "blocks": [
        {
          "type": "text",
          "text": "Kem: 10%, 20%, 22%, 30%, 39%, 40%, 41%, 45%, 47%, 50%.",
          "block_id": "b0006"
        },
        {
          "type": "text",
          "text": "Gel: 39%, 40%, 45%.",
          "block_id": "b0007"
        },
        {
          "type": "text",
          "text": "Thuốc mỡ: 10%, 20%, 22%, 40%.",
          "block_id": "b0008"
        },
        {
          "type": "text",
          "text": "Dung dịch: 45%, 50%.",
          "block_id": "b0009"
        },
        {
          "type": "text",
          "text": "Hỗn dịch: 40%, 50%.",
          "block_id": "b0010"
        },
        {
          "type": "text",
          "text": "Xà phòng: 20%, 35%, 40%.",
          "block_id": "b0011"
        },
        {
          "type": "text",
          "text": "Nhũ tương: 40%, 45%, 50%.",
          "block_id": "b0012"
        },
        {
          "type": "text",
          "text": "Nhũ tương dùng ngoài (lotion): 5%, 10%, 15%, 25%, 40%.",
          "block_id": "b0013"
        },
        {
          "type": "text",
          "text": "Viên nén (trong bộ kit chẩn đoán vi khuẩn HP): 50 mg, 100 mg.",
          "block_id": "b0014"
        },
        {
          "type": "text",
          "text": "Thuốc bột (trong bộ kit chẩn đoán vi khuẩn HP): 45 mg, 75 mg.",
