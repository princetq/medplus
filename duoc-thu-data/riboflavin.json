          "italic": false
        }
      ]
    },
    {
      "id": "b0047",
      "type": "paragraph",
      "text": "Đã gặp một số ca “thiếu riboflavin” ở người đã dùng clopromazin, imipramin, amitriptylin và adriamycin.",
      "page": 1414,
      "printed_page": 1420,
      "column": 0,
      "bbox": [
        35.43,
        75.28,
        289.78,
        100.18
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0048",
      "type": "paragraph",
      "text": "Rượu có thể gây cản trở hấp thu riboflavin ở ruột.",
      "page": 1414,
      "printed_page": 1420,
      "column": 0,
      "bbox": [
        35.43,
        99.5,
        224.26,
        112.29
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Rượu có thể gây cản trở hấp thu riboflavin ở ruột.",
          "bbox": [
            35.43,
            99.5,
            224.26,
            112.29
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0049",
      "type": "paragraph",
      "text": "Probenecid sử dụng cùng riboflavin gây giảm hấp thu riboflavin ở dạ dày, ruột.",
