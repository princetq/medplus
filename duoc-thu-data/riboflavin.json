    },
    {
      "id": "b0009",
      "type": "paragraph",
      "text": "Thuốc tiêm: 5 mg/ml, 10 mg/ml. Thường kết hợp với các vitamin khác trong các dung dịch tiêm truyền đa vitamin.",
      "page": 1413,
      "printed_page": 1419,
      "column": 0,
      "bbox": [
        43.43,
        338.43,
        297.77,
        363.3
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0010",
      "type": "heading",
      "level": 2,
      "text": "Dược lực học",
      "page": 1413,
      "printed_page": 1419,
      "column": 0,
      "bbox": [
        43.43,
        365.42,
        99.41,
        378.57
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Dược lực học ",
          "bbox": [
            43.43,
            365.42,
            99.41,
            378.57
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
