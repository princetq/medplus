    {
      "id": "b0035",
      "type": "paragraph",
      "text": "Không thấy có ADR khi sử dụng riboflavin. Dùng liều cao riboflavin thì nước tiểu sẽ chuyển màu vàng nhạt, gây sai lệch đối với một số xét nghiệm nước tiểu trong phòng thí nghiệm.",
      "page": 1413,
      "printed_page": 1419,
      "column": 1,
      "bbox": [
        307.39,
        518.13,
        561.72,
        555.2
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0036",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
