    {
      "id": "b0010",
      "type": "paragraph",
      "text": "Biotin là một vitamin hòa tan trong nước thuộc vitamin nhóm B.",
      "page": 295,
      "printed_page": 301,
      "column": 1,
      "bbox": [
        299.39,
        268.26,
        553.71,
        281.06
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Biotin là một vitamin hòa tan trong nước thuộc vitamin nhóm B. ",
          "bbox": [
            299.39,
            268.26,
            553.71,
            281.06
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
