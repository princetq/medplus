  "sections": [
    {
      "id": "dang-thuoc-va-ham-luong",
      "title": "Dạng thuốc và hàm lượng",
      "heading_block": "b0005",
      "blocks": [
        {
          "type": "text",
          "text": "Cốm: 50 mg, 100 mg/gói.",
          "block_id": "b0006"
        },
        {
          "type": "text",
          "text": "Viên nén: 200 mg, 400 mg; viên nén giải phóng kéo dài: 600 mg, 1 200 mg.",
          "block_id": "b0007"
        },
        {
          "type": "text",
          "text": "Dung dịch uống, sirô: 100 mg/5 ml, 200 mg/5 ml.",
          "block_id": "b0008"
        },
        {
          "type": "text",
          "text": "Chế phẩm dạng thuốc phối hợp với acetaminophen, dyphylin,",
          "block_id": "b0009"
        },
        {
          "type": "text",
          "text": "theophylin, pseudoephedrin, codein, dextromethorphan, phenylephrin, ephedrin, clorpheniramin.",
          "block_id": "b0010"
        }
      ]
    },
    {
      "id": "duoc-luc-hoc",
      "title": "Dược lực học",
      "heading_block": "b0011",
      "blocks": [
        {
          "type": "text",
          "text": "Guaifenesin có tác dụng long đờm do kích thích tăng tiết dịch ở đường hô hấp, làm tăng thể tích và giảm độ nhớt của dịch tiết ở khí quản và phế quản. Nhờ vậy, thuốc làm tăng hiệu quả của phản xạ ho và làm dễ tống đờm ra ngoài hơn. Cơ chế này khác với cơ chế của các thuốc chống ho, guaifenesin không làm mất ho. Thuốc được chỉ định để điều trị triệu chứng ho có đờm quánh đặc khó khạc do cảm lạnh, viêm nhẹ đường hô hấp trên. Thuốc thường được kết hợp với các thuốc giãn phế quản, thuốc chống sung huyết mũi, kháng histamin hoặc thuốc chống ho opiat.",
          "block_id": "b0012"
        }
      ]
    },
    {
      "id": "duoc-dong-hoc",
      "title": "Dược động học",
      "heading_block": "b0013",
      "blocks": [
        {
          "type": "text",
          "text": "Sau khi uống, thuốc hấp thu tốt từ đường tiêu hóa. Trong máu, 60% lượng thuốc bị thủy phân trong vòng 7 giờ. Chất chuyển hóa không còn hoạt tính được thải trừ qua thận. Sau khi uống 400 mg guaifenesin, không phát hiện thấy thuốc ở dạng nguyên vẹn trong nước tiểu. Nửa đời thải trừ của guaifenesin khoảng 1 giờ.",
          "block_id": "b0014"
        }
      ]
    },
    {
      "id": "chi-dinh",
      "title": "Chỉ định",
      "heading_block": "b0015",
      "blocks": [
        {
          "type": "text",
          "text": "Làm long đờm khi ho có đờm đặc, ứ đọng đờm, gây cản trở đường hô hấp.",
          "block_id": "b0016"
        }
      ]
    },
    {
      "id": "chong-chi-dinh",
      "title": "Chống chỉ định",
      "heading_block": "b0017",
      "blocks": [
        {
          "type": "text",
          "text": "Quá mẫn với guaifenesin.",
          "block_id": "b0018"
        },
        {
          "type": "text",
          "text": "Trẻ em dưới 4 tuổi.",
          "block_id": "b0019"
        }
      ]
    },
    {
      "id": "than-trong",
      "title": "Thận trọng",
      "heading_block": "b0020",
      "blocks": [
        {
          "type": "text",
          "text": "Không tự sử dụng guaifenesin (trừ khi có chỉ định của bác sĩ) trong các trường hợp ho kéo dài hay mạn tính như ở bệnh nhân hút thuốc, bị hen, viêm phế quản mạn tính, khí thũng phổi hoặc ho có quá nhiều đờm.",
          "block_id": "b0021"
        },
        {
          "type": "text",
          "text": "Nếu ho kéo dài trên 7 ngày hoặc ho kèm sốt, nổi mẩn, đau đầu kéo dài phải ngừng ngay thuốc và tham khảo ý kiến bác sĩ.",
          "block_id": "b0022"
        },
        {
          "type": "text",
          "text": "Bệnh nhân cần được uống nước đầy đủ trong khi sử dụng thuốc giúp làm lỏng đờm quánh.",
          "block_id": "b0023"
        },
        {
          "type": "text",
          "text": "Guaifenesin được coi là không an toàn khi sử dụng cho bệnh nhân bị rối loạn chuyển hóa porphyrin do thuốc gây rối loạn chuyển hóa porphyrin trên động vật thí nghiệm.",
          "block_id": "b0024"
        },
        {
          "type": "text",
          "text": "Sử dụng ở trẻ em: Guaifenesin đã từng được dùng cho trẻ em. Tuy nhiên đã có nhiều báo cáo về ngộ độc và quá liều, có thể gây tử vong do dùng các chế phẩm thuốc ho và chữa cảm lạnh không kê đơn có chứa các chất long đờm (bao gồm cả guaifenesin) cho trẻ nhỏ. Vì vậy khuyến cáo không tự ý sử dụng guaifenesin cho trẻ dưới 4 tuổi trừ khi có chỉ định của bác sĩ.",
          "block_id": "b0025"
        },
        {
          "type": "text",
          "text": "Một số kết hợp không hợp lý như kết hợp guaifenesin với thuốc ho, vì phản xạ ho giúp tống đờm ra ngoài, nhất là ở người cao tuổi.",
          "block_id": "b0026"
        },
        {
          "type": "text",
          "text": "Khi dùng các chế phẩm kết hợp guaifenesin với các thuốc khác (như acetaminophen, clorpheniramin, codein, dextromethorphan, ephedrin, phenylephrin, pseudoephedrin) phải chú ý đến phần thận trọng và chống chỉ định của mỗi thuốc.",
          "block_id": "b0027"
        }
      ]
    },
    {
      "id": "thoi-ky-mang-thai",
      "title": "Thời kỳ mang thai",
      "heading_block": "b0028",
      "blocks": [
        {
          "type": "text",
          "text": "Chưa có nghiên cứu có kiểm soát đủ lớn trên phụ nữ mang thai. Do chưa thể loại trừ hoàn toàn nguy cơ của thuốc đối với thai, cần thận trọng và chỉ nên sử dụng guaifenesin cho phụ nữ mang thai khi xét thấy lợi ích cho mẹ vượt trội nguy cơ đối với thai.",
          "block_id": "b0029"
        }
      ]
    },
    {
      "id": "thoi-ky-cho-con-bu",
      "title": "Thời kỳ cho con bú",
      "heading_block": "b0030",
      "blocks": [
        {
          "type": "text",
          "text": "Chưa có dữ liệu về việc sử dụng guaifenesin ở phụ nữ cho con bú.",
          "block_id": "b0031"
        },
        {
          "type": "text",
          "text": "Cần thận trọng khi dùng guaifenesin cho đối tượng bệnh nhân này.",
          "block_id": "b0032"
        }
      ]
    },
    {
      "id": "tac-dung-khong-mong-muon-adr",
      "title": "Tác dụng không mong muốn (ADR)",
      "heading_block": "b0033",
      "blocks": [
        {
          "type": "text",
          "text": "Thường gặp: nôn hoặc buồn nôn, kích ứng đường tiêu hóa.",
          "block_id": "b0034"
        },
        {
          "type": "subheading",
          "text": "Hiếm gặp hoặc ít gặp",
          "block_id": "b0035"
        },
        {
          "type": "text",
          "text": "Chóng mặt, đau đầu, tiêu chảy, đau bụng, ban da, mày đay. Hay gặp khi dùng liều rất cao.",
          "block_id": "b0036"
        },
        {
          "type": "text",
          "text": "Sỏi thận đã được báo cáo ở những bệnh nhân lạm dụng chế phẩm có chứa guaifenesin.",
          "block_id": "b0037"
        }
      ]
    },
    {
      "id": "huong-dan-cach-xu-tri-adr",
      "title": "Hướng dẫn cách xử trí ADR",
      "heading_block": "b0038",
      "blocks": [
        {
          "type": "text",
          "text": "ADR thường nhẹ, tự hết. Nếu nôn nhiều hoặc đau bụng nhiều nên ngừng thuốc. Tránh dùng thuốc kéo dài.",
          "block_id": "b0039"
        }
      ]
    },
    {
      "id": "lieu-luong-va-cach-dung",
      "title": "Liều lượng và cách dùng",
      "heading_block": "b0040",
      "blocks": [
        {
          "type": "text",
          "text": "Cách dùng: Viên thuốc tác dụng kéo dài: Phải nuốt nguyên viên, không được bẻ, nhai hoặc nghiền và không nên dùng cho trẻ em dưới 12 tuổi. Uống thuốc với một cốc nước đầy.",
          "block_id": "b0041"
        },
        {
          "type": "subheading",
          "text": "Liều lượng",
          "block_id": "b0042"
        },
        {
          "type": "text",
          "text": "Người lớn và trẻ em từ 12 tuổi trở lên: 200 - 400 mg, mỗi 4 giờ.",
          "block_id": "b0043"
        },
        {
          "type": "text",
          "text": "Nếu dùng chế phẩm tác dụng kéo dài: 600 mg hoặc 1,2 g, mỗi 12 giờ. Liều tối đa: 2,4 g mỗi ngày.",
          "block_id": "b0044"
        },
        {
          "type": "text",
          "text": "Trẻ em 6 đến dưới 12 tuổi: 100 - 200 mg, mỗi 4 giờ. Nếu dùng chế phẩm tác dụng kéo dài: 600 mg mỗi 12 giờ. Liều tối đa: 1,2 g mỗi ngày.",
          "block_id": "b0045"
        },
        {
          "type": "text",
          "text": "Trẻ em 4 đến dưới 6 tuổi: 50 - 100 mg, mỗi 4 giờ. Liều tối đa:",
          "block_id": "b0046"
        },
        {
          "type": "text",
          "text": "600 mg/ngày.",
          "block_id": "b0047"
        },
        {
          "type": "text",
          "text": "Liều uống theo Anh: Liều uống mỗi lần như trên nhưng chỉ uống tối đa 4 lần/1 ngày.",
          "block_id": "b0048"
        }
      ]
    },
    {
      "id": "tuong-tac-thuoc",
      "title": "Tương tác thuốc",
      "heading_block": "b0049",
      "blocks": [
        {
          "type": "text",
          "text": "Tương tác thuốc - thuốc: Không sử dụng chế phẩm phối hợp guaifenesin với dextromethorphan cho bệnh nhân đang dùng thuốc ức chế MAO (trong vòng 14 ngày) và ngược lại không dùng thuốc ức chế MAO cho bệnh nhân đang dùng chế phẩm phối hợp guaifenesin với dextromethorphan (trong vòng 14 ngày).",
          "block_id": "b0050"
        },
        {
          "type": "text",
          "text": "Cần thận trọng khi sử dụng chế phẩm phối hợp guaifenesin với phenylpropanolamin cho bệnh nhân tăng huyết áp, có bệnh tim, đái tháo đường hay bệnh mạch ngoại vi, phì đại tuyến tiền liệt và glôcôm.",
          "block_id": "b0051"
        },
        {
          "type": "text",
          "text": "Tương tác thuốc - xét nghiệm: Sử dụng guaifenesin có thể cho kết quả dương tính giả ở xét nghiệm đo acid vanilylmandelic trong nước tiểu. Cần ngừng dùng guaifenesin 48 giờ trước khi lấy mẫu nước tiểu để làm xét nghiệm này.",
          "block_id": "b0052"
        }
      ]
    },
    {
      "id": "qua-lieu-va-xu-tri",
      "title": "Quá liều và xử trí",
      "heading_block": "b0053",
      "blocks": [
        {
          "type": "text",
          "text": "Triệu chứng cấp tính: Nếu dùng guaifenesin với liều cao hơn liều điều trị thông thường có thể gây buồn ngủ, buồn nôn, nôn.",
          "block_id": "b0054"
        },
        {
          "type": "text",
          "text": "Xử trí: Rửa dạ dày nếu phát hiện sớm, chữa triệu chứng.",
          "block_id": "b0055"
        },
        {
          "type": "text",
          "text": "Mạn tính: Lạm dụng chế phẩm có chứa guaifenesin có thể gây sỏi thận.",
          "block_id": "b0056"
        }
      ]
    },
    {
      "id": "cap-nhat-lan-cuoi",
      "title": "Cập nhật lần cuối",
      "heading_block": "b0057",
      "blocks": [
        {
          "type": "text",
          "text": "2017.",
          "block_id": "b0057"
        }
      ]
    }
  ],
