    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Cách dùng: Simeticon dùng đường uống. Dạng viên nhai phải nhai kỹ trước khi nuốt. Dạng nang mềm chứa dịch lỏng không được nhai. Lắc kỹ dung dịch thuốc uống trước khi dùng. Uống thuốc vào sau các bữa ăn và trước khi đi ngủ.",
      "page": 1480,
      "printed_page": 1485,
      "column": 0,
      "bbox": [
        35.43,
        594.76,
        289.76,
        643.8
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0039",
