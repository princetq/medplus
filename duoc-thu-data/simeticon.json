  "sections": [
    {
      "id": "dang-thuoc-va-ham-luong",
      "title": "Dạng thuốc và hàm lượng",
      "heading_block": "b0005",
      "blocks": [
        {
          "type": "text",
          "text": "Viên nén: 40 mg; 80 mg, 125 mg.",
          "block_id": "b0006"
        },
        {
          "type": "text",
          "text": "Viên nén để nhai: 80 mg, 125 mg, 150 mg, 166 mg.",
          "block_id": "b0007"
        },
        {
          "type": "text",
          "text": "Nang mềm (chứa chất lỏng): 40 mg; 125 mg, 166 mg, 180 mg, 250 mg.",
          "block_id": "b0008"
        },
        {
          "type": "text",
          "text": "Dung dịch uống: 20 mg/0,3 ml; 600 mg/15 ml; 1 g/15 ml; 1 667 mg/25 ml; 4,5 g/15 ml.",
          "block_id": "b0009"
        },
        {
          "type": "text",
          "text": "Hỗn dịch uống: 40 mg/0,6 mg; 40 mg/ml (lọ 50 ml); 50 mg/5 ml.",
          "block_id": "b0010"
        },
        {
          "type": "text",
          "text": "Thuốc uống nhỏ giọt: 8,4 mg/ml (100 ml).",
          "block_id": "b0011"
        }
      ]
    },
    {
      "id": "duoc-luc-hoc",
      "title": "Dược lực học",
      "heading_block": "b0012",
      "blocks": [
        {
          "type": "text",
          "text": "Simeticon là hỗn hợp polydimethylsiloxan và silicon dioxyd, có tác dụng chống tạo bọt. Simeticon làm giảm sức căng bề mặt của các bọt khí, làm vỡ hoặc kết tụ chúng lại và bị tống ra ngoài, nhờ đó có tác dụng chống đầy hơi. Vì vậy, simeticon có tác dụng làm giảm các triệu chứng liên quan đến có quá nhiều khí ở đường tiêu hóa gây ra ở cả người lớn và trẻ em, như khi nuốt phải nhiều khí vào dạ dày hoặc có một số chất khí được tạo ra ở ruột do sự giáng hóa của những thức ăn không được tiêu hóa bởi các vi khuẩn ruột.",
          "block_id": "b0013"
        },
        {
          "type": "text",
          "text": "Simeticon còn được dùng ở dạng kết hợp với thuốc kháng acid, thuốc chống co thắt và enzym tiêu hóa.",
          "block_id": "b0015"
        }
      ]
    },
    {
      "id": "duoc-dong-hoc",
      "title": "Dược động học",
      "heading_block": "b0016",
      "blocks": [
        {
          "type": "text",
          "text": "Simeticon có tính trơ về sinh lý. Sau khi uống, thuốc không hấp thu qua đường tiêu hóa, cũng không cản trở bài tiết acid dạ dày hoặc hấp thu các chất dinh dưỡng. Simeticon được thải trừ dưới dạng không biến đổi trong phân.",
          "block_id": "b0017"
        }
      ]
    },
    {
      "id": "chi-dinh",
      "title": "Chỉ định",
      "heading_block": "b0018",
      "blocks": [
        {
          "type": "text",
          "text": "Giảm triệu chứng đầy hơi, trướng bụng và các triệu chứng khác liên quan đến quá nhiều khí ở đường tiêu hóa.",
          "block_id": "b0019"
        },
        {
          "type": "text",
          "text": "Simeticon không còn được FDA cấp phép lưu hành ở Mỹ do liên quan đến độ an toàn và hiệu quả của thuốc.",
          "block_id": "b0020"
        }
      ]
    },
    {
      "id": "chong-chi-dinh",
      "title": "Chống chỉ định",
      "heading_block": "b0021",
      "blocks": [
        {
          "type": "text",
          "text": "Quá mẫn với simeticon.",
          "block_id": "b0022"
        },
        {
          "type": "text",
          "text": "Thủng hoặc tắc ruột (đã biết hoặc nghi ngờ).",
          "block_id": "b0023"
        }
      ]
    },
    {
      "id": "than-trong",
      "title": "Thận trọng",
      "heading_block": "b0024",
      "blocks": [
        {
          "type": "text",
          "text": "Thận trọng khi dùng simeticon để điều trị cơn đau bụng ở trẻ nhỏ.",
          "block_id": "b0025"
        },
        {
          "type": "text",
          "text": "Không dùng quá liều khuyến cáo.",
          "block_id": "b0026"
        },
        {
          "type": "text",
          "text": "Tránh đồ uống có carbonat (soda hoặc nước ngọt) hoặc các thức ăn có thể làm tăng lượng khí trong dạ dày.",
          "block_id": "b0027"
        }
      ]
    },
    {
      "id": "thoi-ky-mang-thai",
      "title": "Thời kỳ mang thai",
      "heading_block": "b0028",
      "blocks": [
        {
          "type": "text",
          "text": "Không rõ thuốc có qua được nhau thai hay không, nhưng do hấp thu của simeticon qua ruột bị hạn chế, điều đó làm giảm khả năng phơi nhiễm đối với thai nhi.",
          "block_id": "b0029"
        }
      ]
    },
    {
      "id": "thoi-ky-cho-con-bu",
      "title": "Thời kỳ cho con bú",
      "heading_block": "b0030",
      "blocks": [
        {
          "type": "text",
          "text": "Không biết simeticon có được bài tiết vào sữa mẹ hay không, cũng không có báo cáo về dùng thuốc trong thời kỳ cho con bú. Cần cân nhắc nguy cơ/lợi ích khi sử dụng thuốc này cho bà mẹ đang cho con bú.",
          "block_id": "b0031"
        }
      ]
    },
    {
      "id": "tac-dung-khong-mong-muon-adr",
      "title": "Tác dụng không mong muốn (ADR)",
      "heading_block": "b0032",
      "blocks": [
        {
          "type": "subheading",
          "text": "Thường gặp",
          "block_id": "b0033"
        },
        {
          "type": "text",
          "text": "Tiêu hóa: ỉa chảy (nhẹ), buồn nôn, nôn, ợ.",
          "block_id": "b0034"
        },
        {
          "type": "subheading",
          "text": "Hiếm gặp",
          "block_id": "b0035"
        },
        {
          "type": "text",
          "text": "Táo bón, phản ứng quá mẫn như phát ban, viêm ngứa, phù mặt, phù lưỡi, khó thở.",
          "block_id": "b0036"
        }
      ]
    },
    {
      "id": "lieu-luong-va-cach-dung",
      "title": "Liều lượng và cách dùng",
      "heading_block": "b0037",
      "blocks": [
        {
          "type": "text",
          "text": "Cách dùng: Simeticon dùng đường uống. Dạng viên nhai phải nhai kỹ trước khi nuốt. Dạng nang mềm chứa dịch lỏng không được nhai. Lắc kỹ dung dịch thuốc uống trước khi dùng. Uống thuốc vào sau các bữa ăn và trước khi đi ngủ.",
          "block_id": "b0038"
        },
        {
          "type": "subheading",
          "text": "Liều dùng",
          "block_id": "b0039"
        },
        {
          "type": "text",
          "text": "Người lớn và trẻ em trên 12 tuổi: 40 - 125 mg/lần, 4 lần/ngày.",
          "block_id": "b0040"
        },
        {
          "type": "text",
          "text": "Dùng thuốc cần có sự theo dõi của thầy thuốc. Liều cao hơn liều bình thường cũng đã được dùng. Liều tối đa khi tự điều trị là 500 mg/ngày.",
          "block_id": "b0041"
        },
        {
          "type": "text",
          "text": "Trẻ em 2 - 12 tuổi: 40 mg/lần, 4 lần/ngày. Liều tối đa khi tự điều trị là 240 mg/ngày.",
          "block_id": "b0042"
        },
        {
          "type": "text",
          "text": "Trẻ em dưới 2 tuổi: 20 mg/lần, 4 lần/ngày. Liều tối đa khi tự điều trị là 120 mg/ngày.",
          "block_id": "b0043"
        },
        {
          "type": "text",
          "text": "Trước khi nội soi dạ dày hoặc chụp X-quang ruột, người lớn dùng một liều 67 mg simeticon trong 2,5 ml nước, dưới dạng hỗn dịch uống, phụ với nước bơm làm sạch bóng khí trong quá trình nội soi tiêu hóa.",
          "block_id": "b0044"
        }
      ]
    },
    {
      "id": "tuong-tac-thuoc",
      "title": "Tương tác thuốc",
      "heading_block": "b0045",
      "blocks": [
        {
          "type": "text",
          "text": "Levothyroxin: Có thể làm giảm hấp thu levothyroxin, dẫn đến giảm hiệu quả của levothyroxin, gây giảm năng tuyến giáp. Nếu dùng đồng thời hai thuốc này phải uống cách nhau ít nhất 4 giờ.",
          "block_id": "b0046"
        },
        {
          "type": "text",
          "text": "Theo dõi mức TSH và/hoặc các đánh giá khác về chức năng tuyến giáp khi bắt đầu dùng hoặc khi ngừng dùng simeticon khi điều trị levothyroxin.",
          "block_id": "b0047"
        }
      ]
    },
    {
      "id": "qua-lieu-va-xu-tri",
      "title": "Quá liều và xử trí",
      "heading_block": "b0048",
      "blocks": [
        {
          "type": "text",
          "text": "Không có ghi nhận trường hợp quá liều. Về lý thuyết, táo bón có thể xảy ra nếu quá liều. Điều trị bằng cách bổ sung chất lỏng và theo dõi bệnh nhân.",
          "block_id": "b0049"
        }
      ]
    },
    {
      "id": "cap-nhat-lan-cuoi",
      "title": "Cập nhật lần cuối",
      "heading_block": "b0050",
      "blocks": [
        {
          "type": "text",
          "text": "2018.",
          "block_id": "b0050"
        }
      ]
    }
