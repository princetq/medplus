        35.43,
        643.17,
        80.57,
        655.89
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
