      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 134,
      "printed_page": 140,
      "column": 1,
      "bbox": [
        307.39,
        118.07,
        409.94,
        131.22
      ],
      "style": {
