    {
      "id": "b0035",
      "type": "heading",
      "level": 2,
      "text": "Thời kỳ mang thai",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        687.44,
        374.6,
        700.59
      ],
      "style": {
