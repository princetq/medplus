        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Thận trọng",
          "bbox": [
            299.39,
            501.66,
            345.57,
            514.81
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
