    {
      "id": "b0011",
      "type": "paragraph",
      "text": "Clotrimazol là một thuốc chống nấm tổng hợp thuộc nhóm dẫn chất imidazol được dùng điều trị tại chỗ các trường hợp bệnh nấm Candida bề mặt, nấm ngoài da, lang ben. Cơ chế tác dụng của clotrimazol là liên kết với các phospholipid trong màng tế bào nấm, làm thay đổi tính thấm của màng, gây mất các chất thiết yếu nội bào dẫn đến tiêu hủy tế bào nấm.",
      "page": 497,
      "printed_page": 503,
      "column": 0,
      "bbox": [
        35.43,
        632.07,
        289.77,
        704.87
      ],
      "source": {
        "line_count": 6
      }
    },
    {
      "id": "b0012",
      "type": "subheading",
      "level": 3,
      "text": "Phổ tác dụng:",
      "page": 497,
      "printed_page": 503,
      "column": 0,
      "bbox": [
        35.43,
        704.23,
        89.26,
        716.87
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 0.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-ItalicMT"
        ]
      },
      "spans": [
        {
          "text": "Phổ tác dụng:",
          "bbox": [
            35.43,
            704.23,
            89.26,
            716.87
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
