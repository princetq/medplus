      "v11_fix": "note_title_reclassified_as_heading_alpha5"
    },
    {
      "id": "b0027",
      "type": "paragraph",
      "text": "Không dùng clotrimazol cho điều trị nhiễm nấm toàn thân. Tránh băng kín vùng bôi thuốc.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        513.99,
        553.72,
        538.98
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0028",
      "type": "paragraph",
      "text": "Không dùng clotrimazol đường miệng cho trẻ dưới 3 tuổi, vì chưa xác định hiệu quả và độ an toàn.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        538.37,
        553.72,
        563.35
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0029",
      "type": "paragraph",
      "text": "Nếu có kích ứng hoặc mẫn cảm khi dùng clotrimazol, phải ngừng thuốc và điều trị thích hợp.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        562.74,
        553.71,
        587.72
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0030",
      "type": "paragraph",
      "text": "Clotrimazol dạng kem, nhũ tương dùng ngoài, dung dịch không dùng cho nhãn khoa.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        587.11,
        553.72,
        612.09
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0031",
      "type": "paragraph",
      "text": "Phải điều trị thuốc đủ thời gian cho dù các triệu chứng có thuyên giảm. Sau 4 tuần điều trị, nếu không đỡ cần khám lại.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        611.48,
        553.72,
        636.46
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0032",
      "type": "paragraph",
      "text": "Báo với thầy thuốc nếu có biểu hiện tăng kích ứng ở vùng bôi thuốc (đỏ, ngứa, bỏng, mụn nước, sưng), dấu hiệu của sự quá mẫn.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        635.85,
        553.72,
        660.83
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0033",
      "type": "paragraph",
      "text": "Tránh các nguồn gây nhiễm khuẩn hoặc tái nhiễm.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        660.22,
        491.39,
        673.02
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Tránh các nguồn gây nhiễm khuẩn hoặc tái nhiễm.",
          "bbox": [
            299.39,
            660.22,
            491.39,
            673.02
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Đối với bệnh do nấm Candida không dùng xà phòng có pH acid.",
      "page": 497,
      "printed_page": 503,
      "column": 1,
      "bbox": [
        299.39,
        672.4,
        545.84,
        685.2
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Đối với bệnh do nấm ",
          "bbox": [
            299.39,
            672.4,
            382.25,
            685.2
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        },
        {
