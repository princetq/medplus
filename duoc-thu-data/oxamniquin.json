      }
    },
    {
      "id": "b0053",
      "type": "paragraph",
      "text": "Ở Việt Nam chưa có số liệu tổng kết.",
      "page": 1243,
      "printed_page": 1249,
      "column": 0,
      "bbox": [
        43.43,
        244.12,
