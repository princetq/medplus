      "type": "paragraph",
      "text": "Nên uống thuốc sau bữa ăn. Điều trị trong 1 - 3 ngày.",
      "page": 1243,
      "printed_page": 1249,
      "column": 0,
      "bbox": [
        43.43,
        304.39,
        245.84,
        317.19
