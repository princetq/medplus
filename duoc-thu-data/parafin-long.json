  "sections": [
    {
      "id": "dang-thuoc-va-ham-luong",
      "title": "Dạng thuốc và hàm lượng",
      "heading_block": "b0005",
      "blocks": [
        {
          "type": "text",
          "text": "Dạng lỏng dùng để uống hoặc thụt tháo phân.",
          "block_id": "b0006"
        }
      ]
    },
    {
      "id": "duoc-luc-hoc",
      "title": "Dược lực học",
      "heading_block": "b0007",
      "blocks": [
        {
          "type": "text",
          "text": "Parafin lỏng là hỗn hợp hydrocarbon no, lỏng, có nguồn gốc từ dầu mỏ, có tác dụng như một chất làm trơn, làm mềm phân, làm chậm sự hấp thu nước nên được dùng làm thuốc nhuận tràng. Parafin lỏng còn có tác dụng làm dịu da, sạch da nên được dùng để điều trị các trường hợp da khô, bệnh vảy cá hoặc tăng sừng hóa và làm tá dược cho thuốc mỡ. Thuốc còn được dùng trong thành phần của một số các chế phẩm có chứa các thuốc nhuận tràng khác như cascara, magnesi hydroxyd.",
          "block_id": "b0008"
        }
      ]
    },
    {
      "id": "duoc-dong-hoc",
      "title": "Dược động học",
      "heading_block": "b0009",
      "blocks": [
        {
          "type": "text",
          "text": "Hấp thu parafin lỏng sau khi uống hoặc thụt tháo phân hầu như không đáng kể. Sau khi uống, thuốc có tác dụng trong 6 - 8 giờ.",
          "block_id": "b0010"
        },
        {
          "type": "text",
          "text": "Parafin lỏng không bị chuyển hóa trong cơ thể",
          "block_id": "b0011"
        }
      ]
    },
    {
      "id": "chi-dinh",
      "title": "Chỉ định",
      "heading_block": "b0012",
      "blocks": [
        {
          "type": "text",
          "text": "Điều trị triệu chứng táo bón.",
          "block_id": "b0013"
        },
        {
          "type": "text",
          "text": "Thụt tháo phân: Chỉ nên dùng trong các trường hợp thật cần thiết.",
          "block_id": "b0014"
        }
      ]
    },
    {
      "id": "chong-chi-dinh",
      "title": "Chống chỉ định",
      "heading_block": "b0015",
      "blocks": [
        {
          "type": "text",
          "text": "Mẫn cảm với thuốc.",
          "block_id": "b0016"
        },
        {
          "type": "text",
          "text": "Dùng đường uống cho trẻ em dưới 3 tuổi.",
          "block_id": "b0017"
        }
      ]
    },
    {
      "id": "than-trong",
      "title": "Thận trọng",
      "heading_block": "b0018",
      "blocks": [
        {
          "type": "text",
          "text": "Tránh hít phải parafin lỏng.",
          "block_id": "b0019"
        },
        {
          "type": "text",
          "text": "Người cao tuổi, người bệnh nằm liệt giường, phụ nữ mang thai, người bệnh nuốt khó, trào ngược dạ dày - thực quản, thoát vị khe thực quản.",
          "block_id": "b0020"
        },
        {
          "type": "text",
          "text": "Không nên uống khi đang đau bụng, buồn nôn, nôn.",
          "block_id": "b0021"
        }
      ]
    },
    {
      "id": "thoi-ky-mang-thai",
      "title": "Thời kỳ mang thai",
      "heading_block": "b0022",
      "blocks": [
        {
          "type": "text",
          "text": "Không dùng vì khi uống kéo dài parafin lỏng đã xảy ra trường hợp hạ prothrombin huyết và bệnh chảy máu ở trẻ sơ sinh.",
          "block_id": "b0023"
        }
      ]
    },
    {
      "id": "thoi-ky-cho-con-bu",
      "title": "Thời kỳ cho con bú",
      "heading_block": "b0024",
      "blocks": [
        {
          "type": "text",
          "text": "Không có chống chỉ định dùng cho người cho con bú.",
          "block_id": "b0025"
        }
      ]
    },
    {
      "id": "tac-dung-khong-mong-muon-adr",
      "title": "Tác dụng không mong muốn (ADR)",
      "heading_block": "b0026",
      "blocks": [
        {
          "type": "text",
          "text": "Dùng liều cao đường uống hoặc đường trực tràng có thể gây són phân, kích ứng hậu môn, ngứa hậu môn, có thể gây ảnh hưởng đến cơ chế phản xạ bình thường của trực tràng, tăng nhiễm khuẩn và lâu lành các thương tổn ở hậu môn - trực tràng. Giảm liều có thể giảm thiểu tình trạng són phân này.",
          "block_id": "b0027"
        },
        {
          "type": "text",
          "text": "Viêm phổi dạng lipid do hít phải parafin lỏng. Do đó không nên dùng thuốc cho người bị khó nuốt.",
          "block_id": "b0028"
        },
        {
          "type": "text",
          "text": "Phản ứng u hạt khi hấp thu một lượng nhỏ parafin lỏng.",
          "block_id": "b0029"
        },
        {
          "type": "text",
          "text": "Parafin lỏng, dùng liên tục với lượng lớn có thể gây chán ăn, làm giảm sự hấp thu các vitamin tan trong mỡ (A, D, E, K) và một vài chất khác.",
          "block_id": "b0030"
        }
      ]
    },
    {
      "id": "huong-dan-cach-xu-tri-adr",
      "title": "Hướng dẫn cách xử trí ADR",
      "heading_block": "b0031",
      "blocks": [
        {
          "type": "text",
          "text": "Giảm liều hoặc ngừng thuốc.",
          "block_id": "b0032"
        }
      ]
    },
    {
      "id": "lieu-luong-va-cach-dung",
      "title": "Liều lượng và cách dùng",
      "heading_block": "b0033",
      "blocks": [
        {
          "type": "subheading",
          "text": "Điều trị triệu chứng táo bón:",
          "block_id": "b0034"
        },
        {
          "type": "text",
          "text": "Cách dùng: Nên uống thuốc vào buổi tối hoặc trước bữa ăn sáng, lúc dạ dày rỗng. Không nên uống thuốc ngay trước khi đi ngủ.",
          "block_id": "b0035"
        },
        {
          "type": "text",
          "text": "Không nên dùng kéo dài quá 1 tuần. Nếu không có kết quả, không được vượt quá liều tối đa khuyến cáo.",
          "block_id": "b0036"
        },
        {
          "type": "text",
          "text": "Liều dùng: Người lớn: Uống 10 - 30 ml/ngày, uống 1 lần hoặc chia làm nhiều lần. Trẻ em ≥ 3 tuổi: Uống 5 - 20 ml/ngày.",
          "block_id": "b0037"
        },
        {
          "type": "subheading",
          "text": "Thụt tháo phân:",
          "block_id": "b0038"
        },
        {
          "type": "text",
          "text": "Người lớn và trẻ em trên 12 tuổi: Dùng liều 120 ml trong những trường hợp thật cần thiết.",
          "block_id": "b0039"
        },
        {
          "type": "text",
          "text": "Trẻ em 2 - 11 tuổi: 30 - 60 ml.",
          "block_id": "b0040"
        }
      ]
    },
    {
      "id": "tuong-tac-thuoc",
      "title": "Tương tác thuốc",
      "heading_block": "b0041",
      "blocks": [
        {
          "type": "text",
          "text": "Mọi thuốc nhuận tràng đều có thể làm giảm sự hấp thu của các thuốc khác uống đồng thời. Parafin lỏng có thể làm giảm sự hấp thu của các thuốc uống như vitamin tan trong dầu, caroten, thuốc tránh thai loại uống, các thuốc chống đông máu như coumarin và dẫn xuất indandion. Trong phân, parafin lỏng có thể trộn với các sulfamid không hấp thu được (thí dụ phthalylsulfathiazol) làm ảnh hưởng đến tác dụng kháng khuẩn của những thuốc này. Người dùng những thuốc nói trên nên tránh dùng dầu parafin đồng thời.",
          "block_id": "b0042"
        }
      ]
    },
    {
      "id": "qua-lieu-va-xu-tri",
      "title": "Quá liều và xử trí",
      "heading_block": "b0043",
      "blocks": [
        {
          "type": "text",
          "text": "Triệu chứng: Kích ứng đường tiêu hóa, buồn nôn, nôn, ỉa chảy.",
          "block_id": "b0044"
        },
        {
          "type": "text",
          "text": "Xử trí: Ngừng thuốc và điều trị triệu chứng.",
          "block_id": "b0045"
        }
      ]
    },
