    {
      "id": "b0021",
      "type": "paragraph",
      "text": "Yếu sức, chóng mặt hay buồn ngủ có thể xảy ra khi dùng thuốc.",
      "page": 660,
      "printed_page": 666,
      "column": 1,
      "bbox": [
        307.89,
        115.29,
        562.22,
        128.09
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Yếu sức, chóng mặt hay buồn ngủ có thể xảy ra khi dùng thuốc. ",
          "bbox": [
            307.89,
            115.29,
            562.22,
            128.09
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
