    },
    {
      "id": "b0018",
      "type": "paragraph",
      "text": "Điều trị quá liều paracetamol khi không có acetylcystein.",
      "page": 1092,
      "printed_page": 1098,
      "column": 1,
      "bbox": [
        299.39,
        736.88,
        518.9,
        749.68
