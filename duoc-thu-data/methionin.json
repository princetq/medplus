          "italic": false
        }
      ]
    },
    {
      "id": "b0024",
      "type": "paragraph",
      "text": "Rối loạn chuyển hóa: tăng oxalat, homocystin niệu, tăng methionin huyết.",
      "page": 1093,
      "printed_page": 1099,
      "column": 0,
      "bbox": [
        43.43,
