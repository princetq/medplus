    {
      "id": "b0021",
      "type": "paragraph",
      "text": "Methionin gây toan hóa máu và nước tiểu, do đó không nên sử dụng methionin trong các trường hợp sau: Người bệnh bị nhiễm toan, tăng acid uric huyết, tăng acid uric niệu.",
      "page": 1092,
      "printed_page": 1098,
      "column": 1,
      "bbox": [
        299.39,
        776.03,
        553.71,
        800.87
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0023",
      "type": "paragraph",
      "text": "Sỏi thận có chứa acid uric hoặc cystin.",
      "page": 1093,
      "printed_page": 1099,
      "column": 0,
      "bbox": [
        43.43,
        75.57,
        190.0,
        88.37
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Sỏi thận có chứa acid uric hoặc cystin.",
          "bbox": [
            43.43,
            75.57,
            190.0,
            88.37
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
