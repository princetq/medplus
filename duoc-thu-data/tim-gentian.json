      }
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Tránh dùng tím gentian kéo dài.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        760.99,
        420.95,
        773.79
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Tránh dùng tím gentian kéo dài.",
          "bbox": [
