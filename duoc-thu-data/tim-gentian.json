    },
    {
      "id": "b0041",
      "type": "paragraph",
      "text": "Tiêu hóa: viêm thực quản.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        673.71,
        398.92,
        686.5
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Tiêu hóa: viêm thực quản.",
          "bbox": [
            299.39,
            673.71,
            398.92,
            686.5
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0042",
      "type": "paragraph",
      "text": "Tại chỗ: bỏng, kích ứng, mụn nước, phản ứng mẫn cảm, loét niêm mạc.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        685.75,
        553.72,
        710.59
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0043",
      "type": "paragraph",
      "text": "Hô hấp: viêm thanh quản, viêm khí quản.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        709.83,
        456.91,
        722.63
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Hô hấp: viêm thanh quản, viêm khí quản.",
