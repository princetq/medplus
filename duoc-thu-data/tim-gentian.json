          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0036",
      "type": "paragraph",
      "text": "Vì không biết tím gentian có tiết vào sữa không, nên phải sử dụng thận trọng thuốc này đối với phụ nữ cho con bú.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        538.26,
        553.71,
        563.1
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0037",
      "type": "heading",
      "level": 2,
      "text": "Tác dụng không mong muốn (ADR)",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        565.19,
        445.33,
        578.34
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tác dụng không mong muốn (ADR)",
          "bbox": [
            299.39,
            565.19,
            445.33,
            578.34
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Mặc dù tím gentian thường được dung nạp tốt, thuốc có thể gây kích ứng hoặc gây những phản ứng mẫn cảm và loét niêm mạc.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        577.38,
        553.72,
        602.22
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0039",
      "type": "paragraph",
      "text": "Viêm thực quản, viêm thanh quản hoặc viêm khí quản có thể xảy ra do nuốt dung dịch tím gentian, do sử dụng thuốc thường xuyên và kéo dài trong điều trị bệnh nấm Candida ở miệng. Sự xăm thuốc vào da có thể xảy ra khi bôi tím gentian trên mô hạt. Khả năng hoại tử da ở nồng độ cao hoặc khi băng bịt.",
      "page": 1582,
      "printed_page": 1588,
      "column": 1,
      "bbox": [
        299.39,
        601.46,
        553.72,
        662.42
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0040",
      "type": "subheading",
      "level": 3,
      "text": "Thường gặp hoặc rất thường gặp",
