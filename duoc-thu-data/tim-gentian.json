    },
    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Nếu xảy ra kích ứng hoặc phản ứng mẫn cảm, phải ngừng dùng thuốc.",
      "page": 1582,
      "printed_page": 1588,
