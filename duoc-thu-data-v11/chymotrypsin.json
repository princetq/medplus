{"schema_version":"11.0.0-alpha.1","id":"chymotrypsin","title":"Chymotrypsin","aliases":["chymotrypsin"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":432,"end":432},"printed_pages":{"start":438,"end":438},"extraction":{"start_title_pdf_page":432,"start_column":"left","start_y":464.5400085449219,"next_title_pdf_page":432,"next_column":"right","next_y":636.2599487304688,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"CHYMOTRYPSIN","page":432,"printed_page":438,"column":0,"bbox":[127.92,464.54,210.9,478.38],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"CHYMOTRYPSIN","bbox":[127.92,464.54,210.9,478.38],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"heading","level":2,"text":"(Alpha-chymotrypsin)","page":432,"printed_page":438,"column":0,"bbox":[122.36,478.98,216.46,492.82],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["MinionPro-Bold"]},"spans":[{"text":"(Alpha-chymotrypsin)","bbox":[122.36,478.98,216.46,492.82],"font":"MinionPro-Bold","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Tên chung quốc tế: Chymotrypsin.","page":432,"printed_page":438,"column":0,"bbox":[43.43,502.48,180.4,515.63],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[43.43,502.48,123.66,515.63],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Chymotrypsin.","bbox":[123.66,502.64,180.4,515.43],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Mã ATC: B06AA04, S01KX01.","page":432,"printed_page":438,"column":0,"bbox":[43.43,514.44,168.07,527.59],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[43.43,514.44,83.89,527.59],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"B06AA04, S01KX01.","bbox":[83.89,514.6,168.07,527.39],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"paragraph","text":"Loại thuốc: Enzym thủy phân protein. Thuốc mắt, hỗ trợ phẫu thuật.","page":432,"printed_page":438,"column":0,"bbox":[43.43,528.39,297.77,552.46],"source":{"line_count":2}},{"id":"b0006","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":432,"printed_page":438,"column":0,"bbox":[43.43,554.64,148.35,567.79],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[43.43,554.64,148.35,567.79],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Chứa ít nhất 5 microkatal chymotrypsin trong 1 mg. Chứa ít nhất 1 000 đơn vị chymotrypsin USP trong 1 mg, tính theo dạng khô.","page":432,"printed_page":438,"column":0,"bbox":[43.43,566.9,297.76,591.82],"source":{"line_count":2}},{"id":"b0008","type":"paragraph","text":"Bột chymotrypsin để pha dung dịch dùng trong nhãn khoa: 300 đơn vị USP (catarase). Chymotrypsin vô khuẩn dùng cho mắt, sau khi pha có pH 4,3 - 8,7.","page":432,"printed_page":438,"column":0,"bbox":[43.43,591.15,297.76,628.19],"source":{"line_count":3}},{"id":"b0009","type":"paragraph","text":"Bột chymotrypsin 5 000 đơn vị USP để pha tiêm.","page":432,"printed_page":438,"column":0,"bbox":[43.43,627.51,230.72,640.31],"source":{"line_count":1},"spans":[{"text":"Bột chymotrypsin 5 000 đơn vị USP để pha tiêm.","bbox":[43.43,627.51,230.72,640.31],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Viên nén 21 microkatal.","page":432,"printed_page":438,"column":0,"bbox":[43.43,639.63,134.68,652.42],"source":{"line_count":1},"spans":[{"text":"Viên nén 21 microkatal.","bbox":[43.43,639.63,134.68,652.42],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0011","type":"heading","level":2,"text":"Dược lực học","page":432,"printed_page":438,"column":0,"bbox":[43.43,654.6,97.03,667.75],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[43.43,654.6,97.03,667.75],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0012","type":"paragraph","text":"Chymotrypsin là một enzym phân giải protein, được điều chế bằng cách hoạt hóa chymotrypsinogen chiết xuất từ tụy bò. Chymotrypsin cắt các liên kết chuỗi các acid amin thơm (phenylalamin, tyrosin, tryptophan, methionin, norleucin và norvalin), nên đã phân giải các sợi của dây chằng (Zin) treo thủy tinh thể làm cho việc lấy thủy tinh thể từ bao ra dễ dàng hơn, mà không gây tác hại nặng đến các cấu trúc khác của mắt. Chymotrypsin đã từng được dùng trong phẫu thuật lấy đục thủy tinh thể trong bao ở lứa tuổi từ 20 - 60 tuổi, nhưng hiện nay ít làm vì nhiều biến chứng và có kỹ thuật hiện đại và dụng cụ tinh xảo hơn (Cách làm: Lấy đục thủy tinh thể ngoài bao, nhũ tương hóa thủy tinh thể bằng sóng siêu âm và hút. Dung","page":432,"printed_page":438,"column":0,"bbox":[43.43,666.87,297.77,800.87],"source":{"line_count":11}},{"id":"b0013","type":"paragraph","text":"dịch enzym 1: 5 000 thường có tác dụng trong vòng 2 phút, dung dịch 1: 10 000 khoảng 4 phút). Chymotrypsin cũng đã được sử dụng để điều trị phù nề do viêm, sau chấn thương, sau phẫu thuật.","page":432,"printed_page":438,"column":1,"bbox":[307.38,63.32,561.71,101.08],"source":{"line_count":3}},{"id":"b0014","type":"paragraph","text":"Thuốc ít có chứng cứ tác dụng chống viêm trong các viêm khác (viêm đường hô hấp, xoang…).","page":432,"printed_page":438,"column":1,"bbox":[307.38,100.77,561.72,126.04],"source":{"line_count":2}},{"id":"b0015","type":"heading","level":2,"text":"Chỉ định","page":432,"printed_page":438,"column":1,"bbox":[307.38,128.57,343.03,141.72],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[307.38,128.57,343.03,141.72],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Chymotrypsin dùng hỗ trợ trong phẫu thuật lấy đục thủy tinh thể trong bao ở người từ 20 - 60 tuổi (do thầy thuốc chuyên khoa chỉ định).","page":432,"printed_page":438,"column":1,"bbox":[307.38,141.21,561.74,166.48],"source":{"line_count":2}},{"id":"b0017","type":"paragraph","text":"Dùng trong điều trị phù nề sau chấn thương, phẫu thuật, bỏng.","page":432,"printed_page":438,"column":1,"bbox":[307.38,166.16,543.95,178.96],"source":{"line_count":1},"spans":[{"text":"Dùng trong điều trị phù nề sau chấn thương, phẫu thuật, bỏng.","bbox":[307.38,166.16,543.95,178.96],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0018","type":"heading","level":2,"text":"Chống chỉ định","page":432,"printed_page":438,"column":1,"bbox":[307.38,181.5,369.68,194.65],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[307.38,181.5,369.68,194.65],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0019","type":"paragraph","text":"Quá mẫn với chymotrypsin.","page":432,"printed_page":438,"column":1,"bbox":[307.38,194.13,413.73,206.93],"source":{"line_count":1},"spans":[{"text":"Quá mẫn với chymotrypsin.","bbox":[307.38,194.13,413.73,206.93],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0020","type":"note","level":2,"text":"Thận trọng","page":432,"printed_page":438,"column":1,"bbox":[307.38,209.46,353.57,222.6],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[307.38,209.46,353.57,222.6],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0021","type":"paragraph","text":"Vì khả năng gây mất dịch kính, nên không khuyến cáo dùng chymotrypsin trong phẫu thuật đục nhân mắt ở người bệnh dưới 20 tuổi. Không dùng chymotrypsin cho người bệnh tăng áp suất dịch kính và có vết thương hở hoặc người bệnh đục nhân mắt bẩm sinh.","page":432,"printed_page":438,"column":1,"bbox":[307.38,222.09,561.71,272.33],"source":{"line_count":4}},{"id":"b0022","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":432,"printed_page":438,"column":1,"bbox":[307.38,274.86,453.33,288.01],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[307.38,274.86,453.33,288.01],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0023","type":"paragraph","text":"Tác dụng không mong muốn thường gặp nhất của chymotrypsin là tăng nhất thời nhãn áp do các mảnh vụn dây chằng bị tiêu hủy làm tắc mạng bó dây. Dùng trong nhãn khoa, có thể gặp phù giác mạc, viêm nhẹ màng bồ đào.","page":432,"printed_page":438,"column":1,"bbox":[307.38,287.49,561.72,337.73],"source":{"line_count":4}},{"id":"b0024","type":"paragraph","text":"Chymotrypsin có tính kháng nguyên, nên sau khi tiêm bắp, đôi khi có các phản ứng dị ứng nặng.","page":432,"printed_page":438,"column":1,"bbox":[307.38,337.41,561.71,362.69],"source":{"line_count":2}},{"id":"b0025","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":432,"printed_page":438,"column":1,"bbox":[307.38,365.23,421.95,378.38],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[307.38,365.23,421.95,378.38],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0026","type":"paragraph","text":"Nếu nghi bị dị ứng, cần thử phản ứng trước khi tiêm chymotrypsin.","page":432,"printed_page":438,"column":1,"bbox":[307.38,377.86,559.34,390.66],"source":{"line_count":1},"spans":[{"text":"Nếu nghi bị dị ứng, cần thử phản ứng trước khi tiêm chymotrypsin.","bbox":[307.38,377.86,559.34,390.66],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0027","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":432,"printed_page":438,"column":1,"bbox":[307.38,393.19,407.56,406.33],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[307.38,393.19,407.56,406.33],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0028","type":"paragraph","text":"Trong nhãn khoa: Do thầy thuốc chuyên khoa chỉ định.","page":432,"printed_page":438,"column":1,"bbox":[307.38,405.82,517.6,418.62],"source":{"line_count":1},"spans":[{"text":"Trong nhãn khoa: ","bbox":[307.38,405.98,377.49,418.62],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":"Do thầy thuốc chuyên khoa chỉ định.","bbox":[377.49,405.82,517.6,418.62],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0029","type":"paragraph","text":"Phải pha thuốc ngay trước khi dùng, pha theo hướng dẫn của nhà sản xuất.","page":432,"printed_page":438,"column":1,"bbox":[307.38,418.3,561.71,443.57],"source":{"line_count":2}},{"id":"b0030","type":"paragraph","text":"Thông thường 150 đv/ml tương đương với dung dịch pha loãng 1: 5 000.","page":432,"printed_page":438,"column":1,"bbox":[307.38,443.26,561.72,468.54],"source":{"line_count":2}},{"id":"b0031","type":"paragraph","text":"75 đv/ml tương đương với dung dịch pha loãng 1: 10 000.","page":432,"printed_page":438,"column":1,"bbox":[307.38,468.23,528.04,481.02],"source":{"line_count":1},"spans":[{"text":"75 đv/ml tương đương với dung dịch pha loãng 1: 10 000.","bbox":[307.38,468.23,528.04,481.02],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0032","type":"subheading","level":3,"text":"Điều trị phù nề sau chấn thương, phẫu thuật:","page":432,"printed_page":438,"column":1,"bbox":[307.38,481.87,482.3,494.5],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Điều trị phù nề sau chấn thương, phẫu thuật: ","bbox":[307.38,481.87,482.3,494.5],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0033","type":"paragraph","text":"Uống (viên 21 microkatal): 2 viên/lần, ngày 3 - 4 lần, uống không nhai. Có thể ngậm dưới lưỡi: 4 - 6 viên/ngày.","page":432,"printed_page":438,"column":1,"bbox":[307.38,495.19,561.71,521.46],"source":{"line_count":2}},{"id":"b0034","type":"paragraph","text":"Tiêm bắp: 20 microkatal/5 ml ngày tiêm bắp 1 lần.","page":432,"printed_page":438,"column":1,"bbox":[307.38,522.15,500.2,534.94],"source":{"line_count":1},"spans":[{"text":"Tiêm bắp: 20 microkatal/5 ml ngày tiêm bắp 1 lần.","bbox":[307.38,522.15,500.2,534.94],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0035","type":"heading","level":2,"text":"Quá liều và xử trí","page":432,"printed_page":438,"column":1,"bbox":[307.38,541.47,379.06,554.62],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[307.38,541.47,379.06,554.62],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0036","type":"paragraph","text":"Ở chuột nhắt, chuột cống, thỏ và chó; LD50 = 24 000 - 85 000 đv/kg.","page":432,"printed_page":438,"column":1,"bbox":[307.38,554.11,561.73,566.9],"source":{"line_count":1},"spans":[{"text":"Ở chuột nhắt, chuột cống, thỏ và chó; LD50  = 24 000 - 85 000 đv/kg. ","bbox":[307.38,554.11,561.73,566.9],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0037","type":"paragraph","text":"Gây chảy máu ở nhiều cơ quan. Ở người chưa thấy báo cáo.","page":432,"printed_page":438,"column":1,"bbox":[307.38,567.59,561.72,580.38],"source":{"line_count":1},"spans":[{"text":"Gây chảy máu ở nhiều cơ quan. Ở người chưa thấy báo cáo. \n","bbox":[307.38,567.59,561.72,580.38],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0038","type":"paragraph","text":"Có thể gây sốc phản vệ.","page":432,"printed_page":438,"column":1,"bbox":[307.38,581.07,398.14,593.86],"source":{"line_count":1},"spans":[{"text":"Có thể gây sốc phản vệ.","bbox":[307.38,581.07,398.14,593.86],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Cập nhật lần cuối: 2017.","page":432,"printed_page":438,"column":1,"bbox":[307.38,599.11,402.65,611.74],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2017.","bbox":[307.38,599.11,402.65,611.74],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"chymotrypsin","title":"CHYMOTRYPSIN","heading_block":"b0001","blocks":[]},{"id":"alpha-chymotrypsin","title":"(Alpha-chymotrypsin)","heading_block":"b0002","blocks":["b0003","b0004","b0005"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0006","blocks":["b0007","b0008","b0009","b0010"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0011","blocks":["b0012","b0013","b0014"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0015","blocks":["b0016","b0017"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0018","blocks":["b0019","b0020","b0021"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0022","blocks":["b0023","b0024"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0025","blocks":["b0026"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0027","blocks":["b0028","b0029","b0030","b0031","b0032","b0033","b0034"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0035","blocks":["b0036","b0037","b0038","b0039"]}],"quality":{"block_count":39,"heading_count":10,"subheading_count":1,"paragraph_count":27,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":1}}