{"schema_version":"11.0.0-alpha.1","id":"ethosuximid","title":"Ethosuximid","aliases":["Ethosuximid"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":709,"end":710},"printed_pages":{"start":715,"end":716},"extraction":{"start_title_pdf_page":709,"start_column":"left","start_y":62.82659912109375,"next_title_pdf_page":710,"next_column":"left","next_y":567.9025268554688,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"ETHOSUXIMID","page":709,"printed_page":715,"column":0,"bbox":[124.23,62.83,197.57,76.67],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"ETHOSUXIMID","bbox":[124.23,62.83,197.57,76.67],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Ethosuximide.","page":709,"printed_page":715,"column":0,"bbox":[34.93,86.21,170.32,99.35],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[34.93,86.21,115.16,99.35],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Ethosuximide.","bbox":[115.16,86.36,170.32,99.15],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: N03AD01.","page":709,"printed_page":715,"column":0,"bbox":[34.93,97.72,117.34,110.87],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[34.93,97.72,75.39,110.87],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"N03AD01.","bbox":[75.39,97.87,117.34,110.67],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc chống động kinh nhóm sucinimid.","page":709,"printed_page":715,"column":0,"bbox":[34.93,109.23,240.77,122.38],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[34.93,109.23,84.02,122.38],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc chống động kinh nhóm sucinimid.","bbox":[84.02,109.38,240.77,122.18],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":709,"printed_page":715,"column":0,"bbox":[34.93,124.24,139.85,137.39],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[34.93,124.24,139.85,137.39],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Viên nang: 250 mg.","page":709,"printed_page":715,"column":0,"bbox":[34.93,136.41,109.83,149.2],"source":{"line_count":1},"spans":[{"text":"Viên nang: 250 mg.","bbox":[34.93,136.41,109.83,149.2],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Sirô: Lọ 10 g/200 ml (250 mg/5 ml).","page":709,"printed_page":715,"column":0,"bbox":[34.93,148.42,176.65,161.22],"source":{"line_count":1},"spans":[{"text":"Sirô: Lọ 10 g/200 ml (250 mg/5 ml). ","bbox":[34.93,148.42,176.65,161.22],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Dung dịch uống: 50 mg/ml.","page":709,"printed_page":715,"column":0,"bbox":[34.93,160.43,140.23,173.23],"source":{"line_count":1},"spans":[{"text":"Dung dịch uống: 50 mg/ml.","bbox":[34.93,160.43,140.23,173.23],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0009","type":"heading","level":2,"text":"Dược lực học","page":709,"printed_page":715,"column":0,"bbox":[34.93,175.29,88.53,188.44],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[34.93,175.29,88.53,188.44],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Ethosuximid là một sucinimid có tác dụng chống động kinh đặc hiệu đối với động kinh cơn vắng ý thức. Cơ chế tác dụng là do ức chế kênh calci trong các tế bào thần kinh vùng đồi thị, vì vậy cản trở chức năng tế bào thần kinh tại một trong các đường vòng thần kinh liên quan đến cơn động kinh vắng ý thức.","page":709,"printed_page":715,"column":0,"bbox":[34.93,187.46,289.27,248.3],"source":{"line_count":5}},{"id":"b0011","type":"paragraph","text":"Tác dụng làm giảm tần số cơn động kinh của thuốc là do ức chế vùng vỏ não vận động và nâng ngưỡng của hệ TKTW với các kích thích gây co giật. So sánh với các sucinimid chống co giật khác, ethosuximid có tác dụng đặc hiệu hơn đối với các cơn vắng ý thức đơn thuần. Do khả năng gây độc thấp trong trường hợp dùng kéo dài và vì hiệu lực của thuốc, nên thuốc được chọn dùng đối với cơn động kinh vắng ý thức.","page":709,"printed_page":715,"column":0,"bbox":[34.93,247.52,289.27,332.39],"source":{"line_count":7}},{"id":"b0012","type":"paragraph","text":"Ethosuximid không hiệu quả với một số dạng động kinh khác như động kinh cục bộ hoặc co cứng co giật (động kinh cơn lớn).","page":709,"printed_page":715,"column":0,"bbox":[34.93,331.61,289.26,356.42],"source":{"line_count":2}},{"id":"b0013","type":"paragraph","text":"Ethosuximid có thể dùng cùng các thuốc chống co giật khác (như acid valproic) trong điều trị các loại co giật đồng thời khác (như co cứng co giật toàn thân).","page":709,"printed_page":715,"column":0,"bbox":[34.93,355.63,289.26,392.46],"source":{"line_count":3}},{"id":"b0014","type":"paragraph","text":"Trường hợp đồng thời có cả động kinh cơn vắng ý thức và cơn toàn thể thì có thể dùng ethosuximid phối hợp với phenobarbital và phenytoin.","page":709,"printed_page":715,"column":0,"bbox":[34.93,391.67,289.27,428.49],"source":{"line_count":3}},{"id":"b0015","type":"heading","level":2,"text":"Dược động học","page":709,"printed_page":715,"column":0,"bbox":[34.93,430.56,96.03,443.71],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[34.93,430.56,96.03,443.71],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Ethosuximid được hấp thu tốt qua đường tiêu hóa, nồng độ đỉnh huyết tương đạt được sau 4 - 7 giờ ở trẻ em và người lớn. Thuốc phân bố khắp cơ thể, khoảng 0,69 lít/kg, nhưng liên kết với protein huyết tương không đáng kể (dưới 10%). Ethosuximid chuyển hóa trong gan thành 3 chất chuyển hóa không có tác dụng. Thuốc bài tiết chậm qua nước tiểu dưới dạng chuyển hóa ở dạng tự do và liên hợp với glucuronid (50%), có khoảng 20% dưới dạng không đổi.","page":709,"printed_page":715,"column":0,"bbox":[34.93,442.72,289.27,527.59],"source":{"line_count":7}},{"id":"b0017","type":"paragraph","text":"Một lượng nhỏ thuốc được thải trừ qua phân và mật. Nửa đời thải trừ của thuốc khoảng 60 giờ ở người lớn và 30 giờ ở trẻ em. Thuốc qua hàng rào nhau thai và được bài tiết qua sữa.","page":709,"printed_page":715,"column":0,"bbox":[34.93,526.81,289.27,563.63],"source":{"line_count":3}},{"id":"b0018","type":"paragraph","text":"Thuốc có tác dụng khi nồng độ trong huyết tương đạt khoảng 280 - 700 micromol/lít. Nồng độ thuốc trong huyết tương thường ổn định sau 7 - 10 ngày điều trị và có liên quan đến liều dùng, nhưng khác nhau rất nhiều giữa các cá thể. Nói chung, khi tăng liều thì nồng độ thuốc trong huyết tương ở trẻ nhỏ tăng ít hơn ở trẻ lớn và người lớn. Theo dõi nồng độ thuốc trong huyết tương sẽ giúp cho việc xác định khoảng liều lượng điều trị, nhưng cần kết hợp xem xét toàn bộ tình trạng lâm sàng để làm sao kiểm soát được bệnh và hạn chế ADR ở mức thấp nhất.","page":709,"printed_page":715,"column":0,"bbox":[34.93,562.85,289.26,671.74],"source":{"line_count":9}},{"id":"b0019","type":"heading","level":2,"text":"Chỉ định","page":709,"printed_page":715,"column":0,"bbox":[34.93,673.81,70.57,686.96],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[34.93,673.81,70.57,686.96],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0020","type":"paragraph","text":"Điều trị động kinh cơn vắng ý thức và cơn vắng kèm giật cơ.","page":709,"printed_page":715,"column":0,"bbox":[34.93,685.97,266.24,698.77],"source":{"line_count":1},"spans":[{"text":"Điều trị động kinh cơn vắng ý thức và cơn vắng kèm giật cơ.","bbox":[34.93,685.97,266.24,698.77],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0021","type":"heading","level":2,"text":"Chống chỉ định","page":709,"printed_page":715,"column":0,"bbox":[34.93,700.83,97.23,713.98],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[34.93,700.83,97.23,713.98],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0022","type":"paragraph","text":"Mẫn cảm với ethosuximid, dẫn xuất sucinimid.","page":709,"printed_page":715,"column":0,"bbox":[34.93,713.0,214.12,725.79],"source":{"line_count":1},"spans":[{"text":"Mẫn cảm với ethosuximid, dẫn xuất sucinimid.","bbox":[34.93,713.0,214.12,725.79],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0023","type":"paragraph","text":"Rối loạn chuyển hóa porpyrin (với dạng sirô).","page":709,"printed_page":715,"column":0,"bbox":[34.93,725.01,209.35,737.81],"source":{"line_count":1},"spans":[{"text":"Rối loạn chuyển hóa porpyrin (với dạng sirô).","bbox":[34.93,725.01,209.35,737.81],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0024","type":"note","level":2,"text":"Thận trọng","page":709,"printed_page":715,"column":0,"bbox":[34.93,739.87,81.12,753.02],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[34.93,739.87,81.12,753.02],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0025","type":"paragraph","text":"Có thể xuất hiện lupus ban đỏ hệ thống.","page":709,"printed_page":715,"column":0,"bbox":[34.93,752.04,186.13,764.83],"source":{"line_count":1},"spans":[{"text":"Có thể xuất hiện lupus ban đỏ hệ thống.","bbox":[34.93,752.04,186.13,764.83],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0026","type":"paragraph","text":"Đã có báo cáo về ý tưởng và hành vi tự sát ở những bệnh nhân được điều trị bằng thuốc chống động kinh trong một số chỉ định. Cơ chế của nguy cơ này chưa được biết rõ và dữ liệu có sẵn không loại","page":709,"printed_page":715,"column":0,"bbox":[34.93,764.05,289.26,800.87],"source":{"line_count":3}},{"id":"b0027","type":"paragraph","text":"trừ khả năng tăng nguy cơ đối với ethosuximid. Do đó, bệnh nhân cần được theo dõi các dấu hiệu của ý tưởng và hành vi tự tử và nên được xem xét biện pháp điều trị thích hợp. Bệnh nhân (và người chăm sóc bệnh nhân) nên được tư vấn để đi khám khi xuất hiện dấu hiệu hoặc hành vi tự tử.","page":709,"printed_page":715,"column":1,"bbox":[298.88,63.32,553.22,124.24],"source":{"line_count":5}},{"id":"b0028","type":"paragraph","text":"Sử dụng thận trọng trong suy gan hoặc thận. Theo dõi định kỳ chức năng gan/thận và nồng độ ethosuximid.","page":709,"printed_page":715,"column":1,"bbox":[298.88,123.47,553.21,148.3],"source":{"line_count":2}},{"id":"b0029","type":"paragraph","text":"Nếu ethosuximid được sử dụng để thay thế cho một loại thuốc chống động kinh đang dùng khác thì không được ngừng thuốc đang dùng đột ngột mà việc thay thế phải được thực hiện dần dần với sự phối hợp đồng thời 2 thuốc, nếu không, có thể xuất hiện các cơn động kinh nhỏ.","page":709,"printed_page":715,"column":1,"bbox":[298.88,147.53,553.22,208.44],"source":{"line_count":5}},{"id":"b0030","type":"paragraph","text":"Khi muốn ngừng ethosuximid, phải giảm liều dần dần.","page":709,"printed_page":715,"column":1,"bbox":[298.88,207.68,506.69,220.47],"source":{"line_count":1},"spans":[{"text":"Khi muốn ngừng ethosuximid, phải giảm liều dần dần.","bbox":[298.88,207.68,506.69,220.47],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0031","type":"paragraph","text":"Rối loạn tạo máu đã được báo cáo và có trường hợp tử vong liên quan đến sử dụng ethosuximid, do đó cần theo dõi định kỳ công thức máu. Cần làm công thức máu ở các thời điểm có triệu chứng hoặc dấu hiệu của nhiễm trùng (như đau họng, sốt).","page":709,"printed_page":715,"column":1,"bbox":[298.88,219.71,553.22,268.59],"source":{"line_count":4}},{"id":"b0032","type":"heading","level":2,"text":"Thời kỳ mang thai","page":709,"printed_page":715,"column":1,"bbox":[298.88,270.67,374.09,283.82],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[298.88,270.67,374.09,283.82],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0033","type":"paragraph","text":"Có một số bằng chứng về nguy cơ dị tật bẩm sinh tăng lên sau khi dùng các thuốc chống động kinh cho phụ nữ mang thai, đặc biệt ở 3 tháng đầu của thai kỳ. Phối hợp các thuốc chống động kinh càng tăng nguy cơ này.","page":709,"printed_page":715,"column":1,"bbox":[298.88,282.86,553.21,331.74],"source":{"line_count":4}},{"id":"b0034","type":"paragraph","text":"Nhưng nếu các cơn động kinh không được kiểm soát tốt, cũng có thể gây tăng nguy cơ khuyết tật, thậm chí gây chết bào thai. Chính nguy cơ này còn cao hơn cả nguy cơ do thuốc.","page":709,"printed_page":715,"column":1,"bbox":[298.88,330.97,553.21,367.83],"source":{"line_count":3}},{"id":"b0035","type":"paragraph","text":"Thuốc chống động kinh thường vẫn được chỉ định trong thời kỳ mang thai, nhưng cần phải hết sức thận trọng để tránh và hạn chế các nguy cơ. Nên cho người bệnh dùng bổ sung acid folic.","page":709,"printed_page":715,"column":1,"bbox":[298.88,367.06,553.21,403.92],"source":{"line_count":3}},{"id":"b0036","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":709,"printed_page":715,"column":1,"bbox":[298.88,406.0,377.0,419.15],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[298.88,406.0,377.0,419.15],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0037","type":"paragraph","text":"Ethosuximid được bài tiết qua sữa và nồng độ ethosuximid trong huyết tương của trẻ bú có thể đạt đến gần khoảng liều điều trị, một số trẻ nhỏ có thể biểu hiện dấu hiệu ngủ gà hoặc hốt hoảng. Người mẹ dùng ethosuximid nên ngừng cho con bú.","page":709,"printed_page":715,"column":1,"bbox":[298.88,418.18,553.22,467.07],"source":{"line_count":4}},{"id":"b0038","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":709,"printed_page":715,"column":1,"bbox":[298.88,469.15,444.83,482.3],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[298.88,469.15,444.83,482.3],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Các ADR thường gặp trong khi điều trị với ethosuximid là giảm tập trung và ngủ gà, ADR thường gặp phụ thuộc vào liều dùng.","page":709,"printed_page":715,"column":1,"bbox":[298.88,481.33,553.22,506.16],"source":{"line_count":2}},{"id":"b0040","type":"subheading","level":3,"text":"Thường gặp","page":709,"printed_page":715,"column":1,"bbox":[298.88,505.55,345.29,518.19],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp","bbox":[298.88,505.55,345.29,518.19],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0041","type":"paragraph","text":"Toàn thân: chán ăn, buồn ngủ.","page":709,"printed_page":715,"column":1,"bbox":[298.88,517.42,413.52,530.22],"source":{"line_count":1},"spans":[{"text":"Toàn thân: chán ăn, buồn ngủ.","bbox":[298.88,517.42,413.52,530.22],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0042","type":"paragraph","text":"Tiêu hóa: buồn nôn.","page":709,"printed_page":715,"column":1,"bbox":[298.88,529.45,375.07,542.25],"source":{"line_count":1},"spans":[{"text":"Tiêu hóa: buồn nôn.","bbox":[298.88,529.45,375.07,542.25],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0043","type":"subheading","level":3,"text":"Ít gặp","page":709,"printed_page":715,"column":1,"bbox":[298.88,541.64,321.31,554.28],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Ít gặp","bbox":[298.88,541.64,321.31,554.28],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0044","type":"paragraph","text":"Toàn thân: đau đầu, chóng mặt.","page":709,"printed_page":715,"column":1,"bbox":[298.88,553.51,418.27,566.31],"source":{"line_count":1},"spans":[{"text":"Toàn thân: đau đầu, chóng mặt.","bbox":[298.88,553.51,418.27,566.31],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0045","type":"paragraph","text":"TKTW: mất điều hòa, trầm cảm, sảng khoái, nấc.","page":709,"printed_page":715,"column":1,"bbox":[298.88,565.54,486.38,578.34],"source":{"line_count":1},"spans":[{"text":"TKTW: mất điều hòa, trầm cảm, sảng khoái, nấc.","bbox":[298.88,565.54,486.38,578.34],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0046","type":"subheading","level":3,"text":"Hiếm gặp","page":709,"printed_page":715,"column":1,"bbox":[298.88,577.73,336.08,590.36],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp","bbox":[298.88,577.73,336.08,590.36],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0047","type":"paragraph","text":"Máu: Mất bạch cầu hạt, suy tủy, tăng bạch cầu ưa eosin, giảm tiểu cầu, tăng bạch cầu, tăng bạch cầu đơn nhân.","page":709,"printed_page":715,"column":1,"bbox":[298.88,589.6,553.22,614.42],"source":{"line_count":2}},{"id":"b0048","type":"paragraph","text":"TKTW: rối loạn tâm thần, thường gặp ở người bệnh có tiền sử về tâm thần.","page":709,"printed_page":715,"column":1,"bbox":[298.88,613.66,553.21,638.48],"source":{"line_count":2}},{"id":"b0049","type":"paragraph","text":"Da: ngoại ban, lupus ban đỏ rải rác.","page":709,"printed_page":715,"column":1,"bbox":[298.88,637.72,434.23,650.51],"source":{"line_count":1},"spans":[{"text":"Da: ngoại ban, lupus ban đỏ rải rác.","bbox":[298.88,637.72,434.23,650.51],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0050","type":"paragraph","text":"Chú ý: Hiện tượng buồn nôn xảy ra ở tuần điều trị đầu tiên, thường chỉ thoáng qua.","page":709,"printed_page":715,"column":1,"bbox":[298.88,649.75,553.22,674.57],"source":{"line_count":2}},{"id":"b0051","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":709,"printed_page":715,"column":1,"bbox":[298.88,676.65,413.45,689.8],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[298.88,676.65,413.45,689.8],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0052","type":"paragraph","text":"Cần theo dõi chức năng gan, thận, công thức máu khi dùng ethosuximid.","page":709,"printed_page":715,"column":1,"bbox":[298.88,688.84,553.22,713.66],"source":{"line_count":2}},{"id":"b0053","type":"paragraph","text":"Bệnh nhân và người nhà bệnh nhân cần được hướng dẫn cách nhận biết những dấu hiệu độc tính trên huyết học và cần báo cho thầy thuốc ngay khi có những dấu hiệu như sốt, viêm họng, loét miệng, bầm tím hoặc tăng xuất huyết.","page":709,"printed_page":715,"column":1,"bbox":[298.88,712.89,553.22,761.78],"source":{"line_count":4}},{"id":"b0054","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":709,"printed_page":715,"column":1,"bbox":[298.88,763.86,401.43,777.01],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng ","bbox":[298.88,763.86,401.43,777.01],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0055","type":"subheading","level":3,"text":"Cách dùng","page":709,"printed_page":715,"column":1,"bbox":[298.88,776.12,344.28,788.84],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Cách dùng ","bbox":[298.88,776.12,344.28,788.84],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0056","type":"paragraph","text":"Liều lượng phải cho theo từng người bệnh vì có nhiều thay đổi lớn","page":709,"printed_page":715,"column":1,"bbox":[298.88,788.07,553.22,800.87],"source":{"line_count":1},"spans":[{"text":"Liều lượng phải cho theo từng người bệnh vì có nhiều thay đổi lớn ","bbox":[298.88,788.07,553.22,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0057","type":"paragraph","text":"về dược động học giữa các người bệnh.","page":710,"printed_page":716,"column":0,"bbox":[43.94,63.32,193.96,76.12],"source":{"line_count":1},"spans":[{"text":"về dược động học giữa các người bệnh.","bbox":[43.94,63.32,193.96,76.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0058","type":"paragraph","text":"Thuốc được nuốt nguyên cả viên nang và dùng cùng thức ăn hoặc sữa để giảm kích ứng dạ dày.","page":710,"printed_page":716,"column":0,"bbox":[43.94,75.33,298.27,100.14],"source":{"line_count":2}},{"id":"b0059","type":"paragraph","text":"Khi muốn ngừng điều trị, phải giảm liều dần.","page":710,"printed_page":716,"column":0,"bbox":[43.94,99.35,215.86,112.14],"source":{"line_count":1},"spans":[{"text":"Khi muốn ngừng điều trị, phải giảm liều dần.","bbox":[43.94,99.35,215.86,112.14],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0060","type":"paragraph","text":"Điều trị cần dựa theo kết quả phân tích nồng độ thuốc trong máu định kỳ (7 - 12 ngày) để giúp đánh giá hiệu quả điều trị hoặc khả năng gây ADR. Nồng độ trong huyết thanh có tác dụng điều trị:","page":710,"printed_page":716,"column":0,"bbox":[43.94,111.36,298.27,148.17],"source":{"line_count":3}},{"id":"b0061","type":"paragraph","text":"280 - 700 micromol/lít.","page":710,"printed_page":716,"column":0,"bbox":[43.94,147.38,132.61,160.18],"source":{"line_count":1},"spans":[{"text":"280 - 700 micromol/lít.","bbox":[43.94,147.38,132.61,160.18],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0062","type":"paragraph","text":"Cần định kỳ xét nghiệm công thức máu, nước tiểu và chức năng gan trong suốt quá trình điều trị.","page":710,"printed_page":716,"column":0,"bbox":[43.94,159.39,298.27,184.2],"source":{"line_count":2}},{"id":"b0063","type":"subheading","level":3,"text":"Liều lượng","page":710,"printed_page":716,"column":0,"bbox":[43.94,183.49,87.72,196.21],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Liều lượng","bbox":[43.94,183.49,87.72,196.21],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0064","type":"paragraph","text":"Người lớn và trẻ > 6 tuổi: Ban đầu dùng 500 mg/ngày; sau đó nếu cần cứ 5 - 7 ngày lại tăng 250 mg, liều thường dùng là 1 - 1,5 g/ngày, có thể tăng tới liều 2 g/ngày.","page":710,"printed_page":716,"column":0,"bbox":[43.94,195.42,298.3,232.23],"source":{"line_count":3}},{"id":"b0065","type":"paragraph","text":"Trẻ 0 - 6 tuổi: Khởi đầu 250 mg, tăng liều từ từ với liều nhỏ mỗi vài ngày đến khi kiểm soát được co giật. Liều tối ưu ở hầu hết trẻ em là 20 mg/kg/ngày; liều tối đa 1 g/ngày.","page":710,"printed_page":716,"column":0,"bbox":[43.94,231.45,298.27,268.26],"source":{"line_count":3}},{"id":"b0066","type":"heading","level":2,"text":"Tương tác thuốc","page":710,"printed_page":716,"column":0,"bbox":[43.94,270.32,110.85,283.47],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[43.94,270.32,110.85,283.47],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0067","type":"subheading","level":3,"text":"Tăng tác dụng/độc tính","page":710,"printed_page":716,"column":0,"bbox":[43.94,282.64,132.34,295.28],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Tăng tác dụng/độc tính","bbox":[43.94,282.64,132.34,295.28],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0068","type":"paragraph","text":"Nồng độ và tác dụng/độc tính của ethosuximid có thể tăng lên khi dùng đồng thời với acid valproic, isoniazid và ritonavir.","page":710,"printed_page":716,"column":0,"bbox":[43.94,294.49,298.27,319.3],"source":{"line_count":2}},{"id":"b0069","type":"paragraph","text":"Ethosuximid có thể làm tăng độc tính của fosphenytoin.","page":710,"printed_page":716,"column":0,"bbox":[43.94,318.51,256.36,331.31],"source":{"line_count":1},"spans":[{"text":"Ethosuximid có thể làm tăng độc tính của fosphenytoin.","bbox":[43.94,318.51,256.36,331.31],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0070","type":"subheading","level":3,"text":"Giảm tác dụng","page":710,"printed_page":716,"column":0,"bbox":[43.94,330.68,100.4,343.31],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Giảm tác dụng","bbox":[43.94,330.68,100.4,343.31],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0071","type":"paragraph","text":"Nồng độ huyết tương của ethosuximid có thể giảm đi khi dùng đồng thời với nevirapin, phenytoin, phenobarbital, carbamazepin, ginkgo biloba, evening primprose.","page":710,"printed_page":716,"column":0,"bbox":[43.94,342.53,298.28,379.34],"source":{"line_count":3}},{"id":"b0072","type":"paragraph","text":"Không dùng đồng thời ethosuximid với rượu hoặc các thuốc gây co giật.","page":710,"printed_page":716,"column":0,"bbox":[43.94,378.55,298.27,403.36],"source":{"line_count":2}},{"id":"b0073","type":"heading","level":2,"text":"Quá liều và xử trí","page":710,"printed_page":716,"column":0,"bbox":[43.94,405.42,115.61,418.57],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[43.94,405.42,115.61,418.57],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0074","type":"paragraph","text":"Triệu chứng: Ngộ độc cấp có thể gây buồn nôn, nôn, ức chế TKTW bao gồm hôn mê kèm theo suy hô hấp. Mối liên quan giữa độc tính của ethosuximid và nồng độ của thuốc trong huyết tương chưa được xác định.","page":710,"printed_page":716,"column":0,"bbox":[43.94,417.58,298.27,466.4],"source":{"line_count":4}},{"id":"b0075","type":"paragraph","text":"Xử trí: Khi uống quá 2 g, phải rửa dạ dày hoặc cho dùng than hoạt nếu thời gian uống chưa quá 4 giờ.","page":710,"printed_page":716,"column":0,"bbox":[43.94,465.62,298.27,490.42],"source":{"line_count":2}},{"id":"b0076","type":"paragraph","text":"Duy trì hô hấp và điều trị triệu chứng. Có thể cho thẩm tách máu, nhưng truyền thay máu và bài niệu cưỡng bức thì không có hiệu quả.","page":710,"printed_page":716,"column":0,"bbox":[43.94,489.63,298.27,526.45],"source":{"line_count":3}},{"id":"b0077","type":"paragraph","text":"Cập nhật lần cuối: 2020.","page":710,"printed_page":716,"column":0,"bbox":[43.94,531.22,139.2,543.86],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2020.","bbox":[43.94,531.22,139.2,543.86],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"ethosuximid","title":"ETHOSUXIMID","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007","b0008"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0009","blocks":["b0010","b0011","b0012","b0013","b0014"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0015","blocks":["b0016","b0017","b0018"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0019","blocks":["b0020"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0021","blocks":["b0022","b0023","b0024","b0025","b0026","b0027","b0028","b0029","b0030","b0031"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0032","blocks":["b0033","b0034","b0035"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0036","blocks":["b0037"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0038","blocks":["b0039","b0040","b0041","b0042","b0043","b0044","b0045","b0046","b0047","b0048","b0049","b0050"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0051","blocks":["b0052","b0053"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0054","blocks":["b0055","b0056","b0057","b0058","b0059","b0060","b0061","b0062","b0063","b0064","b0065"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0066","blocks":["b0067","b0068","b0069","b0070","b0071","b0072"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0073","blocks":["b0074","b0075","b0076","b0077"]}],"quality":{"block_count":77,"heading_count":13,"subheading_count":7,"paragraph_count":56,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}