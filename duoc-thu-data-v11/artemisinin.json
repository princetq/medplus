    {
      "id": "b0007",
      "type": "paragraph",
      "text": "Viên nén, viên nang cứng: 250 mg Viên đạn: 100 mg, 200 mg, 300 mg, 400 mg, 500 mg.",
      "page": 230,
      "printed_page": 236,
      "column": 0,
      "bbox": [
