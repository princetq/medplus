      }
    },
    {
      "id": "b0008",
      "type": "heading",
      "level": 2,
      "text": "Dược lực học",
      "page": 230,
      "printed_page": 236,
      "column": 0,
      "bbox": [
        43.43,
        604.88,
        97.03,
        618.02
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Dược lực học",
          "bbox": [
            43.43,
            604.88,
            97.03,
            618.02
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
