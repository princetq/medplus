{"schema_version":"11.0.0-alpha.1","id":"exemestan","title":"Exemestan","aliases":["exemestan"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":723,"end":724},"printed_pages":{"start":729,"end":730},"extraction":{"start_title_pdf_page":723,"start_column":"left","start_y":62.82659912109375,"next_title_pdf_page":724,"next_column":"left","next_y":288.55413818359375,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"EXEMESTAN","page":723,"printed_page":729,"column":0,"bbox":[129.6,62.83,192.2,76.67],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"EXEMESTAN","bbox":[129.6,62.83,192.2,76.67],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Exemestane.","page":723,"printed_page":729,"column":0,"bbox":[34.93,86.42,163.44,99.56],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[34.93,86.42,115.16,99.56],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Exemestane.","bbox":[115.16,86.57,163.44,99.37],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: L02BG06.","page":723,"printed_page":729,"column":0,"bbox":[34.93,98.14,115.76,111.29],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[34.93,98.14,75.39,111.29],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"L02BG06.","bbox":[75.39,98.29,115.76,111.09],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc chống ung thư, ức chế aromatase.","page":723,"printed_page":729,"column":0,"bbox":[34.93,109.86,238.36,123.01],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[34.93,109.86,84.02,123.01],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc chống ung thư, ức chế aromatase.","bbox":[84.02,110.02,238.36,122.81],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":723,"printed_page":729,"column":0,"bbox":[34.93,125.09,139.85,138.23],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[34.93,125.09,139.85,138.23],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Viên nén: 25 mg.","page":723,"printed_page":729,"column":0,"bbox":[34.93,137.46,100.33,150.26],"source":{"line_count":1},"spans":[{"text":"Viên nén: 25 mg.","bbox":[34.93,137.46,100.33,150.26],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"heading","level":2,"text":"Dược lực học","page":723,"printed_page":729,"column":0,"bbox":[34.93,152.53,88.53,165.68],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[34.93,152.53,88.53,165.68],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Exemestan là chất ức chế chọn lọc không hồi phục aromatase steroid. Thuốc có tác dụng ngăn ngừa sự chuyển đổi các androgen thành estrogen ở các mô ngoại vi do đó làm giảm lượng estrogen lưu thông ở bệnh nhân trong khi estrogen là yếu tố tăng trưởng của ung thư vú phụ thuộc estrogen. Khác với anastrozol và letrozol là các thuốc ức chế aromatase không steroid, exemestan có cấu trúc steroid.","page":723,"printed_page":729,"column":0,"bbox":[34.93,164.91,289.27,251.04],"source":{"line_count":7}},{"id":"b0009","type":"heading","level":2,"text":"Dược động học","page":723,"printed_page":729,"column":0,"bbox":[34.93,253.32,96.03,266.47],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[34.93,253.32,96.03,266.47],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Hấp thu: Exemestan được hấp thu nhanh ở ống tiêu hóa. Sinh khả dụng bị hạn chế do chuyển hóa bước đầu ở gan nhưng tăng lên khoảng 40% nếu uống sau bữa ăn có nhiều mỡ. Thời gian đạt nồng độ đỉnh ở huyết tương là 1,2 giờ ở phụ nữ bị ung thư vú.","page":723,"printed_page":729,"column":0,"bbox":[34.93,265.69,289.26,315.16],"source":{"line_count":4}},{"id":"b0011","type":"paragraph","text":"Phân bố: Thuốc được phân bố rộng khắp và gắn nhiều vào protein huyết tương (90%), chủ yếu là gắn vào albumin và acid alpha1glycoprotein.","page":723,"printed_page":729,"column":0,"bbox":[34.93,314.59,289.26,351.83],"source":{"line_count":3}},{"id":"b0012","type":"paragraph","text":"Chuyển hóa, thải trừ: Exemestan bị oxy hóa bởi isoenzym CYP3A4 và bị khử bởi aldoketoreductase, tạo ra nhiều chất chuyển hóa không có hoạt tính. Các chất chuyển hóa được đào thải theo nước tiểu (39 - 45%) và theo phân (36 - 48%); dưới 1% liều được bài xuất dưới dạng không thay đổi trong nước tiểu. Nửa đời thải trừ cuối cùng của thuốc vào khoảng 24 giờ.","page":723,"printed_page":729,"column":0,"bbox":[34.93,351.26,289.26,425.17],"source":{"line_count":6}},{"id":"b0013","type":"heading","level":2,"text":"Chỉ định","page":723,"printed_page":729,"column":0,"bbox":[34.93,427.45,70.57,440.59],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[34.93,427.45,70.57,440.59],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0014","type":"paragraph","text":"Ung thư vú giai đoạn muộn ở phụ nữ mãn kinh (tự nhiên hoặc nhân tạo) sau thất bại điều trị bằng thuốc kháng estrogen.","page":723,"printed_page":729,"column":0,"bbox":[34.93,439.82,289.26,464.84],"source":{"line_count":2}},{"id":"b0015","type":"paragraph","text":"Hỗ trợ điều trị ung thư vú ở giai đoạn sớm, có thụ thể estrogen dương tính ở phụ nữ mãn kinh sau một trị liệu ban đầu bằng tamoxifen kéo dài 2 - 3 năm.","page":723,"printed_page":729,"column":0,"bbox":[34.93,464.27,289.26,501.51],"source":{"line_count":3}},{"id":"b0016","type":"heading","level":2,"text":"Chống chỉ định","page":723,"printed_page":729,"column":0,"bbox":[34.93,503.79,97.23,516.93],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[34.93,503.79,97.23,516.93],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0017","type":"paragraph","text":"Dị ứng với exemestan.","page":723,"printed_page":729,"column":0,"bbox":[34.93,516.16,121.09,528.96],"source":{"line_count":1},"spans":[{"text":"Dị ứng với exemestan.","bbox":[34.93,516.16,121.09,528.96],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Phụ nữ chưa mãn kinh.","page":723,"printed_page":729,"column":0,"bbox":[34.93,528.38,123.07,541.18],"source":{"line_count":1},"spans":[{"text":"Phụ nữ chưa mãn kinh.","bbox":[34.93,528.38,123.07,541.18],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0019","type":"paragraph","text":"Phụ nữ mang thai hoặc nghi ngờ đang mang thai.","page":723,"printed_page":729,"column":0,"bbox":[34.93,540.61,221.9,553.4],"source":{"line_count":1},"spans":[{"text":"Phụ nữ mang thai hoặc nghi ngờ đang mang thai.","bbox":[34.93,540.61,221.9,553.4],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0020","type":"note","level":2,"text":"Thận trọng","page":723,"printed_page":729,"column":0,"bbox":[34.93,555.68,81.12,568.83],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[34.93,555.68,81.12,568.83],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0021","type":"paragraph","text":"Tránh nhầm lẫn với thuốc estramustin.","page":723,"printed_page":729,"column":0,"bbox":[34.93,568.05,181.58,580.85],"source":{"line_count":1},"spans":[{"text":"Tránh nhầm lẫn với thuốc estramustin.","bbox":[34.93,568.05,181.58,580.85],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0022","type":"paragraph","text":"Thuốc có thể gây buồn ngủ, nhược cơ, chóng mặt. Thận trọng khi lái xe, vận hành máy.","page":723,"printed_page":729,"column":0,"bbox":[34.93,580.28,289.26,605.3],"source":{"line_count":2}},{"id":"b0023","type":"paragraph","text":"Exemestan nên được sử dụng thận trọng ở người suy gan hoặc suy thận vì thuốc có thể làm trầm trọng bệnh lý.","page":723,"printed_page":729,"column":0,"bbox":[34.93,604.72,289.26,629.74],"source":{"line_count":2}},{"id":"b0024","type":"paragraph","text":"Exemestan làm giảm estrogen mạnh, giảm mật độ xương (BMD) và tăng tỷ lệ rạn nứt xương sau khi dùng thuốc. Khi bắt đầu điều trị exemestan, phụ nữ bị loãng xương hoặc có nguy cơ bị loãng xương cần phải được đánh giá về mật độ xương dựa trên các hướng dẫn và thực hành lâm sàng hiện tại. Những bệnh nhân mắc bệnh u thư vú ở thời kỳ tiến triển nên được kiểm tra và đánh giá mật độ xương trên cơ sở từng trường hợp cụ thể. Mặc dù chưa có dữ liệu đầy đủ cho thấy hiệu quả điều trị giảm mật độ xương do exemestan gây ra, những bệnh nhân có nguy cơ cao điều trị với exemestran nên được theo dõi cẩn thận và nên điều trị, hoặc dự phòng loãng xương.","page":723,"printed_page":729,"column":0,"bbox":[34.93,629.17,289.26,751.98],"source":{"line_count":10}},{"id":"b0025","type":"paragraph","text":"Do tỷ lệ thiếu hụt vitamin D cao ở phụ nữ mắc ung thư giai đoạn sớm, vì vậy nên cân nhắc đánh giá định kỳ nồng độ vitamin D 25-hydroxy trước khi bắt đầu điều trị ức chế aromatase. Phụ nữ bị thiếu vitamin D cần được bổ sung vitamin D.","page":723,"printed_page":729,"column":0,"bbox":[34.93,751.4,289.26,800.87],"source":{"line_count":4}},{"id":"b0026","type":"heading","level":2,"text":"Thời kỳ mang thai","page":723,"printed_page":729,"column":1,"bbox":[298.88,63.02,374.09,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[298.88,63.02,374.09,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0027","type":"paragraph","text":"Thuốc độc với thai. Không dùng cho phụ nữ mang thai. Phải thông báo cho bệnh nhân biết nguy cơ của thuốc đối với thai nếu có thai trong thời gian trị liệu.","page":723,"printed_page":729,"column":1,"bbox":[298.88,75.2,553.22,112.06],"source":{"line_count":3}},{"id":"b0028","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":723,"printed_page":729,"column":1,"bbox":[298.88,114.15,379.37,127.29],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú ","bbox":[298.88,114.15,379.37,127.29],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0029","type":"paragraph","text":"Tránh dùng cho phụ nữ đang cho con bú. Phải ngừng cho bú nếu dùng thuốc.","page":723,"printed_page":729,"column":1,"bbox":[298.88,126.33,553.21,151.16],"source":{"line_count":2}},{"id":"b0030","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":723,"printed_page":729,"column":1,"bbox":[298.88,153.24,444.83,166.39],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[298.88,153.24,444.83,166.39],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0031","type":"paragraph","text":"Các tác dụng phụ của exemestan giống như tác dụng phụ của các thuốc ức chế aromatase (như anastrozol).","page":723,"printed_page":729,"column":1,"bbox":[298.88,165.43,553.21,190.26],"source":{"line_count":2}},{"id":"b0032","type":"subheading","level":3,"text":"Rất thường gặp","page":723,"printed_page":729,"column":1,"bbox":[298.88,189.65,358.22,202.29],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Rất thường gặp","bbox":[298.88,189.65,358.22,202.29],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0033","type":"paragraph","text":"Tim mạch: huyết áp tăng (5 - 15%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,201.52,434.69,214.32],"source":{"line_count":1},"spans":[{"text":"Tim mạch: huyết áp tăng (5 - 15%).","bbox":[298.88,201.52,434.69,214.32],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0034","type":"paragraph","text":"TKTW: mệt mỏi (8 - 22%), mất ngủ (11 - 14%), đau (13%), nhức đầu (7 - 13%), trầm cảm (6 - 13%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,213.56,553.21,238.38],"source":{"line_count":2}},{"id":"b0035","type":"paragraph","text":"Da: đổ mồ hôi (4 - 18%), rụng tóc (15%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,237.62,456.92,250.42],"source":{"line_count":1},"spans":[{"text":"Da: đổ mồ hôi (4 - 18%), rụng tóc (15%).","bbox":[298.88,237.62,456.92,250.42],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0036","type":"paragraph","text":"Nội tiết - chuyển hóa: cơn bốc hỏa (13 - 21%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,249.65,476.19,262.45],"source":{"line_count":1},"spans":[{"text":"Nội tiết - chuyển hóa: cơn bốc hỏa (13 - 21%).","bbox":[298.88,249.65,476.19,262.45],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0037","type":"paragraph","text":"Tiêu hóa: buồn nôn (9 - 18%), đau bụng (6 - 11%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,261.68,492.11,274.48],"source":{"line_count":1},"spans":[{"text":"Tiêu hóa: buồn nôn (9 - 18%), đau bụng (6 - 11%).","bbox":[298.88,261.68,492.11,274.48],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0038","type":"paragraph","text":"Gan: tăng phosphatase kiềm (14 - 15%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,273.72,452.17,286.51],"source":{"line_count":1},"spans":[{"text":"Gan: tăng phosphatase kiềm (14 - 15%).","bbox":[298.88,273.72,452.17,286.51],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Cơ xương: đau khớp (15 - 29%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,285.75,423.33,298.55],"source":{"line_count":1},"spans":[{"text":"Cơ xương: đau khớp (15 - 29%).","bbox":[298.88,285.75,423.33,298.55],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0040","type":"subheading","level":3,"text":"Thường gặp","page":723,"printed_page":729,"column":1,"bbox":[298.88,297.94,345.29,310.58],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp","bbox":[298.88,297.94,345.29,310.58],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0041","type":"paragraph","text":"Tim - mạch: phù (6 - 7%), thiếu máu cơ tim (2%), đau thắt ngực.","page":723,"printed_page":729,"column":1,"bbox":[298.88,309.81,547.77,322.61],"source":{"line_count":1},"spans":[{"text":"Tim - mạch: phù (6 - 7%), thiếu máu cơ tim (2%), đau thắt ngực. ","bbox":[298.88,309.81,547.77,322.61],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0042","type":"paragraph","text":"TKTW: chóng mặt (8 - 10%), lo âu (4 - 10%), sốt (5%), lú lẫn, giảm cảm giác.","page":723,"printed_page":729,"column":1,"bbox":[298.88,321.85,553.21,346.67],"source":{"line_count":2}},{"id":"b0043","type":"paragraph","text":"Da: viêm da (8%), ngứa, nổi mẩn.","page":723,"printed_page":729,"column":1,"bbox":[298.88,345.91,428.3,358.71],"source":{"line_count":1},"spans":[{"text":"Da: viêm da (8%), ngứa, nổi mẩn.","bbox":[298.88,345.91,428.3,358.71],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0044","type":"paragraph","text":"Nội tiết - chuyển hóa: tăng cân (8%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,357.94,439.77,370.74],"source":{"line_count":1},"spans":[{"text":"Nội tiết - chuyển hóa: tăng cân (8%).","bbox":[298.88,357.94,439.77,370.74],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0045","type":"paragraph","text":"Tiêu hóa: ỉa chảy (4 - 10%), nôn (7%), chán ăn (6%), táo bón (5%), tăng cảm giác thèm ăn (3%), khó tiêu hóa.","page":723,"printed_page":729,"column":1,"bbox":[298.88,369.98,553.21,394.8],"source":{"line_count":2}},{"id":"b0046","type":"paragraph","text":"Niệu - dục: nhiễm khuẩn đường niệu.","page":723,"printed_page":729,"column":1,"bbox":[298.88,394.04,441.25,406.84],"source":{"line_count":1},"spans":[{"text":"Niệu - dục: nhiễm khuẩn đường niệu.","bbox":[298.88,394.04,441.25,406.84],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0047","type":"paragraph","text":"Gan: bilirubin tăng (5 - 7%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,406.07,407.59,418.87],"source":{"line_count":1},"spans":[{"text":"Gan: bilirubin tăng (5 - 7%).","bbox":[298.88,406.07,407.59,418.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0048","type":"paragraph","text":"Cơ xương: đau lưng (9%), đau chi dưới (9%), viêm xương khớp (6%), yếu cơ (6%), loãng xương (5%), gãy xương bệnh lý (4%), loạn cảm (3%), hội chứng ống cổ tay (2%), chuột rút (2%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,418.1,553.21,454.97],"source":{"line_count":3}},{"id":"b0049","type":"paragraph","text":"Mắt: rối loạn nhìn (5%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,454.2,391.5,467.0],"source":{"line_count":1},"spans":[{"text":"Mắt: rối loạn nhìn (5%).","bbox":[298.88,454.2,391.5,467.0],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0050","type":"paragraph","text":"Thận: creatinin tăng (6%).","page":723,"printed_page":729,"column":1,"bbox":[298.88,466.23,399.13,479.03],"source":{"line_count":1},"spans":[{"text":"Thận: creatinin tăng (6%).","bbox":[298.88,466.23,399.13,479.03],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0051","type":"paragraph","text":"Hô hấp: khó thở (10%), ho (6%), viêm phế quản, viêm mũi, viêm xoang, nhiễm khuẩn đường hô hấp trên.","page":723,"printed_page":729,"column":1,"bbox":[298.88,478.27,553.21,503.09],"source":{"line_count":2}},{"id":"b0052","type":"paragraph","text":"Khác: hội chứng giống cúm (6%), tăng tiết mồ hôi (6%), phù bạch huyết, nhiễm khuẩn.","page":723,"printed_page":729,"column":1,"bbox":[298.88,502.33,553.21,527.16],"source":{"line_count":2}},{"id":"b0053","type":"subheading","level":3,"text":"Các ADR khác","page":723,"printed_page":729,"column":1,"bbox":[298.88,526.56,355.17,539.19],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Các ADR khác","bbox":[298.88,526.56,355.17,539.19],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0054","type":"paragraph","text":"Suy tim. Quá sản nội mạc tử cung. Tăng GGT. Bệnh thần kinh.","page":723,"printed_page":729,"column":1,"bbox":[298.88,538.43,538.51,551.22],"source":{"line_count":1},"spans":[{"text":"Suy tim. Quá sản nội mạc tử cung. Tăng GGT. Bệnh thần kinh.","bbox":[298.88,538.43,538.51,551.22],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0055","type":"paragraph","text":"Giảm tiểu cầu, giảm bạch cầu (ở bệnh nhân bị ung thư giai đoạn muộn).","page":723,"printed_page":729,"column":1,"bbox":[298.88,550.46,553.22,575.29],"source":{"line_count":2}},{"id":"b0056","type":"paragraph","text":"Hư xương sụn, huyết khối tắc mạch, tăng transaminase, co quắp ngón tay, polyp tử cung.","page":723,"printed_page":729,"column":1,"bbox":[298.88,574.52,553.22,599.35],"source":{"line_count":2}},{"id":"b0057","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":723,"printed_page":729,"column":1,"bbox":[298.88,601.44,413.45,614.58],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[298.88,601.44,413.45,614.58],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0058","type":"paragraph","text":"Phần lớn các ADR được cho là do giảm estrogen. Theo dõi biểu hiện của các tác dụng phụ và điều trị triệu chứng, hỗ trợ.","page":723,"printed_page":729,"column":1,"bbox":[298.88,613.62,553.21,638.45],"source":{"line_count":2}},{"id":"b0059","type":"paragraph","text":"Đề phòng loãng xương: Theo dõi mật độ xương, bổ sung vitamin D và calci trong khẩu phần.","page":723,"printed_page":729,"column":1,"bbox":[298.88,637.69,553.24,662.51],"source":{"line_count":2}},{"id":"b0060","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":723,"printed_page":729,"column":1,"bbox":[298.88,664.6,399.06,677.75],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[298.88,664.6,399.06,677.75],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0061","type":"paragraph","text":"Uống thuốc sau bữa ăn. Liều uống: 25 mg/ngày; uống 1 lần. Phải duy trì uống thuốc cho đến khi có bằng chứng khối u giảm.","page":723,"printed_page":729,"column":1,"bbox":[298.88,676.78,553.21,701.61],"source":{"line_count":2}},{"id":"b0062","type":"paragraph","text":"Bệnh nhân bị ung thư vú giai đoạn sớm phải dùng thuốc trong thời gian dài tới 5 năm theo trị liệu hỗ trợ tiếp nối (tamoxifen được tiếp theo bằng exemestan). Nếu khối u tái phát thì ngừng exemestan.","page":723,"printed_page":729,"column":1,"bbox":[298.88,700.85,553.22,737.71],"source":{"line_count":3}},{"id":"b0063","type":"paragraph","text":"Bệnh nhân bị ung thư vú giai đoạn muộn phải dùng exemestan cho đến khi nào có dấu hiệu bệnh tiến triển tốt.","page":723,"printed_page":729,"column":1,"bbox":[298.88,736.94,553.21,761.77],"source":{"line_count":2}},{"id":"b0064","type":"paragraph","text":"Bệnh nhân cần được bổ sung vitamin D và calci.","page":723,"printed_page":729,"column":1,"bbox":[298.88,761.01,483.72,773.8],"source":{"line_count":1},"spans":[{"text":"Bệnh nhân cần được bổ sung vitamin D và calci.","bbox":[298.88,761.01,483.72,773.8],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0065","type":"heading","level":2,"text":"Tương tác thuốc","page":723,"printed_page":729,"column":1,"bbox":[298.88,775.89,365.79,789.04],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[298.88,775.89,365.79,789.04],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0066","type":"paragraph","text":"Các thuốc kích thích izoenzym CYP3A4 (ví dụ: rifampicin,","page":723,"printed_page":729,"column":1,"bbox":[298.88,788.07,553.22,800.87],"source":{"line_count":1},"spans":[{"text":"Các thuốc kích thích izoenzym CYP3A4 (ví dụ: rifampicin, ","bbox":[298.88,788.07,553.22,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0067","type":"paragraph","text":"phenytoin, deferasirox) làm giảm nồng độ exemestan. Cần tăng liều exemestan lên 50 mg/ngày ở bệnh nhân dùng đồng thời các thuốc này.","page":724,"printed_page":730,"column":0,"bbox":[43.94,63.32,298.27,100.12],"source":{"line_count":3}},{"id":"b0068","type":"paragraph","text":"Hypericum perforatum (cỏ St.John) làm giảm nồng độ exemestan.","page":724,"printed_page":730,"column":0,"bbox":[43.94,99.32,298.27,112.12],"source":{"line_count":1},"spans":[{"text":"Hypericum perforatum","bbox":[43.94,99.48,131.3,112.12],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":" (cỏ St.John) làm giảm nồng độ exemestan. ","bbox":[131.3,99.32,298.27,112.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0069","type":"paragraph","text":"Không dùng Cimicifuga racemosa (thăng ma), Angelica sinensis (đương quy) cho người bị ung thư vú phụ thuộc estrogen.","page":724,"printed_page":730,"column":0,"bbox":[43.94,111.32,298.27,136.12],"source":{"line_count":2}},{"id":"b0070","type":"paragraph","text":"Không dùng đồng thời với các thuốc có estrogen vì các thuốc này làm mất tác dụng của exemestan.","page":724,"printed_page":730,"column":0,"bbox":[43.94,135.32,298.27,160.12],"source":{"line_count":2}},{"id":"b0071","type":"paragraph","text":"Exemestan làm giảm nồng độ và tác dụng của maraviroc (thuốc ngăn HIV xâm nhập vào lympho T CD4 do chặn receptor CCR5).","page":724,"printed_page":730,"column":0,"bbox":[43.94,159.32,298.27,184.12],"source":{"line_count":2}},{"id":"b0072","type":"heading","level":2,"text":"Quá liều và xử trí","page":724,"printed_page":730,"column":0,"bbox":[43.94,186.17,115.61,199.32],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[43.94,186.17,115.61,199.32],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0073","type":"paragraph","text":"Chưa có dữ liệu về ngộ độc do quá liều. Không có thuốc giải độc đặc hiệu với exemestan. Nếu nghi ngờ uống quá liều thì cần theo dõi chặt chẽ các dấu hiệu sinh tồn, điều trị triệu chứng, điều trị hỗ trợ (ví dụ, bồi phụ nước, điện giải trong trường hợp nôn/ỉa chảy nặng).","page":724,"printed_page":730,"column":0,"bbox":[43.94,198.32,298.31,247.12],"source":{"line_count":4}},{"id":"b0074","type":"paragraph","text":"Cập nhật lần cuối: 2018.","page":724,"printed_page":730,"column":0,"bbox":[43.94,251.88,139.2,264.52],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2018.","bbox":[43.94,251.88,139.2,264.52],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"exemestan","title":"EXEMESTAN","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0007","blocks":["b0008"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0009","blocks":["b0010","b0011","b0012"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0013","blocks":["b0014","b0015"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0016","blocks":["b0017","b0018","b0019","b0020","b0021","b0022","b0023","b0024","b0025"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0026","blocks":["b0027"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0028","blocks":["b0029"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0030","blocks":["b0031","b0032","b0033","b0034","b0035","b0036","b0037","b0038","b0039","b0040","b0041","b0042","b0043","b0044","b0045","b0046","b0047","b0048","b0049","b0050","b0051","b0052","b0053","b0054","b0055","b0056"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0057","blocks":["b0058","b0059"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0060","blocks":["b0061","b0062","b0063","b0064"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0065","blocks":["b0066","b0067","b0068","b0069","b0070","b0071"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0072","blocks":["b0073","b0074"]}],"quality":{"block_count":74,"heading_count":13,"subheading_count":3,"paragraph_count":57,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}