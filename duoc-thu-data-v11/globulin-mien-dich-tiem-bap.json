      "printed_page": 830,
      "column": 0,
      "bbox": [
        43.94,
        447.07,
        257.13,
        459.86
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Giảm tiểu cầu nặng hoặc rối loạn đông máu trầm trọng. ",
          "bbox": [
            43.94,
            447.07,
            257.13,
