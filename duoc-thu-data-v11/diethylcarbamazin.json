          "bbox": [
            299.39,
            666.38,
            321.81,
            679.02
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        },
        {
          "text": ": nôn, buồn nôn, chóng mặt, uể oải.",
