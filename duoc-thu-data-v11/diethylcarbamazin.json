        }
      ]
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Từ ngày điều trị thứ 3 đến thứ 12, có thể có phản ứng tại chỗ như viêm bạch mạch, sưng to từng vùng, hoặc áp xe bạch huyết, nốt phỏng nhỏ, sần dẹt.",
      "page": 582,
      "printed_page": 588,
      "column": 0,
      "bbox": [
        43.43,
        87.39,
        297.77,
        124.24
      ],
      "source": {
