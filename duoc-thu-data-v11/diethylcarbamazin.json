        }
      ]
    },
    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Hiếm gặp: xuất huyết võng mạc, bệnh não, phản ứng quá mẫn.",
      "page": 582,
      "printed_page": 588,
      "column": 0,
      "bbox": [
        43.43,
        75.36,
        281.83,
        88.16
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Hiếm gặp",
          "bbox": [
            43.43,
            75.52,
            80.64,
            88.16
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        },
        {
          "text": ": xuất huyết võng mạc, bệnh não, phản ứng quá mẫn.",
          "bbox": [
            80.64,
