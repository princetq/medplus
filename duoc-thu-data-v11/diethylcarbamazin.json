          "italic": false
        }
      ]
    },
    {
      "id": "b0039",
      "type": "paragraph",
      "text": "Ít gặp: nôn, buồn nôn, chóng mặt, uể oải.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        666.22,
        456.12,
        679.02
      ],
