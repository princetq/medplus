        666.83
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Thường gặp: ",
          "bbox": [
            299.39,
            654.2,
            351.33,
            666.83
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        },
        {
          "text": "nhức đầu, khó chịu, chán ăn, yếu mệt.",
