    {
      "id": "b0036",
      "type": "paragraph",
      "text": "ADR xảy ra trong quá trình dùng dithethylcarbamazin điều trị nhiễm giun chỉ bạch huyết về cơ bản có 2 loại: Phản ứng do thuốc và phản ứng của cơ thể do ký sinh trùng chết.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        605.29,
        553.72,
        642.46
      ],
      "source": {
        "line_count": 3
      }
    },
    {
