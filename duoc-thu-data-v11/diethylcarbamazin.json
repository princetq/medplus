      }
    },
    {
      "id": "b0047",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 582,
      "printed_page": 588,
      "column": 0,
      "bbox": [
        43.43,
        126.32,
        143.61,
        139.47
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng và cách dùng",
