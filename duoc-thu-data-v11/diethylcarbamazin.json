            340.25,
            345.57,
            353.4
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ],
      "note_role": "than trong",
      "v11_fix": "note_title_reclassified_as_heading_alpha5"
    },
    {
      "id": "b0026",
      "type": "paragraph",
      "text": "Nên tránh dùng thuốc đại trà ở những vùng có dịch địa phương Onchocerca hoặc Loa loa, mặc dù có thể dùng cho những người du lịch nước ngoài muốn phòng lây nhiễm.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        352.58,
        553.72,
        389.75
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0027",
      "type": "paragraph",
      "text": "Cho dùng trước corticoid và kháng histamin để giảm thiểu các phản ứng gián tiếp do ấu trùng chết gây ra.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        389.14,
        553.72,
        414.12
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0028",
      "type": "paragraph",
      "text": "Phải thận trọng với người tăng huyết áp, suy thận, người có tiền sử co giật. Cần giảm liều ở người có rối loạn chức năng thận hay có nước tiểu kiềm. Người bệnh nghi có bệnh sốt rét cần được chữa sốt rét trước khi cho uống diethylcarbamazin, vì thuốc có thể gây tái phát nhiễm sốt rét không có triệu chứng.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        413.51,
        553.72,
        475.05
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0029",
      "type": "paragraph",
      "text": "Người bệnh bị viêm bạch mạch do giun chỉ Wuchereria bancrofti hay Brugia malayi nên được điều trị vào giai đoạn bệnh không hoạt động, giữa các đợt bột phát.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        474.44,
        553.72,
        511.61
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0030",
      "type": "paragraph",
      "text": "Bệnh nhân bị nhiễm Loa loa nặng, có nguy cơ rủi ro cho não, phải dừng ngay diethylcarbamazin nếu bắt đầu xuất hiện dấu hiệu về não.",
      "page": 581,
      "printed_page": 587,
      "column": 1,
      "bbox": [
        299.39,
        510.99,
        553.73,
        535.98
      ],
      "source": {
        "line_count": 2
      }
    },
    {
