          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0036",
      "type": "paragraph",
      "text": "Chưa rõ oxymetazolin có phân bố vào sữa mẹ hay không, vì vậy nên thận trọng khi dùng thuốc cho phụ nữ đang cho con bú.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        114.92,
        553.71,
        139.9
