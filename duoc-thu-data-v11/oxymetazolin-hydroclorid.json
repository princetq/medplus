        }
      ]
    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Sự an toàn của oxymetazolin đối với phụ nữ mang thai chưa được biết rõ. Chỉ nên sử dụng thuốc khi có sự chỉ dẫn của thầy thuốc.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        75.36,
        553.72,
