    },
    {
      "id": "b0056",
      "type": "subheading",
      "level": 3,
      "text": "Sung huyết kết mạc:",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        550.66,
        378.53,
        563.3
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 0.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-ItalicMT"
        ]
      },
      "spans": [
        {
          "text": "Sung huyết kết mạc: ",
          "bbox": [
            299.39,
            550.66,
            378.53,
            563.3
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        }
      ]
    },
    {
      "id": "b0057",
      "type": "paragraph",
      "text": "Người lớn và trẻ em trên 6 tuổi: Nhỏ 1 giọt dung dịch 0,025% vào kết mạc, 6 giờ một lần. Thời gian dùng không nên quá 3 ngày.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        562.69,
        553.68,
        587.67
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0058",
      "type": "heading",
      "level": 2,
      "text": "Tương tác thuốc",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        589.91,
        366.29,
        603.06
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tương tác thuốc",
          "bbox": [
            299.39,
            589.91,
            366.29,
            603.06
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0059",
      "type": "paragraph",
      "text": "Oxymetazolin làm giảm tác dụng hạ huyết áp của các thuốc chẹn beta, methyldopa và các thuốc hạ huyết áp khác bao gồm cả các thuốc ức chế hệ adrenergic.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        602.25,
        553.72,
        639.43
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0060",
      "type": "paragraph",
      "text": "Nguy cơ tăng huyết áp và loạn nhịp tim có thể xảy ra khi phối hợp oxymetazolin với các thuốc chống trầm cảm 3 vòng, các thuốc kích thích thần kinh như amphetamin, các thuốc gây chán ăn, IMAO.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        638.82,
        553.72,
        675.99
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0061",
      "type": "paragraph",
      "text": "Phối hợp oxymetazolin với các thuốc điều trị Parkinson như bromocriptin có thể làm tăng độc tính trên tim mạch.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        675.38,
        553.71,
        700.37
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0062",
      "type": "paragraph",
      "text": "Phối hợp oxymetazolin với các glycosid tim có thể làm tăng nguy cơ loạn nhịp tim.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        699.76,
        553.72,
        724.74
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0063",
      "type": "paragraph",
      "text": "Nguy cơ ngộ độc tăng lên khi phối hợp oxymetazolin với các alkaloid cựa lõa mạch.",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        724.13,
        553.72,
        749.12
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0064",
      "type": "heading",
      "level": 2,
      "text": "Quá liều và xử trí",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        751.36,
        375.81,
        764.51
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Quá liều và xử trí  ",
          "bbox": [
            299.39,
            751.36,
            375.81,
            764.51
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0065",
      "type": "paragraph",
      "text": "Triệu chứng: Quá liều bao gồm các triệu chứng giãn đồng tử, buồn nôn, tím tái, sốt, nhịp tim nhanh, loạn nhịp tim, tăng huyết áp, khó thở, suy tim. Bệnh nhân cũng có thể xuất hiện các dấu hiệu ức chế",
      "page": 1248,
      "printed_page": 1254,
      "column": 1,
      "bbox": [
        299.39,
        763.7,
        553.72,
        800.87
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0066",
      "type": "paragraph",
      "text": "TKTW như giảm thân nhiệt, nhịp tim chậm, tụt huyết áp, ngừng thở, mất ý thức.",
      "page": 1249,
      "printed_page": 1255,
      "column": 0,
      "bbox": [
        43.43,
        63.32,
        297.76,
        88.17
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0067",
      "type": "paragraph",
      "text": "Xử trí: Chưa có thuốc giải độc đặc hiệu, trong trường hợp quá liều biện pháp chủ yếu là điều trị triệu chứng, trong trường hợp nặng, có thể cần thông khí nhân tạo cho bệnh nhân.",
      "page": 1249,
      "printed_page": 1255,
      "column": 0,
      "bbox": [
        43.43,
        87.43,
        297.77,
        124.33
      ],
      "source": {
        "line_count": 3
      }
    },
