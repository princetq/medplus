    {
      "id": "b0028",
      "type": "paragraph",
      "text": "Bệnh nhân đang dùng IMAO hoặc trong vòng 14 ngày sau khi dùng IMAO.",
      "page": 1248,
      "printed_page": 1254,
      "column": 0,
