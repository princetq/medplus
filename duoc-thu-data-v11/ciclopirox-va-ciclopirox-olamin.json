{"schema_version":"11.0.0-alpha.1","id":"ciclopirox-va-ciclopirox-olamin","title":"Ciclopirox Và Ciclopirox Olamin","aliases":["Ciclopirox Ciclopirox Olamin","ciclopirox va ciclopirox olamin"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":432,"end":434},"printed_pages":{"start":438,"end":440},"extraction":{"start_title_pdf_page":432,"start_column":"right","start_y":636.2599487304688,"next_title_pdf_page":434,"next_column":"left","next_y":356.6872253417969,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"CICLOPIROX VÀ CICLOPIROX OLAMIN","page":432,"printed_page":438,"column":1,"bbox":[336.36,636.26,530.34,650.1],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"CICLOPIROX VÀ CICLOPIROX OLAMIN","bbox":[336.36,636.26,530.34,650.1],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Ciclopirox, ciclopirox olamine.","page":432,"printed_page":438,"column":1,"bbox":[307.38,660.44,506.89,673.59],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[307.38,660.44,387.61,673.59],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Ciclopirox, ciclopirox olamine.","bbox":[387.62,660.59,506.89,673.39],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: D01AE14, G01AX12.","page":432,"printed_page":438,"column":1,"bbox":[307.38,672.76,433.07,685.91],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[307.38,672.76,347.84,685.91],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"D01AE14, G01AX12.","bbox":[347.84,672.91,433.07,685.71],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc kháng nấm tổng hợp, nhóm pyridon.","page":432,"printed_page":438,"column":1,"bbox":[307.38,685.07,521.93,698.22],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[307.38,685.07,356.47,698.22],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc kháng nấm tổng hợp, nhóm pyridon.","bbox":[356.47,685.23,521.93,698.02],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":432,"printed_page":438,"column":1,"bbox":[307.38,700.56,412.3,713.71],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[307.38,700.56,412.3,713.71],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"subheading","level":3,"text":"Dạng ciclopirox:","page":432,"printed_page":438,"column":1,"bbox":[307.38,713.35,372.19,725.99],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Dạng ciclopirox:","bbox":[307.38,713.35,372.19,725.99],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0007","type":"paragraph","text":"Gel bôi: 0,77%.","page":432,"printed_page":438,"column":1,"bbox":[307.38,725.67,367.55,738.47],"source":{"line_count":1},"spans":[{"text":"Gel bôi: 0,77%.","bbox":[307.38,725.67,367.55,738.47],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Dầu gội đầu: 1%.","page":432,"printed_page":438,"column":1,"bbox":[307.38,738.15,373.88,750.95],"source":{"line_count":1},"spans":[{"text":"Dầu gội đầu: 1%.","bbox":[307.38,738.15,373.88,750.95],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0009","type":"paragraph","text":"Dung dịch dùng ngoài: 8%.","page":432,"printed_page":438,"column":1,"bbox":[307.38,750.63,412.14,763.43],"source":{"line_count":1},"spans":[{"text":"Dung dịch dùng ngoài: 8%.","bbox":[307.38,750.63,412.14,763.43],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0010","type":"subheading","level":3,"text":"Dạng ciclopirox olamin:","page":432,"printed_page":438,"column":1,"bbox":[307.38,763.27,400.96,775.91],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Dạng ciclopirox olamin:","bbox":[307.38,763.27,400.96,775.91],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0011","type":"paragraph","text":"Kem bôi ngoài da, nhũ dịch dùng ngoài, hỗn dịch dùng ngoài:","page":432,"printed_page":438,"column":1,"bbox":[307.38,775.59,561.72,788.39],"source":{"line_count":1},"spans":[{"text":"Kem bôi ngoài da, nhũ dịch dùng ngoài, hỗn dịch dùng ngoài: ","bbox":[307.38,775.59,561.72,788.39],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0012","type":"paragraph","text":"0,77% (tính theo ciclopirox).","page":432,"printed_page":438,"column":1,"bbox":[307.38,788.07,417.41,800.87],"source":{"line_count":1},"spans":[{"text":"0,77% (tính theo ciclopirox).","bbox":[307.38,788.07,417.41,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0013","type":"heading","level":2,"text":"Dược lực học","page":433,"printed_page":439,"column":0,"bbox":[35.43,63.01,89.03,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[35.43,63.01,89.03,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0014","type":"paragraph","text":"Ciclopirox có tác dụng kháng nấm và diệt khuẩn chủ yếu nhờ khả năng ức chế sự vận chuyển các chất thiết yếu nội bào (các acid amin), các ion (ion kali) và các vật liệu nội bào khác qua màng tế bào nấm và vi khuẩn, từ đó làm giảm sự tổng hợp protein, ARN và ADN của tế bào nấm và vi khuẩn. Ciclopirox cũng có thể tạo phức chelat với các cation đa hóa trị (Fe3+, Al3+), dẫn đến ức chế các enzym phụ thuộc kim loại chịu trách nhiệm giáng hóa các peroxyd trong tế bào nấm.","page":433,"printed_page":439,"column":0,"bbox":[35.43,75.21,289.77,172.29],"source":{"line_count":8}},{"id":"b0015","type":"paragraph","text":"Phổ tác dụng: Ciclopirox và ciclopirox olamin có tác dụng kháng nấm đối với cả nấm sợi và nấm men. In vitro, thuốc có tác dụng trên các chủng nấm Trichophyton equinum, T. mentagrophytes, T. rubrum, T. schoenleinii, T. tonsurans, T. verrucosum, T. violaceum, Epidermophyton floccosum, Microsporum audouinii, M. canis, Candida albicans và Malssezia furfur (Pityrosporum orbiculare).","page":433,"printed_page":439,"column":0,"bbox":[35.43,171.54,289.77,256.59],"source":{"line_count":7}},{"id":"b0016","type":"paragraph","text":"Thuốc cũng có tác dụng diệt khuẩn in vitro đối với một số vi khuẩn Gram âm và Gram dương, một số chủng Mycoplasma và Trichomonas vaginalis.","page":433,"printed_page":439,"column":0,"bbox":[35.43,255.84,289.77,292.71],"source":{"line_count":3}},{"id":"b0017","type":"heading","level":2,"text":"Dược động học","page":433,"printed_page":439,"column":0,"bbox":[35.43,294.8,96.54,307.95],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[35.43,294.8,96.54,307.95],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Hấp thu: Ciclopirox được hấp thu qua da nhanh nhưng với lượng thấp. Nồng độ thuốc trong huyết tương trong vòng 1 giờ đầu sau khi bôi ngoài da 4 g ciclopirox dạng kem là dưới 0,01 microgam/ml.","page":433,"printed_page":439,"column":0,"bbox":[35.43,306.99,289.8,343.88],"source":{"line_count":3}},{"id":"b0019","type":"paragraph","text":"Sau khi bôi da 5 g ciclopirox dạng gel hoặc kem thì nồng độ đỉnh của thuốc trong huyết tương lần lượt là 25 hoặc 19 nanogam/ml.","page":433,"printed_page":439,"column":0,"bbox":[35.43,343.12,289.77,368.46],"source":{"line_count":2}},{"id":"b0020","type":"paragraph","text":"Trong một nghiên cứu khác, sau khi bôi 15 g ciclopirox dạng gel trong 14,5 ngày để điều trị nấm bẹn, nồng độ đỉnh của thuốc trong huyết tương ở ngày 1 và ngày 15 lần lượt là 100 và 238 nanogam/ml.","page":433,"printed_page":439,"column":0,"bbox":[35.43,368.2,289.8,406.09],"source":{"line_count":3}},{"id":"b0021","type":"paragraph","text":"Một nghiên cứu trên bệnh nhân bị viêm da đầu tiết bã nhờn, sau khi dùng 5,2 g (5 ml) dầu gội ciclopirox trong 4 tuần, chỉ phát hiện thuốc trong huyết tương trên 1/3 số bệnh nhân, nồng độ thuốc trong huyết tương dao động trong khoảng 10 - 13 nanogam/ml vào ngày 1 và ngày 29.","page":433,"printed_page":439,"column":0,"bbox":[35.43,405.83,289.77,468.79],"source":{"line_count":5}},{"id":"b0022","type":"paragraph","text":"Ciclopirox dạng dung dịch được hấp thu qua da ít (dưới 5% liều).","page":433,"printed_page":439,"column":0,"bbox":[35.43,468.54,289.77,481.34],"source":{"line_count":1},"spans":[{"text":"Ciclopirox dạng dung dịch được hấp thu qua da ít (dưới 5% liều). ","bbox":[35.43,468.54,289.77,481.34],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0023","type":"paragraph","text":"Ciclopirox dạng gel có mức độ hấp thu cao hơn dạng nhũ dịch dùng ngoài và kem bôi.","page":433,"printed_page":439,"column":0,"bbox":[35.43,481.08,289.76,506.42],"source":{"line_count":2}},{"id":"b0024","type":"paragraph","text":"Phân bố: Khi dùng ngoài da, một phần ciclopirox thấm qua chân lông, chân tóc rồi qua lớp biểu bì và nang lông vào tuyến bã nhờn và lớp bì, phần còn lại được giữ ở lớp sừng. Sau khi vào cơ thể, khoảng 94 - 98% lượng thuốc được gắn protein huyết tương. Trên chuột, lượng thuốc qua được hàng rào nhau thai là rất nhỏ. Chưa rõ ciclopirox có phân bố vào sữa không.","page":433,"printed_page":439,"column":0,"bbox":[35.43,506.16,289.77,581.67],"source":{"line_count":6}},{"id":"b0025","type":"paragraph","text":"Chuyển hóa: Quá trình chuyển hóa của ciclopirox trong cơ thể chưa được làm rõ. Thuốc có thể được chuyển hóa qua gan nhờ quá trình liên hợp với acid glucuronic.","page":433,"printed_page":439,"column":0,"bbox":[35.43,581.41,289.76,619.29],"source":{"line_count":3}},{"id":"b0026","type":"paragraph","text":"Thải trừ: Ciclopirox và chất chuyển hóa chính được thải trừ nhanh và gần như hoàn toàn qua nước tiểu. Hầu hết lượng thuốc được thải trừ qua nước tiểu sau 8 - 12 giờ. Sau 2 ngày, lượng thuốc được bài xuất qua nước tiểu chỉ bằng 0,01% liều dùng. Nửa đời của thuốc thay đổi tùy dạng bào chế, đối với dạng nhũ dịch dùng ngoài và kem bôi là 1,7 giờ, đối với dạng gel là 5,5 giờ.","page":433,"printed_page":439,"column":0,"bbox":[35.43,619.03,289.77,694.54],"source":{"line_count":6}},{"id":"b0027","type":"heading","level":2,"text":"Chỉ định","page":433,"printed_page":439,"column":0,"bbox":[35.43,700.13,71.08,713.28],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[35.43,700.13,71.08,713.28],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0028","type":"paragraph","text":"Nấm ngoài da, bao gồm nấm bàn chân, nấm kẽ ngón chân, nấm bẹn, nấm thân do Trichophyton rubrum, Trichophyton mentagrophytes, Epidermophyton floccosum và Microporum canis.","page":433,"printed_page":439,"column":0,"bbox":[35.43,712.82,289.76,750.7],"source":{"line_count":3}},{"id":"b0029","type":"paragraph","text":"Nấm ngoài da do Candida albicans.","page":433,"printed_page":439,"column":0,"bbox":[35.43,750.45,172.64,763.25],"source":{"line_count":1},"spans":[{"text":"Nấm ngoài da do ","bbox":[35.43,750.45,102.98,763.25],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"Candida albicans","bbox":[102.97,750.61,170.27,763.25],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":".","bbox":[170.27,750.45,172.64,763.25],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0030","type":"paragraph","text":"Lang ben do Malassezia furfur.","page":433,"printed_page":439,"column":0,"bbox":[35.43,762.99,154.96,775.79],"source":{"line_count":1},"spans":[{"text":"Lang ben do ","bbox":[35.43,762.99,85.3,775.79],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"Malassezia furfur","bbox":[85.29,763.15,152.59,775.79],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":".","bbox":[152.59,762.99,154.96,775.79],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0031","type":"paragraph","text":"Nấm móng chân, móng tay do nấm sợi, mức độ nhẹ đến vừa.","page":433,"printed_page":439,"column":0,"bbox":[35.43,775.53,267.39,788.33],"source":{"line_count":1},"spans":[{"text":"Nấm móng chân, móng tay do nấm sợi, mức độ nhẹ đến vừa.","bbox":[35.43,775.53,267.39,788.33],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0032","type":"paragraph","text":"Viêm da dầu ở đầu.","page":433,"printed_page":439,"column":0,"bbox":[35.43,788.07,109.28,800.87],"source":{"line_count":1},"spans":[{"text":"Viêm da dầu ở đầu.","bbox":[35.43,788.07,109.28,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0033","type":"heading","level":2,"text":"Chống chỉ định","page":433,"printed_page":439,"column":1,"bbox":[299.38,63.01,361.68,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[299.38,63.01,361.68,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0034","type":"paragraph","text":"Mẫn cảm với ciclopirox, ciclopirox olamin.","page":433,"printed_page":439,"column":1,"bbox":[299.38,75.7,465.1,88.49],"source":{"line_count":1},"spans":[{"text":"Mẫn cảm với ciclopirox, ciclopirox olamin.","bbox":[299.38,75.7,465.1,88.49],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0035","type":"note","level":2,"text":"Thận trọng","page":433,"printed_page":439,"column":1,"bbox":[299.38,94.07,345.57,107.22],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[299.38,94.07,345.57,107.22],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0036","type":"paragraph","text":"Hiệu quả và an toàn của ciclopirox chưa được chứng minh ở trẻ dưới 12 tuổi đối với dạng dung dịch, trẻ dưới 16 tuổi đối với dạng gel và dầu gội đầu, trẻ dưới 10 tuổi đối với dạng nhũ dịch dùng ngoài, hỗn dịch và kem bôi.","page":433,"printed_page":439,"column":1,"bbox":[299.38,106.74,553.72,157.12],"source":{"line_count":4}},{"id":"b0037","type":"paragraph","text":"Không dùng các chế phẩm dùng ngoài của ciclopirox để nhỏ mắt, uống hoặc bôi âm đạo. Nếu lỡ để thuốc dính lên mắt, cần rửa sạch bằng nước.","page":433,"printed_page":439,"column":1,"bbox":[299.38,156.84,553.72,194.69],"source":{"line_count":3}},{"id":"b0038","type":"paragraph","text":"Cần tuân thủ dùng thuốc đầy đủ ngay cả khi triệu chứng đã cải thiện. Nếu không cải thiện sau 4 tuần điều trị, cần đi khám lại.","page":433,"printed_page":439,"column":1,"bbox":[299.38,194.43,553.72,219.74],"source":{"line_count":2}},{"id":"b0039","type":"heading","level":2,"text":"Thời kỳ mang thai","page":433,"printed_page":439,"column":1,"bbox":[299.38,225.32,374.59,238.47],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[299.38,225.32,374.59,238.47],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0040","type":"paragraph","text":"Chưa rõ ciclopirox có được vận chuyển qua nhau thai hay không.","page":433,"printed_page":439,"column":1,"bbox":[299.38,238.0,553.71,250.8],"source":{"line_count":1},"spans":[{"text":"Chưa rõ ciclopirox có được vận chuyển qua nhau thai hay không. ","bbox":[299.38,238.0,553.71,250.8],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0041","type":"paragraph","text":"Dữ liệu trên người về an toàn của thuốc trong thời kỳ mang thai hiện chưa đầy đủ. Tuy nhiên, các nghiên cứu trên chuột nhắt, chuột cống, thỏ và khỉ không ghi nhận độc tính của thuốc lên thai. Có thể dùng thuốc trong thời kỳ mang thai, nhưng cần thận trọng cân nhắc giữa lợi ích và nguy cơ.","page":433,"printed_page":439,"column":1,"bbox":[299.38,250.52,553.72,313.42],"source":{"line_count":5}},{"id":"b0042","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":433,"printed_page":439,"column":1,"bbox":[299.38,319.0,377.5,332.15],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[299.38,319.0,377.5,332.15],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0043","type":"paragraph","text":"Chưa rõ thuốc có được bài tiết vào sữa mẹ không. Tuy nhiên, lượng thuốc được hấp thu qua da là rất nhỏ, nên nếu được bài tiết vào sữa thì lượng thuốc trong sữa cũng rất thấp. Có thể dùng thuốc trong thời kỳ cho con bú, nhưng cần thận trọng cân nhắc giữa lợi ích và nguy cơ.","page":433,"printed_page":439,"column":1,"bbox":[299.38,331.68,553.72,394.57],"source":{"line_count":5}},{"id":"b0044","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":433,"printed_page":439,"column":1,"bbox":[299.38,400.16,445.33,413.31],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[299.38,400.16,445.33,413.31],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0045","type":"subheading","level":3,"text":"Thường gặp","page":433,"printed_page":439,"column":1,"bbox":[299.38,412.99,345.79,425.63],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp","bbox":[299.38,412.99,345.79,425.63],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0046","type":"paragraph","text":"Ban đỏ (dầu gội đầu, dung dịch), cảm giác nóng rát (gel, dung dịch, dầu gội đầu), viêm da tiếp xúc (nhũ dịch dùng ngoài, kem, gel), ngứa (dầu gội đầu, nhũ dịch dùng ngoài, kem, gel).","page":433,"printed_page":439,"column":1,"bbox":[299.38,425.35,553.72,463.2],"source":{"line_count":3}},{"id":"b0047","type":"paragraph","text":"Ít gặp: Khô da, mụn, phát ban, rụng tóc, đau mắt, phù mặt (gel).","page":433,"printed_page":439,"column":1,"bbox":[299.38,462.93,543.45,475.73],"source":{"line_count":1},"spans":[{"text":"Ít gặp: ","bbox":[299.38,463.1,327.35,475.73],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":"Khô da, mụn, phát ban, rụng tóc, đau mắt, phù mặt (gel).","bbox":[327.35,462.93,543.45,475.73],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0048","type":"paragraph","text":"Hiếm gặp: Mất màu tóc (dầu gội đầu).","page":433,"printed_page":439,"column":1,"bbox":[299.38,475.46,445.55,488.25],"source":{"line_count":1},"spans":[{"text":"Hiếm gặp: ","bbox":[299.38,475.62,342.12,488.25],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":"Mất màu tóc (dầu gội đầu).","bbox":[342.12,475.46,445.55,488.25],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0049","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":433,"printed_page":439,"column":1,"bbox":[299.38,493.83,413.95,506.98],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[299.38,493.83,413.95,506.98],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0050","type":"paragraph","text":"Nếu nghi ngờ bị kích ứng hoặc mẫn cảm với thuốc, cần dừng thuốc.","page":433,"printed_page":439,"column":1,"bbox":[299.38,506.51,551.34,519.31],"source":{"line_count":1},"spans":[{"text":"Nếu nghi ngờ bị kích ứng hoặc mẫn cảm với thuốc, cần dừng thuốc.","bbox":[299.38,506.51,551.34,519.31],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0051","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":433,"printed_page":439,"column":1,"bbox":[299.38,524.88,399.56,538.03],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[299.38,524.88,399.56,538.03],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0052","type":"subheading","level":3,"text":"Cách dùng","page":433,"printed_page":439,"column":1,"bbox":[299.38,537.63,342.41,550.35],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Cách dùng","bbox":[299.38,537.63,342.41,550.35],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0053","type":"paragraph","text":"Dạng dùng của ciclopirox olamin là kem bôi, nhũ dịch dùng ngoài và hỗn dịch; của ciclopirox là gel, dầu gội đầu và dung dịch. Các chế phẩm này chỉ để dùng ngoài, không được uống, không bôi lên mắt và vùng âm đạo.","page":433,"printed_page":439,"column":1,"bbox":[299.38,550.09,553.72,600.46],"source":{"line_count":4}},{"id":"b0054","type":"paragraph","text":"Nhũ dịch dùng ngoài: Lắc mạnh trước khi sử dụng. Ưu tiên dùng trên các vùng da rộng hoặc vùng da ít nhờn.","page":433,"printed_page":439,"column":1,"bbox":[299.38,600.19,553.71,625.51],"source":{"line_count":2}},{"id":"b0055","type":"paragraph","text":"Gel: Rửa sạch vùng da bị nhiễm trùng rồi thoa thuốc và mát xa nhẹ nhàng trên vùng da nhiễm trùng và vùng da xung quanh.","page":433,"printed_page":439,"column":1,"bbox":[299.38,625.24,553.71,650.56],"source":{"line_count":2}},{"id":"b0056","type":"paragraph","text":"Dầu gội đầu: Thoa thuốc lên tóc khi ướt và vùng da đầu bị nhiễm trùng, để trong 3 phút rồi gội sạch.","page":433,"printed_page":439,"column":1,"bbox":[299.38,650.29,553.72,675.61],"source":{"line_count":2}},{"id":"b0057","type":"paragraph","text":"Dung dịch: Bệnh nhân dùng ciclopirox dạng dung dịch để điều trị nấm móng cần cắt sạch móng, loại bỏ các vật liệu làm móng trước khi thoa thuốc lên toàn bộ vùng móng bị nhiễm nấm. Đợi đến khi móng khô và ít nhất 8 giờ sau mới được tắm rửa. Rửa vùng móng đã bôi thuốc bằng cồn và cắt móng sạch mỗi 7 ngày.","page":433,"printed_page":439,"column":1,"bbox":[299.38,675.35,553.72,738.25],"source":{"line_count":5}},{"id":"b0058","type":"subheading","level":3,"text":"Liều lượng","page":433,"printed_page":439,"column":1,"bbox":[299.38,739.28,343.17,752.0],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Liều lượng","bbox":[299.38,739.28,343.17,752.0],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0059","type":"subheading","level":3,"text":"Nấm ngoài da","page":433,"printed_page":439,"column":1,"bbox":[299.38,750.66,353.22,763.29],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Nấm ngoài da","bbox":[299.38,750.66,353.22,763.29],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0060","type":"paragraph","text":"Đối với nấm bàn chân, nấm bẹn, nấm thân, nấm da do Candida albicans, lang ben: Dùng ciclopirox olamin dạng nhũ dịch dùng ngoài, hoặc hỗn dịch, hoặc kem thoa một lượng nhỏ lên vùng da","page":433,"printed_page":439,"column":1,"bbox":[299.38,763.02,553.72,800.87],"source":{"line_count":3}},{"id":"b0061","type":"paragraph","text":"nhiễm trùng và vùng da xung quanh, ngày 2 lần, vào buổi sáng và tối. Các triệu chứng như ngứa thường đáp ứng trong vòng 1 tuần, nhưng để diệt sạch nấm cần ít nhất 2 tuần điều trị liên tục. Không cần băng kín vùng da nhiễm trùng. Nếu không có cải thiện sau 4 tuần, cần khám lại.","page":434,"printed_page":440,"column":0,"bbox":[43.43,63.32,297.77,126.22],"source":{"line_count":5}},{"id":"b0062","type":"paragraph","text":"Đối với nấm kẽ ngón chân và nấm thân: Rửa sạch vùng da bị tổn thương rồi thoa gel ciclopirox lên vùng da bị tổn thương và vùng da xung quanh, ngày 2 lần, vào buổi sáng và tối, trong 4 tuần.","page":434,"printed_page":440,"column":0,"bbox":[43.43,125.95,297.77,163.8],"source":{"line_count":3}},{"id":"b0063","type":"subheading","level":3,"text":"Nấm móng chân, móng tay","page":434,"printed_page":440,"column":0,"bbox":[43.43,163.69,145.55,176.32],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Nấm móng chân, móng tay","bbox":[43.43,163.69,145.55,176.32],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0064","type":"paragraph","text":"Thoa dung dịch ciclopirox lên vùng móng bị tổn thương, nên dùng bàn chải để dễ đưa thuốc, ngày 1 lần, vào buổi tối trước khi đi ngủ hoặc 8 giờ trước khi tắm rửa. Rửa sạch vùng móng đã bôi thuốc bằng cồn sau mỗi 7 ngày.","page":434,"printed_page":440,"column":0,"bbox":[43.43,176.05,297.76,226.42],"source":{"line_count":4}},{"id":"b0065","type":"subheading","level":3,"text":"Viêm da dầu ở đầu","page":434,"printed_page":440,"column":0,"bbox":[43.43,226.31,114.82,238.95],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Viêm da dầu ở đầu","bbox":[43.43,226.31,114.82,238.95],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0066","type":"paragraph","text":"Gel: Thoa gel ciclopirox lên vùng da đầu bị tổn thương, ngày 2 lần, vào buổi sáng và tối, trong 4 tuần.","page":434,"printed_page":440,"column":0,"bbox":[43.43,238.68,297.76,264.0],"source":{"line_count":2}},{"id":"b0067","type":"paragraph","text":"Dầu gội đầu: Dùng 5 ml dầu gội ciclopirox 1% (có thể dùng 10 ml nếu tóc dài) xoa lên vùng da bệnh, để khoảng 3 phút rồi gội sạch.","page":434,"printed_page":440,"column":0,"bbox":[43.43,263.73,297.76,289.05],"source":{"line_count":2}},{"id":"b0068","type":"paragraph","text":"Gội đầu 2 lần/tuần, các lần cách nhau ít nhất 3 ngày, trong 4 tuần.","page":434,"printed_page":440,"column":0,"bbox":[43.43,288.78,297.76,301.57],"source":{"line_count":1},"spans":[{"text":"Gội đầu 2 lần/tuần, các lần cách nhau ít nhất 3 ngày, trong 4 tuần. ","bbox":[43.43,288.78,297.76,301.57],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0069","type":"paragraph","text":"Trường hợp không có cải thiện sau 4 tuần điều trị, cần khám lại.","page":434,"printed_page":440,"column":0,"bbox":[43.43,301.3,287.06,314.1],"source":{"line_count":1},"spans":[{"text":"Trường hợp không có cải thiện sau 4 tuần điều trị, cần khám lại.","bbox":[43.43,301.3,287.06,314.1],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0070","type":"paragraph","text":"Cập nhật lần cuối: 2019.","page":434,"printed_page":440,"column":0,"bbox":[43.43,319.99,138.69,332.63],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2019.","bbox":[43.43,319.99,138.69,332.63],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"ciclopirox-va-ciclopirox-olamin","title":"CICLOPIROX VÀ CICLOPIROX OLAMIN","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007","b0008","b0009","b0010","b0011","b0012"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0013","blocks":["b0014","b0015","b0016"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0017","blocks":["b0018","b0019","b0020","b0021","b0022","b0023","b0024","b0025","b0026"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0027","blocks":["b0028","b0029","b0030","b0031","b0032"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0033","blocks":["b0034","b0035","b0036","b0037","b0038"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0039","blocks":["b0040","b0041"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0042","blocks":["b0043"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0044","blocks":["b0045","b0046","b0047","b0048"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0049","blocks":["b0050"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0051","blocks":["b0052","b0053","b0054","b0055","b0056","b0057","b0058","b0059","b0060","b0061","b0062","b0063","b0064","b0065","b0066","b0067","b0068","b0069","b0070"]}],"quality":{"block_count":70,"heading_count":11,"subheading_count":8,"paragraph_count":50,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":3}}