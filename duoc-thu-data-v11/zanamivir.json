{"schema_version":"11.0.0-alpha.1","id":"zanamivir","title":"Zanamivir","aliases":["zanamivir"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":1711,"end":1712},"printed_pages":{"start":1717,"end":1718},"extraction":{"start_title_pdf_page":1711,"start_column":"right","start_y":264.61004638671875,"next_title_pdf_page":1712,"next_column":"right","next_y":243.55419921875,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"ZANAMIVIR","page":1711,"printed_page":1717,"column":1,"bbox":[403.36,264.61,463.35,278.45],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"ZANAMIVIR","bbox":[403.36,264.61,463.35,278.45],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Zanamivir.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,288.16,429.04,301.31],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[307.38,288.16,387.61,301.31],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Zanamivir.","bbox":[387.62,288.32,429.04,301.11],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: J05AH01.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,299.86,386.64,313.01],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[307.38,299.86,347.84,313.01],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"J05AH01.","bbox":[347.84,300.01,386.64,312.81],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc kháng virus nhóm ức chế neuraminidase.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,311.55,539.18,324.7],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[307.38,311.55,356.47,324.7],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc kháng virus nhóm ức chế neuraminidase.","bbox":[356.47,311.7,539.18,324.5],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,326.75,412.3,339.9],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[307.38,326.75,412.3,339.9],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Thuốc dạng bột hít: 5 mg/liều.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,339.09,422.97,351.89],"source":{"line_count":1},"spans":[{"text":"Thuốc dạng bột hít: 5 mg/liều.","bbox":[307.38,339.09,422.97,351.89],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"heading","level":2,"text":"Dược lực học","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,354.14,360.98,367.29],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[307.38,354.14,360.98,367.29],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Zanamivir là dẫn chất của acid sialic, có tác dụng ức chế cạnh tranh, chọn lọc enzym neuraminidase, là enzym cần thiết cho sự nhân lên của virus cúm. Zanamivir có hoạt tính với đa số các chủng cúm A và cúm B, bao gồm cả những chủng đã kháng amantadin, rimantadin và oseltamivir.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,365.48,561.72,423.05],"source":{"line_count":5}},{"id":"b0009","type":"heading","level":2,"text":"Dược động học","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,425.3,368.49,438.44],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[307.38,425.3,368.49,438.44],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Hấp thu: Khi hít qua đường miệng, khoảng 4 - 17% lượng thuốc được hấp thu vào tuần hoàn chung. Sinh khả dụng tuyệt đối trung bình đạt 2%, nồng độ trong máu đạt đỉnh trong vòng 1 - 2 giờ sau khi hít qua đường miệng.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,437.65,561.72,487.03],"source":{"line_count":4}},{"id":"b0011","type":"paragraph","text":"Phân bố: Sau khi hít, zanamivir phân bố tới lớp biểu mô của đường hô hấp. Lượng thuốc tồn tại trong hệ hô hấp phụ thuộc vào đặc tính của người bệnh, bao gồm lưu lượng khí hít vào. Zanamivir có thể còn tồn trong đờm và dịch rửa mũi ít nhất 12 giờ sau khi dùng thuốc. Tỷ lệ thuốc liên kết với protein huyết tương thấp hơn 10%.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,486.42,561.75,547.99],"source":{"line_count":5}},{"id":"b0012","type":"paragraph","text":"Zanamivir qua được nhau thai và có phân bố trong sữa của động vật.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,547.39,561.74,560.19],"source":{"line_count":1},"spans":[{"text":"Zanamivir qua được nhau thai và có phân bố trong sữa của động vật. ","bbox":[307.38,547.39,561.74,560.19],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0013","type":"paragraph","text":"Hiện chưa rõ liệu thuốc có phân bố vào trong sữa của người không.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,559.59,560.03,572.38],"source":{"line_count":1},"spans":[{"text":"Hiện chưa rõ liệu thuốc có phân bố vào trong sữa của người không. ","bbox":[307.38,559.59,560.03,572.38],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0014","type":"paragraph","text":"Chuyển hóa: Zanamivir không chuyển hóa mà thải trừ trực tiếp qua nước tiểu ở dạng không đổi.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,571.78,561.72,596.77],"source":{"line_count":2}},{"id":"b0015","type":"paragraph","text":"Thải trừ: Phần thuốc không hấp thu hết được thải trừ qua phân.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,596.16,561.71,608.96],"source":{"line_count":1},"spans":[{"text":"Thải trừ:","bbox":[307.38,596.32,342.79,608.96],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":" Phần thuốc không hấp thu hết được thải trừ qua phân. ","bbox":[342.79,596.16,561.71,608.96],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Nửa đời thải trừ của zanamivir qua đường hít là 2,5 - 5,1 giờ, kéo dài hơn ở người bệnh suy giảm chức năng thận: 4,7 giờ ở người bệnh suy thận nhẹ đến vừa và 18,5 giờ ở người suy thận nặng.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,608.36,561.72,645.54],"source":{"line_count":3}},{"id":"b0017","type":"heading","level":2,"text":"Chỉ định","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,647.79,343.03,660.93],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[307.38,647.79,343.03,660.93],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Điều trị các trường hợp nhiễm virus cúm A hoặc cúm B ở người lớn và trẻ em trên 7 tuổi có triệu chứng khởi phát chưa quá 2 ngày, chưa có biến chứng.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,660.14,561.71,697.32],"source":{"line_count":3}},{"id":"b0019","type":"paragraph","text":"Dự phòng nhiễm virus cúm A và cúm B ở người lớn và trẻ em trên 5 tuổi.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,696.72,561.72,721.71],"source":{"line_count":2}},{"id":"b0020","type":"heading","level":2,"text":"Chống chỉ định","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,723.95,369.68,737.1],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[307.38,723.95,369.68,737.1],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0021","type":"paragraph","text":"Quá mẫn với zanamivir.","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,736.3,398.94,749.09],"source":{"line_count":1},"spans":[{"text":"Quá mẫn với zanamivir.","bbox":[307.38,736.3,398.94,749.09],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0022","type":"note","level":2,"text":"Thận trọng","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,751.34,353.57,764.49],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[307.38,751.34,353.57,764.49],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0023","type":"paragraph","text":"Việc dự phòng cúm được xác định trên cơ sở từng trường hợp, tùy thuộc vào hoàn cảnh, khuyến cáo và dân số cần bảo vệ, nên được xem xét trên cơ sở những khuyến cáo chính thức, cần cân nhắc dựa","page":1711,"printed_page":1717,"column":1,"bbox":[307.38,763.69,561.73,800.87],"source":{"line_count":3}},{"id":"b0024","type":"paragraph","text":"trên những thông tin về đặc tính của các chủng virus cúm lưu hành, độ nhạy cảm của thuốc cúm cho mỗi mùa và tác động của bệnh này tại các khu vực địa lý, quần thể bệnh khác nhau.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,63.32,289.76,100.18],"source":{"line_count":3}},{"id":"b0025","type":"paragraph","text":"Thận trọng khi sử dụng thuốc cho các bệnh nhân mắc bệnh hô hấp mạn tính do có thể tăng nguy cơ co thắt phế quản. Khi thực sự cần sử dụng zanamivir cho bệnh nhân có tiền sử hen hoặc có bệnh lý tắc nghẽn đường thở mạn tính, cần có sẵn thuốc giãn phế quản tác dụng nhanh bên cạnh. Nếu bệnh nhân đang điều trị duy trì bằng thuốc giãn phế quản đường hít, cần dùng thuốc giãn phế quản trước khi sử dụng zanamivir.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,99.41,289.77,184.39],"source":{"line_count":7}},{"id":"b0026","type":"paragraph","text":"Cần theo dõi người bệnh về các dấu hiệu hành vi bất thường trong suốt quá trình điều trị.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,183.62,289.77,208.44],"source":{"line_count":2}},{"id":"b0027","type":"paragraph","text":"Zanamivir không thay thế được cho việc tiêm chủng cúm mùa hàng năm. Mặc dù các thuốc kháng virus sử dụng điều trị hay phòng ngừa cúm, bao gồm cả zanamivir có thể dùng đồng thời với các vắc xin cúm bất hoạt, các thuốc kháng virus này có thể ức chế virus có trong vắc xin cúm sống dùng đường mũi.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,207.68,289.77,268.59],"source":{"line_count":5}},{"id":"b0028","type":"paragraph","text":"Khi dùng thuốc cho trẻ em, cần có sự giám sát của người lớn để đảm bảo việc sử dụng dụng cụ hít đúng cách. Độ an toàn và hiệu quả của thuốc ở người cao tuổi tương tự như ở những người trẻ.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,267.83,289.77,304.68],"source":{"line_count":3}},{"id":"b0029","type":"paragraph","text":"Chưa có dữ liệu về độ an toàn của thuốc ở người bệnh suy gan, suy thận. Mặc dù thuốc rất ít hấp thu, không loại trừ khả năng thuốc bị tích lũy khi dùng cho người bệnh suy thận.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,303.92,289.77,340.77],"source":{"line_count":3}},{"id":"b0030","type":"heading","level":2,"text":"Thời kỳ mang thai","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,342.85,110.64,356.0],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[35.43,342.85,110.64,356.0],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0031","type":"paragraph","text":"Có thể sử dụng zanamivir cho phụ nữ đang mang thai. Zanamivir có thể được ưu tiên hơn so với oseltamivir do thuốc ít hấp thu vào máu, tuy nhiên cần thận trọng các biến chứng trên đường hô hấp, đặc biệt ở những phụ nữ có mắc kèm bệnh hô hấp mạn tính như hen, bệnh tắc nghẽn đường thở mạn tính.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,355.03,289.77,415.95],"source":{"line_count":5}},{"id":"b0032","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,418.03,113.55,431.18],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[35.43,418.03,113.55,431.18],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0033","type":"paragraph","text":"Zanamivir có phân bố vào sữa động vật. Hiện chưa rõ thuốc có phân bố trong sữa người hay không. Zanamivir có thể sử dụng thận trọng ở phụ nữ đang cho con bú.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,430.21,289.76,467.07],"source":{"line_count":3}},{"id":"b0034","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,469.15,181.38,482.3],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[35.43,469.15,181.38,482.3],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0035","type":"subheading","level":3,"text":"Thường gặp","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,481.49,81.84,494.13],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp","bbox":[35.43,481.49,81.84,494.13],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0036","type":"paragraph","text":"Các phản ứng xảy ra với tần suất 1 - 3% bao gồm: tiêu chảy, nôn và buồn nôn, triệu chứng mũi, viêm phế quản, viêm xoang, ho, nhiễm khuẩn tai mũi họng, đau đầu và chóng mặt.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,493.36,289.77,530.22],"source":{"line_count":3}},{"id":"b0037","type":"subheading","level":3,"text":"Ít gặp","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,529.61,57.86,542.25],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Ít gặp","bbox":[35.43,529.61,57.86,542.25],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0038","type":"paragraph","text":"Co thắt phế quản, khó thở, phù hầu họng và ban da nghiêm trọng, mày đay.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,541.48,289.76,566.31],"source":{"line_count":2}},{"id":"b0039","type":"subheading","level":3,"text":"Hiếm gặp","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,565.7,72.64,578.34],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp","bbox":[35.43,565.7,72.64,578.34],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0040","type":"paragraph","text":"ADR trên tâm thần kinh như mê sảng hay có hành vi bất thường.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,577.57,281.9,590.36],"source":{"line_count":1},"spans":[{"text":"ADR trên tâm thần kinh như mê sảng hay có hành vi bất thường.","bbox":[35.43,577.57,281.9,590.36],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0041","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,592.45,149.57,605.59],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[35.43,592.45,149.57,605.59],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0042","type":"paragraph","text":"Nếu bệnh nhân có biểu hiện co thắt phế quản hoặc chức năng hô hấp xấu đi khi sử dụng zanamivir, nên ngừng thuốc ngay lập tức, theo dõi chặt bệnh nhân và nếu cần phải nhập viện.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,604.63,289.76,641.48],"source":{"line_count":3}},{"id":"b0043","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,643.56,135.61,656.71],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[35.43,643.56,135.61,656.71],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0044","type":"subheading","level":3,"text":"Cách dùng","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,655.82,78.46,668.54],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Cách dùng","bbox":[35.43,655.82,78.46,668.54],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0045","type":"paragraph","text":"Zanamivir dạng bột hít qua đường miệng chỉ được sử dụng bằng thiết bị của nhà sản xuất cung cấp. Tuyệt đối không tự ý thay đổi dạng dùng của thuốc, không hòa bột với bất cứ dịch lỏng nào để dùng qua đường khí dung hoặc thở máy. Việc sử dụng sai cách có thể dẫn tới tử vong.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,667.78,289.77,728.69],"source":{"line_count":5}},{"id":"b0046","type":"subheading","level":3,"text":"Liều lượng","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,728.0,79.22,740.72],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Liều lượng","bbox":[35.43,728.0,79.22,740.72],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0047","type":"paragraph","text":"Điều trị cúm ở người lớn và trẻ em trên 7 tuổi: 10 mg/lần, 2 lần/ ngày trong 5 ngày, bắt đầu điều trị càng sớm càng tốt, không quá 48 giờ sau khi triệu chứng khởi phát. Ngày điều trị đầu tiên, 2 liều zanamivir cần cách nhau tối thiểu 2 giờ, các ngày tiếp theo, dùng đều đặn 2 liều cách nhau khoảng 12 giờ, vào buổi sáng và tối.","page":1712,"printed_page":1718,"column":0,"bbox":[35.43,739.95,289.77,800.87],"source":{"line_count":5}},{"id":"b0048","type":"paragraph","text":"Dự phòng cúm ở người lớn và trẻ em trên 5 tuổi: 10 mg/lần/ngày trong 10 ngày, có thể kéo dài tới 28 ngày nếu cần. Bắt đầu điều trị trong vòng 36 giờ sau khi tiếp xúc với nguồn bệnh hoặc trong vòng 5 ngày kể từ khi dịch cúm bùng phát.","page":1712,"printed_page":1718,"column":1,"bbox":[299.39,63.32,553.72,112.12],"source":{"line_count":4}},{"id":"b0049","type":"heading","level":2,"text":"Tương tác thuốc","page":1712,"printed_page":1718,"column":1,"bbox":[299.39,114.17,366.29,127.32],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[299.39,114.17,366.29,127.32],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0050","type":"paragraph","text":"Zanamivir không chuyển hóa qua gan, cũng không có ảnh hưởng tới hoạt tính của CYP450 nên không có ghi nhận tương tác với các thuốc khác.","page":1712,"printed_page":1718,"column":1,"bbox":[299.39,126.32,553.72,163.12],"source":{"line_count":3}},{"id":"b0051","type":"heading","level":2,"text":"Quá liều và xử trí","page":1712,"printed_page":1718,"column":1,"bbox":[299.39,165.17,371.06,178.32],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[299.39,165.17,371.06,178.32],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0052","type":"paragraph","text":"Quá liều zanamivir khó xảy ra do thuốc được dùng dạng đơn liều hít qua đường miệng và có sinh khả dụng thấp.","page":1712,"printed_page":1718,"column":1,"bbox":[299.39,177.32,553.72,202.12],"source":{"line_count":2}},{"id":"b0053","type":"paragraph","text":"Cập nhật lần cuối: 2018.","page":1712,"printed_page":1718,"column":1,"bbox":[299.39,206.88,404.15,219.52],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2018.    ","bbox":[299.39,206.88,404.15,219.52],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"zanamivir","title":"ZANAMIVIR","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0007","blocks":["b0008"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0009","blocks":["b0010","b0011","b0012","b0013","b0014","b0015","b0016"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0017","blocks":["b0018","b0019"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0020","blocks":["b0021","b0022","b0023","b0024","b0025","b0026","b0027","b0028","b0029"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0030","blocks":["b0031"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0032","blocks":["b0033"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0034","blocks":["b0035","b0036","b0037","b0038","b0039","b0040"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0041","blocks":["b0042"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0043","blocks":["b0044","b0045","b0046","b0047","b0048"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0049","blocks":["b0050"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0051","blocks":["b0052","b0053"]}],"quality":{"block_count":53,"heading_count":13,"subheading_count":5,"paragraph_count":34,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}