count":1},"spans":[{"text":"Mã ATC: ","bbox":[35.43,650.42,75.89,663.57],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"P01AB07.","bbox":[75.89,650.57,115.74,663.37],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc chống amip và các nguyên sinh động vật khác.","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,661.92,287.39,675.07],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[35.43,661.92,84.4,675.07],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc chống amip và các nguyên sinh động vật khác.","bbox":[84.28,662.07,287.39,674.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,676.92,142.73,690.07],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng ","bbox":[35.43,676.92,142.73,690.07],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Viên nén bao phim: 500 mg.","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,689.07,143.58,701.87],"source":{"line_count":1},"spans":[{"text":"Viên nén bao phim: 500 mg.","bbox":[35.43,689.07,143.58,701.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Thuốc cốm: 2 g.","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,701.07,97.71,713.87],"source":{"line_count":1},"spans":[{"text":"Thuốc cốm: 2 g.","bbox":[35.43,701.07,97.71,713.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"heading","level":2,"text":"Dược lực học","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,715.92,89.03,729.07],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[35.43,715.92,89.03,729.07],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0009","type":"paragraph","text":"Secnidazol là một dẫn xuất của 5-nitroimidazol. Có hoạt tính diệt ký sinh trùng: Entamoeba histolytica, Giardia intestinalis, Trichomonas vaginalis và hoạt tính diệt vi khuẩn kỵ khí:","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,728.07,289.77,764.87],"source":{"line_count":3}},{"id":"b0010","type":"paragraph","text":"Bacteroides, Fusobacterium, Clostridium, Peptostreptococcus, Veillonella… Thuốc đi vào các vi sinh vật do khuếch tán và bị khử trong tế bào, cuối cùng gây tổn hại cho DNA, dẫn đến ngăn cản","page":1466,"printed_page":1472,"column":0,"bbox":[35.43,764.23,289.77,800.87],"source":{"line_count":3}},{"id":"b0011","type":"paragraph","text":"tổng hợp protein và gây chết tế bào ở các vi sinh vật nhạy cảm.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,63.32,539.24,76.12],"source":{"line_count":1},"spans":[{"text":"tổng hợp protein và gây chết tế bào ở các vi sinh vật nhạy cảm.","bbox":[299.39,63.32,539.24,76.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0012","type":"heading","level":2,"text":"Dược động học","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,78.29,360.49,91.44],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[299.39,78.29,360.49,91.44],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0013","type":"paragraph","text":"Sau khi uống một liều duy nhất 2 g secnidazol (dưới dạng viên nén 500 mg), nồng độ trong huyết thanh tối đa đạt ở 3 giờ. Nửa đời huyết tương khoảng 25 giờ. Bài xuất chủ yếu qua nước tiểu (khoảng 50% liều uống) trong khoảng 120 giờ. Secnidazol đi qua nhau thai và vào sữa mẹ.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,90.56,553.72,151.83],"source":{"line_count":5}},{"id":"b0014","type":"heading","level":2,"text":"Chỉ định","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,154.0,335.03,167.15],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[299.39,154.0,335.03,167.15],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0015","type":"paragraph","text":"Bệnh amip ở ruột và ở gan.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,166.27,403.11,179.07],"source":{"line_count":1},"spans":[{"text":"Bệnh amip ở ruột và ở gan.","bbox":[299.39,166.27,403.11,179.07],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Bệnh do Giardia.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,178.39,365.8,191.18],"source":{"line_count":1},"spans":[{"text":"Bệnh do ","bbox":[299.39,178.39,333.69,191.18],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"Giardia.","bbox":[333.69,178.55,365.8,191.18],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0017","type":"paragraph","text":"Viêm âm đạo và niệu đạo do Trichomonas vaginalis.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,190.51,499.61,203.3],"source":{"line_count":1},"spans":[{"text":"Viêm âm đạo và niệu đạo do ","bbox":[299.39,190.51,410.42,203.3],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"Trichomonas vaginalis","bbox":[410.41,190.67,497.24,203.3],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":".","bbox":[497.23,190.51,499.61,203.3],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Viêm âm đạo không đặc trưng (nhiễm khuẩn âm đạo).","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,202.62,505.01,215.42],"source":{"line_count":1},"spans":[{"text":"Viêm âm đạo không đặc trưng (nhiễm khuẩn âm đạo).","bbox":[299.39,202.62,505.01,215.42],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0019","type":"heading","level":2,"text":"Chống chỉ định","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,217.59,361.69,230.74],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[299.39,217.59,361.69,230.74],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0020","type":"paragraph","text":"Quá mẫn cảm đối với các dẫn xuất của imidazol.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,229.86,484.87,242.66],"source":{"line_count":1},"spans":[{"text":"Quá mẫn cảm đối với các dẫn xuất của imidazol.","bbox":[299.39,229.86,484.87,242.66],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0021","type":"note","level":2,"text":"Thận trọng","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,244.83,345.57,257.98],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[299.39,244.83,345.57,257.98],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0022","type":"paragraph","text":"Tránh uống rượu trong thời gian điều trị với secnidazol.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,257.1,511.37,269.89],"source":{"line_count":1},"spans":[{"text":"Tránh uống rượu trong thời gian điều trị với secnidazol.","bbox":[299.39,257.1,511.37,269.89],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0023","type":"paragraph","text":"Tránh dùng secnidazol ở người có tiền sử rối loạn tạo máu.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,269.22,523.62,282.01],"source":{"line_count":1},"spans":[{"text":"Tránh dùng secnidazol ở người có tiền sử rối loạn tạo máu.","bbox":[299.39,269.22,523.62,282.01],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0024","type":"paragraph","text":"Tác dụng trên khả năng lái xe và vận hành máy móc: Các trường hợp chóng mặt đã được báo cáo sau khi sử dụng các dẫn xuất của imidazol nhưng hiếm gặp.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,281.34,553.72,318.37],"source":{"line_count":3}},{"id":"b0025","type":"paragraph","text":"Không dùng cho người có tiền sử rối loạn thể tạng máu.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,317.69,512.08,330.49],"source":{"line_count":1},"spans":[{"text":"Không dùng cho người có tiền sử rối loạn thể tạng máu.","bbox":[299.39,317.69,512.08,330.49],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0026","type":"heading","level":2,"text":"Thời kỳ mang thai","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,332.66,374.6,345.8],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[299.39,332.66,374.6,345.8],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0027","type":"paragraph","text":"Hiện nay trên lâm sàng, chưa có những nghiên cứu đầy đủ đối với phụ nữ mang thai dùng secnidazol nên không đánh giá được độc tính của secnidazol đối với thai. Do đó để thận trọng, không nên sử dụng secnidazol ở phụ nữ trong thời kỳ mang thai.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,344.93,553.72,394.08],"source":{"line_count":4}},{"id":"b0028","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,396.25,377.5,409.4],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[299.39,396.25,377.5,409.4],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0029","type":"paragraph","text":"Secnidazol và các dẫn xuất khác của imidazol đã vào trong sữa mẹ và đã có các trường hợp bệnh nấm Candida miệng - hậu môn và tiêu chảy được báo cáo ở trẻ em bú sữa người mẹ được điều trị với các dẫn xuất khác của imidazol. Do đó, nên ngừng cho con bú trong thời gian điều trị.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,408.52,553.72,469.79],"source":{"line_count":5}},{"id":"b0030","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,471.96,445.33,485.11],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[299.39,471.96,445.33,485.11],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0031","type":"paragraph","text":"Các ADR đã quan sát thấy đối với các dẫn xuất của imidazol bao gồm:","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,484.23,553.72,509.15],"source":{"line_count":2}},{"id":"b0032","type":"subheading","level":3,"text":"Thường gặp","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,508.63,348.17,521.26],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp ","bbox":[299.39,508.63,348.17,521.26],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0033","type":"paragraph","text":"Tiêu hóa: rối loạn tiêu hóa với buồn nôn, đau vùng thượng vị, thay đổi vị giác (miệng có vị kim loại), viêm lưỡi, viêm miệng.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,520.59,553.72,545.5],"source":{"line_count":2}},{"id":"b0034","type":"paragraph","text":"Da: mày đay.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,544.82,349.68,557.62],"source":{"line_count":1},"spans":[{"text":"Da: mày đay.","bbox":[299.39,544.82,349.68,557.62],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0035","type":"paragraph","text":"Huyết học: giảm bạch cầu mức độ vừa, hồi phục khi ngừng thuốc.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,556.94,550.72,569.74],"source":{"line_count":1},"spans":[{"text":"Huyết học: giảm bạch cầu mức độ vừa, hồi phục khi ngừng thuốc.","bbox":[299.39,556.94,550.72,569.74],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0036","type":"subheading","level":3,"text":"Hiếm gặp","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,569.22,336.59,581.86],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp","bbox":[299.39,569.22,336.59,581.86],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0037","type":"paragraph","text":"TKTW: chóng mặt, hiện tượng mất phối hợp, mất điều hòa, dị cảm, viêm nhiều dây thần kinh cảm giác - vận động.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,581.18,553.72,606.09],"source":{"line_count":2}},{"id":"b0038","type":"paragraph","text":"Tiêu hóa: rối loạn tiêu hóa, buồn nôn, nôn, đau vùng thượng vị.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,605.41,540.38,618.21],"source":{"line_count":1},"spans":[{"text":"Tiêu hóa: rối loạn tiêu hóa, buồn nôn, nôn, đau vùng thượng vị.","bbox":[299.39,605.41,540.38,618.21],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Phản ứng quá mẫn cảm: sốt, ban đỏ, mày đay, phù mạch.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,617.53,515.78,630.33],"source":{"line_count":1},"spans":[{"text":"Phản ứng quá mẫn cảm: sốt, ban đỏ, mày đay, phù mạch.","bbox":[299.39,617.53,515.78,630.33],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0040","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,632.5,399.56,645.65],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[299.39,632.5,399.56,645.65],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0041","type":"paragraph","text":"Viêm niệu đạo và viêm âm đạo do Trichomonas vaginalis và nhiễm khuẩn âm đạo:","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,645.93,553.71,671.68],"source":{"line_count":2}},{"id":"b0042","type":"paragraph","text":"Người lớn: 2 g, uống một liều duy nhất vào đầu bữa ăn. Điều trị đồng thời người có quan hệ tình dục với cùng liều như trên.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,672.01,553.72,697.92],"source":{"line_count":2}},{"id":"b0043","type":"subheading","level":3,"text":"Bệnh lỵ amip đường ruột:","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,698.41,397.77,711.04],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Bệnh lỵ amip đường ruột:","bbox":[299.39,698.41,397.77,711.04],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0044","type":"paragraph","text":"Bệnh lỵ amip cấp tính có triệu chứng (dạng histolytica):","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,711.36,512.16,724.16],"source":{"line_count":1},"spans":[{"text":"Bệnh lỵ amip cấp tính có triệu chứng (dạng ","bbox":[299.39,711.36,466.8,724.16],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"histolytica","bbox":[466.78,711.52,506.37,724.16],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":"):","bbox":[506.36,711.36,512.16,724.16],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0045","type":"paragraph","text":"Người lớn: 2 g, uống một liều duy nhất vào đầu bữa ăn.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,724.48,510.78,737.28],"source":{"line_count":1},"spans":[{"text":"Người lớn: 2 g, uống một liều duy nhất vào đầu bữa ăn.","bbox":[299.39,724.48,510.78,737.28],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0046","type":"paragraph","text":"Trẻ em: 30 mg/kg/ngày uống làm 1 lần, chỉ dùng trong 1 ngày.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,737.6,537.47,750.4],"source":{"line_count":1},"spans":[{"text":"Trẻ em: 30 mg/kg/ngày uống làm 1 lần, chỉ dùng trong 1 ngày.","bbox":[299.39,737.6,537.47,750.4],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0047","type":"paragraph","text":"Bệnh lỵ amip không triệu chứng (các dạng minuta và bào nang):","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,750.72,553.72,763.51],"source":{"line_count":1},"spans":[{"text":"Bệnh lỵ amip không triệu chứng (các dạng ","bbox":[299.39,750.72,468.33,763.51],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"minuta","bbox":[468.96,750.88,495.35,763.51],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":" và bào nang): ","bbox":[495.35,750.72,553.72,763.51],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0048","type":"paragraph","text":"Uống cùng liều hàng ngày như trên trong 3 ngày.","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,763.84,485.96,776.63],"source":{"line_count":1},"spans":[{"text":"Uống cùng liều hàng ngày như trên trong 3 ngày.","bbox":[299.39,763.84,485.96,776.63],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0049","type":"subheading","level":3,"text":"Bệnh amip gan:","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,776.12,360.07,788.75],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Bệnh amip gan:","bbox":[299.39,776.12,360.07,788.75],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0050","type":"paragraph","text":"Người lớn: 1,5 g/ngày, uống làm 1 lần hoặc chia uống làm nhiều","page":1466,"printed_page":1472,"column":1,"bbox":[299.39,788.07,553.72,800.87],"source":{"line_count":1},"spans":[{"text":"Người lớn: 1,5 g/ngày, uống làm 1 lần hoặc chia uống làm nhiều ","bbox":[299.39,788.07,553.72,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0051","type":"paragraph","text":"lần vào đầu các bữa ăn, trong 5 ngày.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,63.32,184.61,76.12],"source":{"line_count":1},"spans":[{"text":"lần vào đầu các bữa ăn, trong 5 ngày.","bbox":[43.43,63.32,184.61,76.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0052","type":"paragraph","text":"Trẻ em: 30 mg/kg/ngày, uống làm 1 lần hoặc chia uống làm nhiều lần vào đầu các bữa ăn, trong 5 ngày.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,75.38,297.77,100.24],"source":{"line_count":2}},{"id":"b0053","type":"paragraph","text":"Trong giai đoạn mưng mủ của bệnh amip gan, cần thực hiện việc điều trị với secnidazol kết hợp với dẫn lưu mủ.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,99.51,297.77,124.36],"source":{"line_count":2}},{"id":"b0054","type":"subheading","level":3,"text":"Bệnh do Giardia:","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,123.79,110.1,136.43],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Bệnh do Giardia:","bbox":[43.43,123.79,110.1,136.43],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0055","type":"paragraph","text":"Trẻ em: 30 mg/kg/ngày, uống làm 1 lần duy nhất, chỉ dùng trong 1 ngày.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,135.69,297.77,160.55],"source":{"line_count":2}},{"id":"b0056","type":"heading","level":2,"text":"Tương tác thuốc","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,159.5,110.34,172.64],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[43.43,159.5,110.34,172.64],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0057","type":"subheading","level":3,"text":"Không nên phối hợp với:","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,171.87,138.55,184.51],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Không nên phối hợp với:","bbox":[43.43,171.87,138.55,184.51],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0058","type":"paragraph","text":"Disulfiram: gây cơn hoang tưởng, lú lẫn.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,183.77,200.34,196.57],"source":{"line_count":1},"spans":[{"text":"Disulfiram: gây cơn hoang tưởng, lú lẫn. ","bbox":[43.43,183.77,200.34,196.57],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0059","type":"paragraph","text":"Rượu: gây phản ứng nóng, đỏ bừng, nôn, tim đập nhanh.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,195.83,259.18,208.63],"source":{"line_count":1},"spans":[{"text":"Rượu: gây phản ứng nóng, đỏ bừng, nôn, tim đập nhanh.","bbox":[43.43,195.83,259.18,208.63],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0060","type":"subheading","level":3,"text":"Cần thận trọng khi phối hợp:","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,208.05,154.86,220.69],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Cần thận trọng khi phối hợp:","bbox":[43.43,208.05,154.86,220.69],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0061","type":"paragraph","text":"Với thuốc chống đông máu dạng uống do gây tăng tác dụng của thuốc chống đông máu dạng uống và tăng nguy cơ xuất huyết do giảm sự dị hóa ở gan.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,219.95,297.77,256.87],"source":{"line_count":3}},{"id":"b0062","type":"paragraph","text":"Cần kiểm tra thường xuyên prothrombin và theo dõi INR. Điều chỉnh liều lượng thuốc chống đông máu uống trong thời gian điều trị với secnidazol và trong 8 ngày sau khi ngừng secnidazol.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,256.14,297.77,293.06],"source":{"line_count":3}},{"id":"b0063","type":"paragraph","text":"Cập nhật lần cuối: 2018.","page":1467,"printed_page":1473,"column":0,"bbox":[43.43,297.89,138.7,310.52],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2018.","bbox":[43.43,297.89,138.7,310.52],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"secnidazol","title":"SECNIDAZOL","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0008","blocks":["b0009","b0010","b0011"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0012","blocks":["b0013"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0014","blocks":["b0015","b0016","b0017","b0018"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":