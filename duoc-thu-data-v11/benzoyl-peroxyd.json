{"schema_version":"11.0.0-alpha.1","id":"benzoyl-peroxyd","title":"Benzoyl Peroxyd","aliases":["Benzoyl Peroxyd"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":277,"end":278},"printed_pages":{"start":283,"end":284},"extraction":{"start_title_pdf_page":277,"start_column":"left","start_y":256.13385009765625,"next_title_pdf_page":278,"next_column":"left","next_y":165.20703125,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"BENZOYL PEROXYD","page":277,"printed_page":283,"column":0,"bbox":[111.26,256.13,211.55,269.97],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"BENZOYL PEROXYD","bbox":[111.26,256.13,211.55,269.97],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Benzoyl peroxide.","page":277,"printed_page":283,"column":0,"bbox":[35.43,277.01,192.43,290.15],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[35.43,277.01,115.66,290.15],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Benzoyl peroxide. ","bbox":[115.66,277.16,187.69,289.95],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: D10AE01.","page":277,"printed_page":283,"column":0,"bbox":[35.43,288.85,116.79,302.0],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[35.43,288.85,75.89,302.0],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"D10AE01.","bbox":[75.89,289.0,116.79,301.8],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc dùng ngoài da có tác dụng kháng khuẩn và bong lớp sừng.","page":277,"printed_page":283,"column":0,"bbox":[35.43,302.69,289.76,326.64],"source":{"line_count":2}},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":277,"printed_page":283,"column":0,"bbox":[35.43,328.7,140.35,341.85],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[35.43,328.7,140.35,341.85],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Gel bôi ngoài da: 2,5%, 5%, 10%.","page":277,"printed_page":283,"column":0,"bbox":[35.43,340.86,165.25,353.65],"source":{"line_count":1},"spans":[{"text":"Gel bôi ngoài da: 2,5%, 5%, 10%.","bbox":[35.43,340.86,165.25,353.65],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Nhũ tương dùng ngoài (lotion): 5%, 10%.","page":277,"printed_page":283,"column":0,"bbox":[35.43,352.86,194.43,365.66],"source":{"line_count":1},"spans":[{"text":"Nhũ tương dùng ngoài (lotion): 5%, 10%.","bbox":[35.43,352.86,194.43,365.66],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Kem bôi ngoài da: 2,5%, 4%, 5%, 10%.","page":277,"printed_page":283,"column":0,"bbox":[35.43,364.87,187.41,377.67],"source":{"line_count":1},"spans":[{"text":"Kem bôi ngoài da: 2,5%, 4%, 5%, 10%.","bbox":[35.43,364.87,187.41,377.67],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0009","type":"heading","level":2,"text":"Dược lực học","page":277,"printed_page":283,"column":0,"bbox":[35.43,379.72,91.41,392.87],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học ","bbox":[35.43,379.72,91.41,392.87],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Benzoyl peroxyd có tác dụng làm tróc vảy da, bong lớp sừng và kháng khuẩn. Thuốc có tác dụng kháng khuẩn (có thể do tính oxy hóa), chống lại Staphyloccocus epidermidis và Propionibacterium acnes, nên dùng để điều trị mụn trứng cá.","page":277,"printed_page":283,"column":0,"bbox":[35.43,391.88,289.77,440.7],"source":{"line_count":4}},{"id":"b0011","type":"paragraph","text":"Trường hợp bị mụn trứng cá nặng, cần dùng thêm tại chỗ erythromycin, clindamycin hoặc clarithromycin để ức chế các vi khuẩn kháng thuốc.","page":277,"printed_page":283,"column":0,"bbox":[35.43,439.91,289.76,476.71],"source":{"line_count":3}},{"id":"b0012","type":"paragraph","text":"Benzoyl peroxid còn dùng để điều trị nấm trên da như Tinea pedis.","page":277,"printed_page":283,"column":0,"bbox":[35.43,475.92,289.76,488.72],"source":{"line_count":1},"spans":[{"text":"Benzoyl peroxid còn dùng để điều trị nấm trên da như ","bbox":[35.43,475.92,241.8,488.72],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"Tinea pedis","bbox":[241.63,476.08,285.01,488.72],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":". ","bbox":[285.01,475.92,289.76,488.72],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0013","type":"paragraph","text":"Làm thuốc tẩy trong công nghiệp thực phẩm và chất xúc tác trong công nghiệp chất dẻo.","page":277,"printed_page":283,"column":0,"bbox":[35.43,487.93,289.77,512.73],"source":{"line_count":2}},{"id":"b0014","type":"heading","level":2,"text":"Dược động học","page":277,"printed_page":283,"column":0,"bbox":[35.43,514.79,96.54,527.94],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[35.43,514.79,96.54,527.94],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0015","type":"paragraph","text":"Thuốc được hấp thu qua da khoảng 1,8 microgam/cm2 hoặc 45% liều dùng trong khoảng 24 giờ.","page":277,"printed_page":283,"column":0,"bbox":[35.43,526.95,289.76,551.75],"source":{"line_count":2}},{"id":"b0016","type":"paragraph","text":"Lượng benzoyl peroxyd được hấp thu sẽ chuyển hoàn toàn thành acid benzoic ở da và được thải trừ nhanh chóng vào nước tiểu.","page":277,"printed_page":283,"column":0,"bbox":[35.43,550.96,289.76,575.76],"source":{"line_count":2}},{"id":"b0017","type":"heading","level":2,"text":"Chỉ định","page":277,"printed_page":283,"column":0,"bbox":[35.43,577.82,73.45,590.97],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định ","bbox":[35.43,577.82,73.45,590.97],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Dùng tại chỗ để điều trị mụn trứng cá nhẹ hoặc vừa và là thuốc bổ trợ trong điều trị mụn trứng cá nặng và mụn trứng cá có mủ.","page":277,"printed_page":283,"column":0,"bbox":[35.43,589.98,289.76,614.78],"source":{"line_count":2}},{"id":"b0019","type":"heading","level":2,"text":"Chống chỉ định","page":277,"printed_page":283,"column":0,"bbox":[35.43,616.84,100.11,629.99],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định ","bbox":[35.43,616.84,100.11,629.99],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0020","type":"paragraph","text":"Người dị ứng với benzoyl peroxyd.","page":277,"printed_page":283,"column":0,"bbox":[35.43,629.0,169.77,641.79],"source":{"line_count":1},"spans":[{"text":"Người dị ứng với benzoyl peroxyd.","bbox":[35.43,629.0,169.77,641.79],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0021","type":"note","level":2,"text":"Thận trọng","page":277,"printed_page":283,"column":0,"bbox":[35.43,643.85,81.62,657.0],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[35.43,643.85,81.62,657.0],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0022","type":"paragraph","text":"Thuốc có thể gây sưng và phồng rộp khi bôi trên da. Ngừng thuốc nếu có bất kỳ triệu chứng nào xảy ra.","page":277,"printed_page":283,"column":0,"bbox":[35.43,656.01,289.77,680.81],"source":{"line_count":2}},{"id":"b0023","type":"paragraph","text":"Cảm giác bỏng rát nhẹ có thể thấy trong lần bôi đầu tiên. Một số vết đỏ và bong tróc da sẽ xảy ra trong vòng vài ngày. Trong những tuần đầu điều trị, sự bong tróc đột ngột sẽ xảy ra ở hầu hết bệnh nhân. Điều này không có hại và thường sẽ giảm dần trong vòng một hoặc hai ngày nếu việc điều trị tạm thời bị ngừng lại. Nếu bị kích ứng nghiêm trọng, giảm số lần dùng, tạm thời ngừng hoặc ngừng sử dụng hoàn toàn.","page":277,"printed_page":283,"column":0,"bbox":[35.43,680.02,289.77,764.85],"source":{"line_count":7}},{"id":"b0024","type":"paragraph","text":"Thông báo cho bệnh nhân: Dùng quá mức sẽ không tăng hiệu quả, mà có thể làm tăng nguy cơ kích ứng da.","page":277,"printed_page":283,"column":0,"bbox":[35.43,764.06,289.76,788.86],"source":{"line_count":2}},{"id":"b0025","type":"paragraph","text":"Thận trọng khi dùng đồng thời với các thuốc khác để điều trị mụn","page":277,"printed_page":283,"column":0,"bbox":[35.43,788.07,289.77,800.87],"source":{"line_count":1},"spans":[{"text":"Thận trọng khi dùng đồng thời với các thuốc khác để điều trị mụn ","bbox":[35.43,788.07,289.77,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0026","type":"paragraph","text":"trứng cá vì có thể gây kích ứng tích lũy, đôi khi nghiêm trọng, đặc biệt là sử dụng cùng với các chất lột, chất tẩy da hoặc mài mòn da.","page":277,"printed_page":283,"column":1,"bbox":[299.39,63.32,553.72,88.13],"source":{"line_count":2}},{"id":"b0027","type":"paragraph","text":"Thuốc có thể gây tăng nhạy cảm với ánh sáng mặt trời. Hạn chế hoặc tránh tiếp xúc lâu với ánh sáng mặt trời hoặc tia cực tím. Khi phải tiếp xúc với ánh sáng mặt trời, bệnh nhân nên sử dụng sản phẩm chống nắng và mặc quần áo bảo hộ.","page":277,"printed_page":283,"column":1,"bbox":[299.39,87.35,553.72,136.18],"source":{"line_count":4}},{"id":"b0028","type":"paragraph","text":"Do nguy cơ mẫn cảm, không nên bôi benzoyl peroxyd lên vùng da bị tổn thương.","page":277,"printed_page":283,"column":1,"bbox":[299.39,135.4,553.71,160.21],"source":{"line_count":2}},{"id":"b0029","type":"paragraph","text":"Tránh để thuốc tiếp xúc với mắt, niêm mạc, môi, miệng và những vùng da nhạy cảm như ở cổ. Nếu thuốc vào mắt, phải rửa kỹ với nước.","page":277,"printed_page":283,"column":1,"bbox":[299.39,159.42,553.75,184.23],"source":{"line_count":2}},{"id":"b0030","type":"paragraph","text":"Benzoyl peroxyd có thể oxy hóa làm bạc màu quần áo, vải vóc.","page":277,"printed_page":283,"column":1,"bbox":[299.39,183.45,553.71,196.25],"source":{"line_count":1},"spans":[{"text":"Benzoyl peroxyd có thể oxy hóa làm bạc màu quần áo, vải vóc. ","bbox":[299.39,183.45,553.71,196.25],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0031","type":"paragraph","text":"Người da trắng dễ bị kích ứng hơn.","page":277,"printed_page":283,"column":1,"bbox":[299.39,195.46,435.57,208.26],"source":{"line_count":1},"spans":[{"text":"Người da trắng dễ bị kích ứng hơn. ","bbox":[299.39,195.46,435.57,208.26],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0032","type":"heading","level":2,"text":"Thời kỳ mang thai","page":277,"printed_page":283,"column":1,"bbox":[299.39,210.32,376.97,223.47],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai ","bbox":[299.39,210.32,376.97,223.47],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0033","type":"paragraph","text":"Chưa biết benzoyl peroxyd có gây tổn hại cho thai khi dùng cho người mang thai hoặc có thể ảnh hưởng đến khả năng sinh sản hay không. Tuy nhiên, chỉ nên dùng cho người mang thai khi thật cần thiết. Chưa có tài liệu về tác dụng của benzoyl peroxyd trên sự trưởng thành, phát triển và hoàn thiện các chức năng của thai nhi.","page":277,"printed_page":283,"column":1,"bbox":[299.39,221.99,553.72,280.83],"source":{"line_count":5}},{"id":"b0034","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":277,"printed_page":283,"column":1,"bbox":[299.39,285.4,377.5,298.55],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[299.39,285.4,377.5,298.55],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0035","type":"paragraph","text":"Chưa biết thuốc có bài tiết vào sữa hay không, nên cần hết sức thận trọng khi dùng benzoyl peroxyd cho người mẹ trong thời kỳ cho con bú.","page":277,"printed_page":283,"column":1,"bbox":[299.39,297.06,553.72,332.89],"source":{"line_count":3}},{"id":"b0036","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":277,"printed_page":283,"column":1,"bbox":[299.39,337.45,445.33,350.6],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[299.39,337.45,445.33,350.6],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0037","type":"paragraph","text":"Kích ứng da có thể xảy ra nhất là khi bắt đầu điều trị. Một số người bệnh bị kích ứng đến mức cần phải giảm số lần dùng hoặc tạm thời dừng điều trị. Khô da, tróc da, nổi mẩn và phù nề thoáng qua có thể gặp khi dùng thuốc bôi có benzoyl peroxyd. Mẫn cảm do tiếp xúc cũng có khi xảy ra.","page":277,"printed_page":283,"column":1,"bbox":[299.39,349.61,553.72,410.46],"source":{"line_count":5}},{"id":"b0038","type":"subheading","level":3,"text":"Rất thường gặp và thường gặp","page":277,"printed_page":283,"column":1,"bbox":[299.39,409.84,416.21,422.47],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Rất thường gặp và thường gặp","bbox":[299.39,409.84,416.21,422.47],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0039","type":"paragraph","text":"Khô da, lột da, ban đỏ, cảm giác nóng rát, ngứa da, đau da chỗ bôi, kích ứng da.","page":277,"printed_page":283,"column":1,"bbox":[299.39,421.69,553.72,446.5],"source":{"line_count":2}},{"id":"b0040","type":"subheading","level":3,"text":"Hiếm gặp","page":277,"printed_page":283,"column":1,"bbox":[299.39,445.88,336.59,458.51],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp","bbox":[299.39,445.88,336.59,458.51],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0041","type":"paragraph","text":"Hiện tượng ngứa dữ dội, tấy đỏ, nóng rát, sưng phù.","page":277,"printed_page":283,"column":1,"bbox":[299.39,457.73,499.43,470.53],"source":{"line_count":1},"spans":[{"text":"Hiện tượng ngứa dữ dội, tấy đỏ, nóng rát, sưng phù. ","bbox":[299.39,457.73,499.43,470.53],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0042","type":"paragraph","text":"Phản ứng dị ứng nghiêm trọng và có khả năng đe dọa tính mạng hoặc kích ứng nghiêm trọng đã được báo cáo với các sản phẩm trị mụn không kê đơn.","page":277,"printed_page":283,"column":1,"bbox":[299.39,469.74,553.72,506.56],"source":{"line_count":3}},{"id":"b0043","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":277,"printed_page":283,"column":1,"bbox":[299.39,508.63,416.33,521.78],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR ","bbox":[299.39,508.63,416.33,521.78],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0044","type":"paragraph","text":"Cần xác định xem người bệnh có mẫn cảm với benzoyl peroxyd hay không, bằng cách trước hết bôi thử trên một vùng nhỏ. Nếu có kích ứng hoặc khô da thì nên giảm số lần dùng. Nếu bị ngứa nhiều, đỏ, nóng bừng, sưng phồng hoặc kích ứng thì ngừng thuốc và hỏi ý kiến thầy thuốc.","page":277,"printed_page":283,"column":1,"bbox":[299.39,520.79,553.72,581.64],"source":{"line_count":5}},{"id":"b0045","type":"paragraph","text":"Nếu thuốc không có tác dụng trong vòng 4 tuần, nên ngừng thuốc và hỏi ý kiến thầy thuốc Một đợt điều trị không được kéo dài quá 3 tháng.","page":277,"printed_page":283,"column":1,"bbox":[299.39,580.86,553.72,617.68],"source":{"line_count":3}},{"id":"b0046","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":277,"printed_page":283,"column":1,"bbox":[299.39,621.74,401.94,634.89],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng ","bbox":[299.39,621.74,401.94,634.89],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0047","type":"paragraph","text":"Cách dùng: Thuốc chỉ được dùng ngoài. Trước khi dùng thuốc, phải rửa sạch bằng xà phòng và nước các vùng có mụn trứng cá.","page":277,"printed_page":283,"column":1,"bbox":[299.39,632.91,553.72,656.72],"source":{"line_count":2}},{"id":"b0048","type":"paragraph","text":"Với nhũ tương dùng ngoài (lotion), cần lắc kỹ trước khi dùng.","page":277,"printed_page":283,"column":1,"bbox":[299.39,654.93,537.44,667.73],"source":{"line_count":1},"spans":[{"text":"Với nhũ tương dùng ngoài (lotion), cần lắc kỹ trước khi dùng. ","bbox":[299.39,654.93,537.44,667.73],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0049","type":"subheading","level":3,"text":"Liều dùng:","page":277,"printed_page":283,"column":1,"bbox":[299.39,666.11,340.81,678.74],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Liều dùng:","bbox":[299.39,666.11,340.81,678.74],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0050","type":"paragraph","text":"Người lớn và trẻ em ≥ 12 tuổi: Bôi một lớp rất mỏng, ngày 1 - 2 lần. Tốt nhất là nên dùng vào lúc đi ngủ để thuốc tác dụng qua đêm.","page":277,"printed_page":283,"column":1,"bbox":[299.39,676.96,553.72,700.77],"source":{"line_count":2}},{"id":"b0051","type":"paragraph","text":"Với trẻ em, nên bắt đầu dùng với nồng độ benzoyl peroxyd nhỏ nhất (2,5%) để tránh kích ứng.","page":277,"printed_page":283,"column":1,"bbox":[299.39,698.98,553.71,722.79],"source":{"line_count":2}},{"id":"b0052","type":"heading","level":2,"text":"Tương tác thuốc","page":277,"printed_page":283,"column":1,"bbox":[299.39,726.86,366.29,740.01],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[299.39,726.86,366.29,740.01],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0053","type":"paragraph","text":"Dùng đồng thời với thuốc chống nắng có chứa acid paraaminobenzoic sẽ làm biến đổi màu da một thời gian.","page":277,"printed_page":283,"column":1,"bbox":[299.39,738.02,551.34,761.83],"source":{"line_count":2}},{"id":"b0054","type":"heading","level":2,"text":"Tương hợp","page":277,"printed_page":283,"column":1,"bbox":[299.39,765.9,344.92,779.04],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương hợp","bbox":[299.39,765.9,344.92,779.04],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0055","type":"paragraph","text":"Benzoyl peroxyd có thể phối hợp trong các chế phẩm có chứa hydrocortison, clindamycin và erythromycin.","page":277,"printed_page":283,"column":1,"bbox":[299.39,777.06,553.72,800.87],"source":{"line_count":2}},{"id":"b0056","type":"heading","level":2,"text":"Quá liều và xử trí","page":278,"printed_page":284,"column":0,"bbox":[43.43,63.02,115.11,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[43.43,63.02,115.11,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0057","type":"paragraph","text":"Nếu xảy ra tróc vảy da quá nhanh, ban đỏ hoặc phù, cần ngừng thuốc. Để khắc phục nhanh các tác dụng có hại, có thể đắp gạc lạnh. Sau khi các triệu chứng và các biểu hiện trên đã giảm, có thể dùng thử một cách thận trọng liều lượng thấp hơn nếu cho rằng phản ứng đã xảy ra là do dùng quá liều chứ không phải do dị ứng.","page":278,"printed_page":284,"column":0,"bbox":[43.43,74.21,297.77,132.19],"source":{"line_count":5}},{"id":"b0058","type":"paragraph","text":"Cập nhật lần cuối: 2019.","page":278,"printed_page":284,"column":0,"bbox":[43.43,137.0,138.7,149.63],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2019.","bbox":[43.43,137.0,138.7,149.63],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"benzoyl-peroxyd","title":"BENZOYL PEROXYD","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007","b0008"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0009","blocks":["b0010","b0011","b0012","b0013"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0014","blocks":["b0015","b0016"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0017","blocks":["b0018"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0019","blocks":["b0020","b0021","b0022","b0023","b0024","b0025","b0026","b0027","b0028","b0029","b0030","b0031"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0032","blocks":["b0033"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0034","blocks":["b0035"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0036","blocks":["b0037","b0038","b0039","b0040","b0041","b0042"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0043","blocks":["b0044","b0045"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0046","blocks":["b0047","b0048","b0049","b0050","b0051"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0052","blocks":["b0053"]},{"id":"tuong-hop","title":"Tương hợp","heading_block":"b0054","blocks":["b0055"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0056","blocks":["b0057","b0058"]}],"quality":{"block_count":58,"heading_count":14,"subheading_count":3,"paragraph_count":40,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}