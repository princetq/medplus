          "bold": true,
          "italic": false
        }
      ],
      "note_role": "than trong",
      "v11_fix": "note_title_reclassified_as_heading_alpha5"
    },
    {
      "id": "b0022",
      "type": "paragraph",
      "text": "Độ an toàn và hiệu quả sử dụng thuốc ở trẻ em dưới 12 tuổi chưa được chứng minh đầy đủ. Sử dụng thuốc ở trẻ em, đặc biệt là trẻ sơ sinh có thể gây ức chế TKTW, dẫn đến hôn mê và hạ thân nhiệt.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        607.42,
        561.72,
        644.3
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0023",
      "type": "paragraph",
      "text": "Nếu cần thiết, phải dùng hết sức thận trọng và có sự giám sát của thầy thuốc.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        643.55,
        561.71,
        668.39
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0024",
      "type": "paragraph",
      "text": "Không nên dùng nhiều lần và liên tục để tránh bị sung huyết nặng trở lại. Khi dùng thuốc nhỏ mũi liên tục 3 ngày không cải thiện, người bệnh cần ngừng thuốc và đi khám bác sĩ.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        667.64,
        561.72,
        704.52
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0025",
      "type": "paragraph",
      "text": "Khi đang dùng naphazolin nhỏ mắt, nếu thấy mắt vẫn đau, kích ứng, nhìn mờ, tình trạng nghiêm trọng hơn sau 24 giờ dùng thuốc hoặc có biểu hiện hấp thu toàn thân như nhức đầu, buồn nôn, hạ thân nhiệt, cần ngừng thuốc và đi khám bác sĩ.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        703.77,
        561.72,
        752.69
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0026",
      "type": "paragraph",
      "text": "Thận trọng khi dùng thuốc cho những người bị cường giáp, bệnh lý tim mạch, bệnh động mạch vành, chứng xơ vữa động mạch, bệnh tăng huyết áp hoặc đái tháo đường, người đang dùng các thuốc IMAO.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        751.94,
        561.72,
        800.87
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0027",
      "type": "paragraph",
      "text": "Ngừng thuốc trước khi sử dụng các thuốc gây mê làm tăng nhạy cảm cơ tim như cyclopropan, halothan.",
      "page": 1164,
      "printed_page": 1170,
      "column": 0,
      "bbox": [
        35.43,
        63.32,
        289.76,
        88.3
      ],
      "source": {
        "line_count": 2
      }
    },
    {
