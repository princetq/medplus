          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0014",
      "type": "paragraph",
      "text": "Nhỏ mũi hoặc xịt mũi để giảm tạm thời triệu chứng sung huyết do viêm mũi cấp hoặc mạn tính, cảm lạnh hoặc dị ứng.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        444.85,
        561.72,
        469.69
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0015",
      "type": "paragraph",
      "text": "Nhỏ mắt để giảm sung huyết và kích ứng mắt do bụi, gió, khói thuốc, không khí ô nhiễm.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        468.94,
        561.73,
        493.78
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0016",
      "type": "heading",
      "level": 2,
      "text": "Chống chỉ định",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        495.87,
        372.06,
        509.02
      ],
