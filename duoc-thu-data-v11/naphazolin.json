    },
    {
      "id": "b0017",
      "type": "paragraph",
      "text": "Mẫn cảm với naphazolin.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        508.07,
        406.6,
        520.87
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Mẫn cảm với naphazolin. ",
          "bbox": [
            307.38,
            508.07,
            406.6,
            520.87
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0018",
      "type": "paragraph",
      "text": "Người bị bệnh glôcôm, glôcôm góc đóng, viêm mống mắt cấp và các bệnh lý nghiêm trọng khác trên mắt.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        520.12,
        561.71,
        544.95
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0019",
      "type": "paragraph",
      "text": "Không dùng đồng thời với kính áp tròng. Nên bỏ kính áp tròng trước khi nhỏ thuốc và đợi ít nhất 15 phút trước khi đeo kính lại.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        544.2,
        561.71,
        569.04
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0020",
      "type": "paragraph",
      "text": "Trước khi làm thủ thuật cắt mống mắt ở những bệnh nhân có khả năng bị glôcôm góc đóng.",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        568.29,
        561.71,
        593.12
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0021",
      "type": "heading",
      "level": 2,
      "text": "Thận trọng",
      "page": 1163,
      "printed_page": 1169,
      "column": 1,
      "bbox": [
        307.38,
        595.22,
        353.57,
        608.37
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Thận trọng",
          "bbox": [
            307.38,
            595.22,
            353.57,
            608.37
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
