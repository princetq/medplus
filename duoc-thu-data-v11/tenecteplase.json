    {
      "id": "b0021",
      "type": "paragraph",
      "text": "ADR thường gặp nhất khi dùng tenecteplase là xuất huyết. Phần lớn bệnh nhân dùng tenecteplase trong các nghiên cứu lâm sàng thường dùng đồng thời với aspirin và heparin, do đó, khó xác định",
      "page": 1530,
      "printed_page": 1536,
      "column": 0,
      "bbox": [
        35.43,
        764.07,
        289.77,
        800.87
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0022",
      "type": "paragraph",
      "text": "biến chứng xuất huyết có phải do một mình tenecteplase hay không.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
