        }
      ]
    },
    {
      "id": "b0033",
      "type": "paragraph",
      "text": "Thường gặp: chảy máu nhẹ.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        293.86,
        406.47,
        306.66
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Thường gặp:",
          "bbox": [
            299.39,
            294.03,
            348.96,
            306.66
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        },
        {
          "text": " chảy máu nhẹ.",
          "bbox": [
            348.96,
            293.86,
            406.47,
            306.66
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Ít gặp: đột quỵ, chảy máu cam, xuất huyết tiêu hóa, tiết niệu, xuất huyết nặng, chảy máu tại chỗ đặt cathete.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        306.17,
        553.72,
        331.28
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0035",
      "type": "paragraph",
      "text": "Hiếm gặp: sốc phản vệ, phù mạch, tắc mạch do cholesterol, phù hầu họng, ban, xuất huyết nội sọ, xuất huyết đường hô hấp, xuất huyết màng bụng, mề đay, hạ huyết áp.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        330.79,
        553.71,
        368.2
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0036",
      "type": "heading",
      "level": 2,
      "text": "Hướng dẫn cách xử trí ADR",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        370.56,
        413.95,
        383.71
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Hướng dẫn cách xử trí ADR",
          "bbox": [
            299.39,
            370.56,
            413.95,
            383.71
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0037",
      "type": "paragraph",
      "text": "Nếu xảy ra xuất huyết nặng khi phối hợp giữa tenecteplase với heparin hoặc các chất ức chế tiểu cầu, cần ngưng dùng thuốc phối hợp. Có thể đảo ngược tác dụng chống đông máu của heparin bằng protamin sulfat.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        383.02,
        553.72,
        432.74
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Có thể hạn chế hạ huyết áp bằng cách nâng cao chân, hoặc giảm tốc độ truyền hoặc tạm dừng thuốc.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        432.25,
        553.72,
        457.36
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0039",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        459.72,
        399.56,
        472.86
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng và cách dùng",
          "bbox": [
            299.39,
            459.72,
            399.56,
            472.86
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0040",
      "type": "paragraph",
      "text": "Cách dùng: Tiêm tĩnh mạch trong vòng 5 giây. Tổng liều khuyến cáo không quá 50 mg, dựa trên cân nặng cơ thể và cần tiêm càng sớm càng tốt từ khi có triệu chứng nhồi máu cơ tim cấp, trong vòng 30 phút từ khi nhập viện cấp cứu.",
      "page": 1530,
      "printed_page": 1536,
      "column": 1,
      "bbox": [
        299.39,
        472.18,
        553.72,
        521.9
      ],
      "source": {
        "line_count": 4
      }
    },
