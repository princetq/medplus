        }
      ]
    },
    {
      "id": "b0048",
      "type": "paragraph",
      "text": "Người lớn: 2 - 3 gói mỗi ngày (thường vào trước bữa ăn).",
      "page": 238,
      "printed_page": 244,
      "column": 0,
      "bbox": [
