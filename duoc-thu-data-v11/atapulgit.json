    },
    {
      "id": "b0043",
      "type": "paragraph",
      "text": "Chống ỉa chảy: Uống 1,2 g đến 1,5 g mỗi lần đi phân lỏng; không vượt quá 9 g trong 24 giờ.",
      "page": 238,
      "printed_page": 244,
      "column": 0,
      "bbox": [
        43.43,
        201.4,
        297.76,
        226.22
      ],
