          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Trẻ em dưới 6 tuổi: Không nên dùng trừ khi có chỉ dẫn của thầy thuốc.",
      "page": 238,
      "printed_page": 244,
      "column": 0,
      "bbox": [
        43.43,
        237.46,
        297.77,
