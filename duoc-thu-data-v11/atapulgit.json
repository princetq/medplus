      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Trẻ em từ 6 đến 12 tuổi: Uống 600 - 750 mg sau mỗi lần đi phân lỏng, không vượt quá 6 g trong 24 giờ.",
      "page": 238,
      "printed_page": 244,
      "column": 0,
      "bbox": [
        43.43,
        261.5,
        297.77,
        286.32
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0047",
      "type": "paragraph",
      "text": "Atapulgit gói (3 g).",
      "page": 238,
      "printed_page": 244,
      "column": 0,
      "bbox": [
        43.43,
        285.71,
        116.27,
        298.34
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
