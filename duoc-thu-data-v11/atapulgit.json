        "line_count": 2
      }
    },
    {
      "id": "b0044",
      "type": "paragraph",
      "text": "Liều thường dùng cho trẻ em:",
      "page": 238,
      "printed_page": 244,
      "column": 0,
      "bbox": [
        43.43,
        225.44,
        156.78,
        238.24
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Liều thường dùng cho trẻ em:",
