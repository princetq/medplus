    },
    {
      "id": "b0009",
      "type": "heading",
      "level": 2,
      "text": "Dược lực học",
      "page": 1380,
      "printed_page": 1386,
      "column": 1,
      "bbox": [
        299.39,
        63.02,
        352.98,
