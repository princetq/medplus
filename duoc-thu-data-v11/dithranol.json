            438.61
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0030",
      "type": "paragraph",
      "text": "Dithranol có thể được hấp thu toàn thân, nhưng không biết dithranol có phân bố vào sữa hay không và chưa có tài liệu nghiên cứu đầy đủ trên người. Vì vậy không thể loại trừ nguy cơ đối với trẻ nhỏ bú mẹ. Sử dụng thận trọng cho phụ nữ đang cho con bú.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        437.7,
        297.77,
        486.75
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0031",
      "type": "heading",
      "level": 2,
      "text": "Tác dụng không mong muốn (ADR)",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        491.88,
        189.38,
        505.03
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tác dụng không mong muốn (ADR)",
          "bbox": [
            43.43,
            491.88,
            189.38,
            505.03
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0032",
      "type": "paragraph",
      "text": "Dithranol có thể gây cảm giác bỏng rát, đặc biệt vùng da lành quanh vùng tổn thương. Người bệnh có màu da sáng dễ mẫn cảm hơn người da sẫm màu. Dithranol kích ứng mắt và các niêm mạc.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        504.12,
        297.77,
        541.09
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0033",
      "type": "subheading",
      "level": 3,
      "text": "Thường gặp",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        540.54,
        89.84,
        553.17
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 0.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-ItalicMT"
        ]
      },
      "spans": [
        {
          "text": "Thường gặp",
          "bbox": [
            43.43,
            540.54,
            89.84,
            553.17
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        }
      ]
    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Nhuộm màu da (tím nâu), thường từ trung bình đến nặng, song ít khi phải ngừng điều trị.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        552.46,
        297.76,
        577.34
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0035",
      "type": "paragraph",
      "text": "Kích ứng da và viêm da (các phản ứng nghiêm trọng làm đỏ da, gây cảm giác nóng, đau và sưng tấy).",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        576.63,
        297.76,
        601.51
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0036",
      "type": "subheading",
      "level": 3,
      "text": "Hiếm gặp",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        600.96,
        80.64,
        613.6
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 0.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-ItalicMT"
        ]
      },
      "spans": [
        {
          "text": "Hiếm gặp",
          "bbox": [
            43.43,
            600.96,
            80.64,
            613.6
          ],
          "font": "TimesNewRomanPS-ItalicMT",
          "fontsize": 9.5,
          "flags": 6,
          "bold": false,
          "italic": true
        }
      ]
    },
    {
      "id": "b0037",
      "type": "paragraph",
      "text": "Dị ứng (ban da).",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        612.89,
        106.1,
        625.68
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Dị ứng (ban da).",
          "bbox": [
            43.43,
            612.89,
            106.1,
            625.68
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Chú ý: Nếu vô ý để thuốc dây vào mắt, có thể bị viêm kết mạc nặng, viêm giác mạc hoặc mờ đục giác mạc.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        624.97,
        297.77,
        649.85
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0039",
      "type": "heading",
      "level": 2,
      "text": "Hướng dẫn cách xử trí ADR",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        654.99,
        160.37,
        668.14
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Hướng dẫn cách xử trí  ADR",
          "bbox": [
            43.43,
            654.99,
            160.37,
            668.14
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0040",
      "type": "paragraph",
      "text": "Nếu vùng da lành bị kích ứng, bôi vaselin quanh vùng bị kích ứng trước khi dùng dithranol.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        667.22,
        297.76,
        692.11
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0041",
      "type": "paragraph",
      "text": "Dạng kem dithranol ít nhuộm màu khăn tắm, quần áo, đồ vải... hơn dạng mỡ. Nhiều tuần sau khi ngừng điều trị, da và tóc sẽ hết bị nhuộm màu.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        691.39,
        297.77,
        728.36
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0042",
      "type": "paragraph",
      "text": "Một tiêu chuẩn để xác định nồng độ tối ưu khi dùng là xuất hiện hồng ban trên da lành kề bên tổn thương. Khi hồng ban xuất hiện, phải giảm liều lượng, số lần bôi và/hoặc thời gian điều trị. Khi đã đạt được nồng độ tối ưu, có thể bôi vaselin trên da lành quanh vùng tổn thương để bảo vệ trước khi bôi dithranol để giảm thiểu kích ứng.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
      "bbox": [
        43.43,
        727.65,
        297.77,
        800.87
      ],
      "source": {
        "line_count": 6
      }
    },
    {
      "id": "b0043",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        63.02,
        407.56,
        76.16
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng và cách dùng",
          "bbox": [
            307.39,
            63.02,
            407.56,
            76.16
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0044",
      "type": "subheading",
      "level": 3,
      "text": "Cách dùng",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        75.25,
        350.41,
        87.97
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
        ]
      },
      "spans": [
        {
          "text": "Cách dùng",
          "bbox": [
            307.39,
            75.25,
            350.41,
            87.97
          ],
          "font": "TimesNewRomanPS-BoldItal",
          "fontsize": 9.5,
          "flags": 22,
          "bold": true,
          "italic": true
        }
      ]
    },
    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Khi bôi dithranol phải dùng găng tay hoặc bôi thuốc xong phải rửa tay ngay. Chỉ bôi một lớp thuốc mỏng vào đúng chỗ tổn thương, xoa nhẹ nhàng cẩn thận cho thuốc ngấm vào chỗ tổn thương, tránh vùng da lành. Vùng da lành xung quanh phải được bôi vaselin để bảo vệ. Đối với da đầu: Chải tóc để loại bỏ hết các mảng bám, làm ướt tóc, rẽ tóc cho phù hợp để bôi thuốc đúng vào chỗ tổn thương, xoa nhẹ nhàng, cẩn thận.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        87.17,
        561.72,
        171.99
      ],
      "source": {
        "line_count": 7
      }
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Sau mỗi khoảng thời gian tiếp xúc với thuốc, người bệnh phải tắm gội để loại bỏ dithranol còn dư lại. Có thể sử dụng xà phòng và dầu gội đầu sau khi đã rửa sạch thuốc trên da bằng nước ấm.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        171.19,
        561.72,
        207.99
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0047",
      "type": "paragraph",
      "text": "Thời gian tiếp xúc tối ưu với thuốc thay đổi phụ thuộc vào nồng độ thuốc và đáp ứng của người bệnh. Khi điều trị ban đầu, nếu tổn thương lan rộng hoặc bị kích ứng mạnh, có thể phải giảm nồng độ dithranol hoặc số lần bôi thuốc, nếu cần phải ngừng điều trị.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        207.2,
        561.72,
        256.01
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0048",
      "type": "subheading",
      "level": 3,
      "text": "Liều lượng",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        255.29,
        351.17,
        268.01
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng",
          "bbox": [
            307.39,
            255.29,
            351.17,
            268.01
          ],
          "font": "TimesNewRomanPS-BoldItal",
          "fontsize": 9.5,
          "flags": 22,
          "bold": true,
          "italic": true
        }
      ]
    },
    {
      "id": "b0049",
      "type": "paragraph",
      "text": "Dùng dithranol bôi lên da hoặc da đầu theo một trong hai cách sau:",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        267.21,
        559.34,
        280.01
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Dùng dithranol bôi lên da hoặc da đầu theo một trong hai cách sau:",
          "bbox": [
            307.39,
            267.21,
            559.34,
            280.01
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0050",
      "type": "paragraph",
      "text": "Điều trị thông thường: Bắt đầu bôi thuốc mỡ hay bột nhão chứa 0,1% dithranol (0,05% đối với người bệnh có màu da sáng), để trong vài giờ. Tăng dần nồng độ thuốc nếu cần tới 0,5%, đôi khi tới 1% và thời gian tiếp xúc có thể để qua đêm (bôi dithranol vào buổi tối và rửa sạch vào buổi sáng hôm sau) hoặc lâu hơn.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        279.22,
        561.72,
        340.02
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0051",
      "type": "paragraph",
      "text": "Liệu pháp tiếp xúc ngắn: Sử dụng liệu pháp tiếp xúc ngắn cho hiệu quả tương đương với liệu pháp điều trị thông thường, nhưng là cách để giảm kích ứng hoặc nhuộm màu da, đặc biệt có lợi khi điều trị bệnh nhân ngoại trú. Thường bôi thuốc lên vùng tổn thương hàng ngày từ 5 đến 10 phút, sau đó rửa sạch. Tùy theo đáp ứng của người bệnh, thời gian tiếp xúc có thể tới 60 phút. Nồng độ thuốc dùng thường tăng dần từ 0,1% tới 2%, có thể tới nồng độ 5% nếu cần.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        339.23,
        561.76,
        424.04
      ],
      "source": {
        "line_count": 7
      }
    },
    {
      "id": "b0052",
      "type": "paragraph",
      "text": "Phải điều trị bệnh vẩy nến đến khi da hoàn toàn sạch tổn thương.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        423.25,
        561.72,
        436.05
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Phải điều trị bệnh vẩy nến đến khi da hoàn toàn sạch tổn thương. ",
          "bbox": [
            307.39,
            423.25,
            561.72,
            436.05
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0053",
      "type": "paragraph",
      "text": "Có thể cần phải điều trị từng đợt để duy trì đáp ứng.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        435.25,
        505.04,
        448.05
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Có thể cần phải điều trị từng đợt để duy trì đáp ứng.",
          "bbox": [
            307.39,
            435.25,
            505.04,
            448.05
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0054",
      "type": "heading",
      "level": 2,
      "text": "Tương tác thuốc",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        450.1,
        374.29,
        463.25
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tương tác thuốc",
          "bbox": [
            307.39,
            450.1,
            374.29,
            463.25
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0055",
      "type": "paragraph",
      "text": "Thêm acid ascorbic (vitamin C) hoặc acid oxalic có thể làm tăng độ ổn định của dithranol.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        462.26,
        561.72,
        487.06
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0056",
      "type": "paragraph",
      "text": "Dùng corticosteroid tại chỗ kéo dài có thể làm bệnh vảy nến không ổn định, khi ngừng thuốc sẽ gây tác dụng hồi ứng. Nên ngừng corticosteroid một tuần trước khi điều trị bằng dithranol. Dùng vaselin hoặc thuốc làm mềm phù hợp khác trong khoảng thời gian một tuần này.",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        486.26,
        561.72,
        547.07
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0057",
      "type": "heading",
      "level": 2,
      "text": "Tương kỵ",
      "page": 614,
      "printed_page": 620,
      "column": 1,
      "bbox": [
        307.39,
        549.13,
