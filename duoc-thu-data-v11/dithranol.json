    },
    {
      "id": "b0028",
      "type": "paragraph",
      "text": "Dithranol có thể được hấp thụ vào vòng tuần hoàn của cơ thể vì vậy nên thận trọng khi dùng cho phụ nữ mang thai.",
      "page": 614,
      "printed_page": 620,
      "column": 0,
