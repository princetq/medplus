      "column": 0,
      "bbox": [
        43.43,
        292.76,
        246.63,
        305.56
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Bắt đầu điều trị phải dưới sự giám sát của thầy thuốc.",
          "bbox": [
            43.43,
