    {
      "id": "b0007",
      "type": "paragraph",
      "text": "Mỡ: Dithranol trong vaselin vàng, nồng độ thường dùng là 0,1 - 2% dithranol.",
      "page": 613,
      "printed_page": 619,
      "column": 1,
