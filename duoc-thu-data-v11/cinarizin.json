        }
      ]
    },
    {
      "id": "b0025",
      "type": "paragraph",
      "text": "Thận trọng khi sử dụng thuốc trên người bệnh động kinh, tắc nghẽn môn vị tá tràng, bí tiểu.",
      "page": 442,
      "printed_page": 448,
      "column": 0,
      "bbox": [
        43.43,
        185.05,
        297.76,
        210.03
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0026",
      "type": "paragraph",
      "text": "Thận trọng khi sử dụng thuốc trên người lớn phì đại tuyến tiền liệt, nhạy cảm với tăng nhãn áp góc đóng, trẻ em có tăng nhãn áp.",
