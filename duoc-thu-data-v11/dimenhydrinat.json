{"schema_version":"11.0.0-alpha.1","id":"dimenhydrinat","title":"Dimenhydrinat","aliases":["Dimenhydrinat"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":596,"end":597},"printed_pages":{"start":602,"end":603},"extraction":{"start_title_pdf_page":596,"start_column":"left","start_y":166.57183837890625,"next_title_pdf_page":597,"next_column":"right","next_y":226.15069580078125,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"DIMENHYDRINAT","page":596,"printed_page":602,"column":0,"bbox":[125.43,166.57,213.57,180.41],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"DIMENHYDRINAT","bbox":[125.43,166.57,213.57,180.41],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Dimenhydrinate.","page":596,"printed_page":602,"column":0,"bbox":[43.43,190.11,187.78,203.26],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[43.43,190.11,123.66,203.26],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Dimenhydrinate.","bbox":[123.66,190.26,187.78,203.06],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: Không có.","page":596,"printed_page":602,"column":0,"bbox":[43.43,201.78,123.47,214.93],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[43.43,201.78,83.89,214.93],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Không có.","bbox":[83.89,201.93,123.47,214.73],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc kháng histamin H1, thế hệ thứ nhất.","page":596,"printed_page":602,"column":0,"bbox":[43.43,213.45,253.21,228.34],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[43.43,213.45,92.52,226.6],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc kháng histamin H","bbox":[92.52,213.6,186.72,226.4],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"1","bbox":[186.71,220.88,189.48,228.34],"font":"TimesNewRomanPSMT","fontsize":5.54,"flags":4,"bold":false,"italic":false},{"text":", thế hệ thứ nhất.","bbox":[189.48,213.6,253.21,226.4],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":596,"printed_page":602,"column":0,"bbox":[43.43,228.29,148.35,241.43],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[43.43,228.29,148.35,241.43],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Viên nén, viên nén bao phim: 50 mg.","page":596,"printed_page":602,"column":0,"bbox":[43.43,240.61,184.03,253.4],"source":{"line_count":1},"spans":[{"text":"Viên nén, viên nén bao phim: 50 mg.","bbox":[43.43,240.61,184.03,253.4],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Viên nén nhai: 50 mg.","page":596,"printed_page":602,"column":0,"bbox":[43.43,252.78,127.57,265.57],"source":{"line_count":1},"spans":[{"text":"Viên nén nhai: 50 mg.","bbox":[43.43,252.78,127.57,265.57],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Dung dịch uống: 12,5 mg/5 ml.","page":596,"printed_page":602,"column":0,"bbox":[43.43,264.95,162.98,277.74],"source":{"line_count":1},"spans":[{"text":"Dung dịch uống: 12,5 mg/5 ml.","bbox":[43.43,264.95,162.98,277.74],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0009","type":"paragraph","text":"Dung dịch tiêm: 50 mg/ml (1 ml).","page":596,"printed_page":602,"column":0,"bbox":[43.43,277.12,172.48,289.91],"source":{"line_count":1},"spans":[{"text":"Dung dịch tiêm: 50 mg/ml (1 ml).","bbox":[43.43,277.12,172.48,289.91],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Đạn đặt trực tràng: 25 mg, 50 mg, 100 mg.","page":596,"printed_page":602,"column":0,"bbox":[43.43,289.29,206.38,302.08],"source":{"line_count":1},"spans":[{"text":"Đạn đặt trực tràng: 25 mg, 50 mg, 100 mg.","bbox":[43.43,289.29,206.38,302.08],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0011","type":"heading","level":2,"text":"Dược lực học","page":596,"printed_page":602,"column":0,"bbox":[43.43,304.3,99.41,317.45],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học ","bbox":[43.43,304.3,99.41,317.45],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0012","type":"paragraph","text":"Dimenhydrinat là một thuốc kháng histamin H1 thế hệ thứ nhất, thuộc nhóm dẫn xuất ethanolamin, có chứa gần một nửa là diphenhydramin. Thuốc tác dụng bằng cách cạnh tranh với histamin ở thụ thể H1. Ngoài tác dụng kháng histamin, dimenhydrinat còn có tác dụng ức chế TKTW, kháng cholinergic, chống nôn.","page":596,"printed_page":602,"column":0,"bbox":[43.43,316.63,297.77,378.1],"source":{"line_count":5}},{"id":"b0013","type":"paragraph","text":"Dimenhydrinat được dùng chủ yếu làm thuốc dự phòng (có hiệu quả hơn), chống nôn khi say tàu xe và chống chóng mặt. Cơ chế của các tác dụng này chưa biết chính xác, nhưng tác dụng chống nôn có thể liên quan tới dimenhydrinat làm giảm kích thích tiền đình, tác động đến ốc tai và khi dùng liều cao, tác động tới các ống bán khuyên của tai trong. Tác dụng chống nôn có thể do tác động lên vùng nhận cảm hóa học (chemoreceptive trigger zone). Một số nghiên cứu cho rằng dimenhydrinat ức chế acetylcholin là cơ chế tác dụng chính, vì kích thích cholinergic ở hệ thống tiền đình và lưới có thể là nguyên nhân gây buồn nôn và nôn do say tàu xe.","page":596,"printed_page":602,"column":0,"bbox":[43.43,377.47,297.77,499.8],"source":{"line_count":10}},{"id":"b0014","type":"paragraph","text":"Tác dụng ức chế hệ TKTW thường giảm sau một vài ngày điều trị và hiệu quả chống nôn có thể giảm phần nào sau khi dùng kéo dài.","page":596,"printed_page":602,"column":0,"bbox":[43.43,499.17,297.77,524.14],"source":{"line_count":2}},{"id":"b0015","type":"paragraph","text":"Dimenhydrinat tuy là một kháng histamin nhưng chưa được đánh giá về tác dụng chống dị ứng.","page":596,"printed_page":602,"column":0,"bbox":[43.43,523.51,297.76,548.48],"source":{"line_count":2}},{"id":"b0016","type":"heading","level":2,"text":"Dược động học","page":596,"printed_page":602,"column":0,"bbox":[43.43,550.7,104.54,563.85],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[43.43,550.7,104.54,563.85],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0017","type":"paragraph","text":"Hấp thu: Dimenhydrinat hấp thu tốt sau khi uống hoặc tiêm. Tác dụng chống nôn thường bắt đầu ngay sau tiêm tĩnh mạch, trong vòng 15 - 30 phút sau khi uống, 30 - 45 phút sau khi đặt trực tràng và 20 - 30 phút sau tiêm bắp. Thời gian tác dụng từ 3 - 6 giờ sau khi dùng thuốc.","page":596,"printed_page":602,"column":0,"bbox":[43.43,563.02,297.77,624.49],"source":{"line_count":5}},{"id":"b0018","type":"paragraph","text":"Phân bố: Giống như các thuốc kháng histamin khác, thuốc có thể được phân bố rộng rãi vào các tổ chức trong cơ thể, qua được nhau thai, một lượng nhỏ được phân bố vào sữa.","page":596,"printed_page":602,"column":0,"bbox":[43.43,623.87,297.76,661.0],"source":{"line_count":3}},{"id":"b0019","type":"paragraph","text":"Chuyển hóa, thải trừ: Thuốc bị chuyển hóa ở gan và thải trừ qua nước tiểu.","page":596,"printed_page":602,"column":0,"bbox":[43.43,660.38,297.78,685.34],"source":{"line_count":2}},{"id":"b0020","type":"heading","level":2,"text":"Chỉ định","page":596,"printed_page":602,"column":0,"bbox":[43.43,687.56,79.08,700.71],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[43.43,687.56,79.08,700.71],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0021","type":"paragraph","text":"Phòng và điều trị triệu chứng buồn nôn, nôn, chóng mặt khi say tàu xe.","page":596,"printed_page":602,"column":0,"bbox":[43.43,699.89,297.76,724.85],"source":{"line_count":2}},{"id":"b0022","type":"paragraph","text":"Điều trị triệu chứng nôn và chóng mặt trong bệnh Ménière và các rối loạn tiền đình khác.","page":596,"printed_page":602,"column":0,"bbox":[43.43,724.22,297.77,749.19],"source":{"line_count":2}},{"id":"b0023","type":"heading","level":2,"text":"Chống chỉ định","page":596,"printed_page":602,"column":0,"bbox":[43.43,751.41,105.73,764.56],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[43.43,751.41,105.73,764.56],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0024","type":"paragraph","text":"Quá mẫn với dimenhydrinat hoặc các thành phần của nó (diphenhydramin, 8-clorotheophylin).","page":596,"printed_page":602,"column":0,"bbox":[43.43,763.73,297.76,788.7],"source":{"line_count":2}},{"id":"b0025","type":"paragraph","text":"Trẻ sơ sinh.","page":596,"printed_page":602,"column":0,"bbox":[43.43,788.07,87.97,800.87],"source":{"line_count":1},"spans":[{"text":"Trẻ sơ sinh.","bbox":[43.43,788.07,87.97,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0026","type":"note","level":2,"text":"Thận trọng","page":596,"printed_page":602,"column":1,"bbox":[307.39,63.02,353.57,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[307.39,63.02,353.57,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0027","type":"paragraph","text":"Cần báo trước cho người bệnh phải thận trọng khi lái xe hoặc vận hành máy móc vì dimenhydrinat có tác dụng gây buồn ngủ nên làm giảm sự tỉnh táo.","page":596,"printed_page":602,"column":1,"bbox":[307.39,75.2,561.72,112.06],"source":{"line_count":3}},{"id":"b0028","type":"paragraph","text":"Tránh dùng thuốc cùng rượu hoặc các thuốc ức chế TKTW khác vì làm tăng tác dụng buồn ngủ.","page":596,"printed_page":602,"column":1,"bbox":[307.39,111.3,561.72,136.13],"source":{"line_count":2}},{"id":"b0029","type":"paragraph","text":"Phải dùng thận trọng ở người mắc những bệnh có thể bị nặng lên do tác dụng kháng cholinergic (như phì đại tuyến tiền liệt, hẹp môn vị - tá tràng, tắc cổ bàng quang (bí tiểu), glôcôm góc hẹp, hen phế quản, loạn nhịp tim) hoặc dùng cho người bị động kinh vì có thể gây co giật.","page":596,"printed_page":602,"column":1,"bbox":[307.39,135.36,561.72,196.29],"source":{"line_count":5}},{"id":"b0030","type":"paragraph","text":"Thuốc có thể che lấp các triệu chứng độc đối với thính giác, do đó phải thận trọng ở những người bệnh có dùng các thuốc đặc biệt có độc tính đối với thính giác và phải theo dõi chặt chẽ khi dùng cùng với dimenhydrinat.","page":596,"printed_page":602,"column":1,"bbox":[307.39,195.52,561.72,244.42],"source":{"line_count":4}},{"id":"b0031","type":"paragraph","text":"Cần thận trọng dùng thuốc cho người cao tuổi vì dễ bị hạ huyết áp thế đứng, chóng mặt và buồn nôn.","page":596,"printed_page":602,"column":1,"bbox":[307.39,243.65,561.69,268.48],"source":{"line_count":2}},{"id":"b0032","type":"paragraph","text":"Tác dụng chống nôn của dimenhydrinat có thể gây trở ngại cho chẩn đoán viêm ruột thừa và che đậy các dấu hiệu nhiễm độc khi dùng quá liều các thuốc khác.","page":596,"printed_page":602,"column":1,"bbox":[307.39,267.72,561.72,304.58],"source":{"line_count":3}},{"id":"b0033","type":"heading","level":2,"text":"Thời kỳ mang thai","page":596,"printed_page":602,"column":1,"bbox":[307.39,306.66,382.6,319.81],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[307.39,306.66,382.6,319.81],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0034","type":"paragraph","text":"Chưa có nghiên cứu đầy đủ về sử dụng dimenhydrinat ở phụ nữ mang thai. Một số nghiên cứu lâm sàng cho biết dùng dimenhydrinat ở một số người mang thai không thấy có sự tăng nguy cơ bất thường đối với thai trong bất kỳ giai đoạn nào của thai kỳ. Các nghiên cứu trên động vật không thấy dimenhydrinat gây tác hại cho thai. Tuy nhiên, chỉ nên dùng dimenhydrinat trong thời kỳ mang thai khi thực sự cần thiết.","page":596,"printed_page":602,"column":1,"bbox":[307.39,318.85,561.72,403.84],"source":{"line_count":7}},{"id":"b0035","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":596,"printed_page":602,"column":1,"bbox":[307.39,405.92,385.5,419.07],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[307.39,405.92,385.5,419.07],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0036","type":"paragraph","text":"Các thuốc kháng histamin thế hệ 1 có thể ức chế tiết sữa do tác dụng kháng cholinergic của thuốc. Một lượng nhỏ dimenhydrinat được phân bố vào sữa mẹ, có nguy cơ gây tác dụng có hại cho con. Vì vậy phải ngừng cho con bú hoặc ngừng thuốc nếu dùng dimenhydrinat.","page":596,"printed_page":602,"column":1,"bbox":[307.39,418.1,561.73,479.03],"source":{"line_count":5}},{"id":"b0037","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":596,"printed_page":602,"column":1,"bbox":[307.39,481.11,453.33,494.26],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[307.39,481.11,453.33,494.26],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0038","type":"paragraph","text":"Buồn ngủ là ADR hay gặp nhất của dimenhydrinat. Một số ADR của dimenhydrinat có liên quan đến tác dụng kháng cholinergic của thuốc.","page":596,"printed_page":602,"column":1,"bbox":[307.39,493.3,561.72,530.16],"source":{"line_count":3}},{"id":"b0039","type":"subheading","level":3,"text":"Thường gặp","page":596,"printed_page":602,"column":1,"bbox":[307.39,529.56,353.79,542.19],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp","bbox":[307.39,529.56,353.79,542.19],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0040","type":"paragraph","text":"TKTW: buồn ngủ, đau đầu, hoa mắt, chóng mặt, mất phối hợp vận động.","page":596,"printed_page":602,"column":1,"bbox":[307.39,541.43,561.72,566.26],"source":{"line_count":2}},{"id":"b0041","type":"paragraph","text":"Nhìn mờ, khô miệng và đường hô hấp, ù tai.","page":596,"printed_page":602,"column":1,"bbox":[307.39,565.49,476.16,578.29],"source":{"line_count":1},"spans":[{"text":"Nhìn mờ, khô miệng và đường hô hấp, ù tai.","bbox":[307.39,565.49,476.16,578.29],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0042","type":"subheading","level":3,"text":"Ít gặp","page":596,"printed_page":602,"column":1,"bbox":[307.39,577.69,329.81,590.32],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Ít gặp","bbox":[307.39,577.69,329.81,590.32],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0043","type":"paragraph","text":"Tiêu hóa: chán ăn, táo bón hoặc ỉa chảy.","page":596,"printed_page":602,"column":1,"bbox":[307.39,589.56,459.43,602.35],"source":{"line_count":1},"spans":[{"text":"Tiêu hóa: chán ăn, táo bón hoặc ỉa chảy.","bbox":[307.39,589.56,459.43,602.35],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0044","type":"paragraph","text":"Tiết niệu: bí đái, khó tiểu tiện.","page":596,"printed_page":602,"column":1,"bbox":[307.39,601.59,422.1,614.39],"source":{"line_count":1},"spans":[{"text":"Tiết niệu: bí đái, khó tiểu tiện.","bbox":[307.39,601.59,422.1,614.39],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0045","type":"paragraph","text":"Tim mạch: đánh trống ngực (nhịp tim nhanh), hạ huyết áp.","page":596,"printed_page":602,"column":1,"bbox":[307.39,613.62,530.15,626.42],"source":{"line_count":1},"spans":[{"text":"Tim mạch: đánh trống ngực (nhịp tim nhanh), hạ huyết áp.","bbox":[307.39,613.62,530.15,626.42],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0046","type":"subheading","level":3,"text":"Hiếm gặp","page":596,"printed_page":602,"column":1,"bbox":[307.39,625.81,344.59,638.45],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp","bbox":[307.39,625.81,344.59,638.45],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0047","type":"paragraph","text":"Kích thích nghịch thường ở trẻ em, đôi khi gặp ở người lớn: kích động, run, mất ngủ, co giật.","page":596,"printed_page":602,"column":1,"bbox":[307.39,637.69,561.72,662.51],"source":{"line_count":2}},{"id":"b0048","type":"subheading","level":3,"text":"Chưa xác định được tần suất","page":596,"printed_page":602,"column":1,"bbox":[307.39,661.91,417.55,674.55],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Chưa xác định được tần suất","bbox":[307.39,661.91,417.55,674.55],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0049","type":"paragraph","text":"Ban da, tăng tiết dịch phế quản, đau vùng thượng vị.","page":596,"printed_page":602,"column":1,"bbox":[307.39,673.78,506.75,686.58],"source":{"line_count":1},"spans":[{"text":"Ban da, tăng tiết dịch phế quản, đau vùng thượng vị.","bbox":[307.39,673.78,506.75,686.58],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0050","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":596,"printed_page":602,"column":1,"bbox":[307.39,688.66,421.95,701.81],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[307.39,688.66,421.95,701.81],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0051","type":"paragraph","text":"Các ADR thường nhẹ. Buồn ngủ thường hết sau vài ngày dùng thuốc. Cần thận trọng đối với người cao tuổi, nên dùng liều thấp nhất có hiệu quả để tránh bí đái do có thể có phì đại tuyến tiền liệt.","page":596,"printed_page":602,"column":1,"bbox":[307.39,700.85,561.72,737.71],"source":{"line_count":3}},{"id":"b0052","type":"paragraph","text":"Có thể uống thuốc cùng với thức ăn, sữa để tránh kích ứng dạ dày.","page":596,"printed_page":602,"column":1,"bbox":[307.39,736.94,561.72,749.74],"source":{"line_count":1},"spans":[{"text":"Có thể uống thuốc cùng với thức ăn, sữa để tránh kích ứng dạ dày. ","bbox":[307.39,736.94,561.72,749.74],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0053","type":"paragraph","text":"Nếu khô mồm, có thể ngậm kẹo hoặc kẹo cao su không đường. Các ADR thường hết khi ngừng thuốc.","page":596,"printed_page":602,"column":1,"bbox":[307.39,748.98,561.72,773.8],"source":{"line_count":2}},{"id":"b0054","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":596,"printed_page":602,"column":1,"bbox":[307.39,775.89,407.56,789.04],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[307.39,775.89,407.56,789.04],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0055","type":"paragraph","text":"Cách dùng: Dimenhydrinat dùng bằng đường uống, tiêm tĩnh","page":596,"printed_page":602,"column":1,"bbox":[307.39,788.07,561.72,800.87],"source":{"line_count":1},"spans":[{"text":"Cách dùng:","bbox":[307.39,788.15,355.66,800.87],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true},{"text":" Dimenhydrinat dùng bằng đường uống, tiêm tĩnh ","bbox":[355.66,788.07,561.72,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0056","type":"paragraph","text":"mạch hoặc tiêm bắp. Tiêm tĩnh mạch phải pha loãng 50 mg trong 10 ml dung dịch natri clorid 0,9%, tiêm chậm trong ít nhất 2 phút.","page":597,"printed_page":603,"column":0,"bbox":[35.43,63.32,289.77,88.25],"source":{"line_count":2}},{"id":"b0057","type":"subheading","level":3,"text":"Liều lượng","page":597,"printed_page":603,"column":0,"bbox":[35.43,87.66,79.22,100.38],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-BoldItal"]},"spans":[{"text":"Liều lượng","bbox":[35.43,87.66,79.22,100.38],"font":"TimesNewRomanPS-BoldItal","fontsize":9.5,"flags":22,"bold":true,"italic":true}]},{"id":"b0058","type":"subheading","level":3,"text":"Phòng và điều trị buồn nôn, nôn, chóng mặt do say tàu xe","page":597,"printed_page":603,"column":0,"bbox":[35.43,99.88,255.5,112.51],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Phòng và điều trị buồn nôn, nôn, chóng mặt do say tàu xe","bbox":[35.43,99.88,255.5,112.51],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0059","type":"paragraph","text":"Phòng say tàu xe, liều đầu tiên phải uống 30 phút trước khi khởi hành.","page":597,"printed_page":603,"column":0,"bbox":[35.43,111.85,289.76,136.77],"source":{"line_count":2}},{"id":"b0060","type":"paragraph","text":"Liều uống:","page":597,"printed_page":603,"column":0,"bbox":[35.43,136.11,76.86,148.91],"source":{"line_count":1},"spans":[{"text":"Liều uống:","bbox":[35.43,136.11,76.86,148.91],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0061","type":"paragraph","text":"Người lớn và trẻ em ≥ 12 tuổi: Mỗi lần 50 - 100 mg, cách 4 - 6 giờ/ lần khi cần, không quá 400 mg/ngày.","page":597,"printed_page":603,"column":0,"bbox":[35.43,148.24,287.39,173.17],"source":{"line_count":2}},{"id":"b0062","type":"paragraph","text":"Trẻ em từ 6 - 11 tuổi: Mỗi lần 25 - 50 mg, cách 6 - 8 giờ/lần khi cần, tối đa mỗi ngày 150 mg.","page":597,"printed_page":603,"column":0,"bbox":[35.43,172.5,289.76,197.43],"source":{"line_count":2}},{"id":"b0063","type":"paragraph","text":"Trẻ em từ 2 - 5 tuổi: Mỗi lần 12,5 - 25 mg, cách 6 - 8 giờ/lần khi cần, tối đa mỗi ngày 75 mg.","page":597,"printed_page":603,"column":0,"bbox":[35.43,196.77,289.76,221.69],"source":{"line_count":2}},{"id":"b0064","type":"paragraph","text":"Trẻ em dưới 2 tuổi chỉ dùng dimenhydrinat đường uống khi có sự theo dõi của bác sĩ.","page":597,"printed_page":603,"column":0,"bbox":[35.43,221.03,289.76,245.96],"source":{"line_count":2}},{"id":"b0065","type":"paragraph","text":"Trẻ sơ sinh: Không dùng.","page":597,"printed_page":603,"column":0,"bbox":[35.43,245.29,132.22,258.09],"source":{"line_count":1},"spans":[{"text":"Trẻ sơ sinh: Không dùng.","bbox":[35.43,245.29,132.22,258.09],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0066","type":"paragraph","text":"Liều tiêm:","page":597,"printed_page":603,"column":0,"bbox":[35.43,257.42,74.75,270.22],"source":{"line_count":1},"spans":[{"text":"Liều tiêm:","bbox":[35.43,257.42,74.75,270.22],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0067","type":"paragraph","text":"Người lớn: Tiêm bắp hoặc tiêm tĩnh mạch, 50 - 100 mg cách 4 giờ/lần khi cần. Tiêm tĩnh mạch phải pha loãng 50 mg trong 10 ml dung dịch natri clorid 0,9%, tiêm chậm trong ít nhất 2 phút. Tối đa 100 mg mỗi 4 giờ.","page":597,"printed_page":603,"column":0,"bbox":[35.43,269.55,289.77,318.75],"source":{"line_count":4}},{"id":"b0068","type":"paragraph","text":"Trẻ em: Tiêm bắp 1,25 mg/kg hoặc 37,5 mg/m2, 4 lần/ngày nếu cần, tối đa 300 mg/ngày. Trẻ sơ sinh không được dùng.","page":597,"printed_page":603,"column":0,"bbox":[35.43,318.08,289.76,343.01],"source":{"line_count":2}},{"id":"b0069","type":"paragraph","text":"Đặt trực tràng:","page":597,"printed_page":603,"column":0,"bbox":[35.43,342.34,93.61,355.14],"source":{"line_count":1},"spans":[{"text":"Đặt trực tràng: ","bbox":[35.43,342.34,93.61,355.14],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0070","type":"paragraph","text":"Người lớn và trẻ em ≥ 12 tuổi: Mỗi lần 50 mg, cách 8 - 12 giờ đặt lại nếu cần thiết.","page":597,"printed_page":603,"column":0,"bbox":[35.43,354.47,289.76,379.4],"source":{"line_count":2}},{"id":"b0071","type":"paragraph","text":"Trẻ em 8 - 11 tuổi: Mỗi lần 25 - 50 mg, cách 8 - 12 giờ đặt lại nếu cần.","page":597,"printed_page":603,"column":0,"bbox":[35.43,378.74,287.42,391.53],"source":{"line_count":1},"spans":[{"text":"Trẻ em 8 - 11 tuổi: Mỗi lần 25 - 50 mg, cách 8 - 12 giờ đặt lại nếu cần.","bbox":[35.43,378.74,287.42,391.53],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0072","type":"paragraph","text":"Trẻ em 6 - 7 tuổi: Mỗi lần 12,5 - 25 mg, cách 8 - 12 giờ đặt lại nếu cần.","page":597,"printed_page":603,"column":0,"bbox":[35.43,390.87,287.42,403.67],"source":{"line_count":1},"spans":[{"text":"Trẻ em 6 - 7 tuổi: Mỗi lần 12,5 - 25 mg, cách 8 - 12 giờ đặt lại nếu cần.","bbox":[35.43,390.87,287.42,403.67],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0073","type":"paragraph","text":"Trẻ em 2 - 5 tuổi: 12,5 - 25 mg đặt 1 lần không lặp lại trừ khi có chỉ định của thầy thuốc.","page":597,"printed_page":603,"column":0,"bbox":[35.43,403.0,289.76,427.93],"source":{"line_count":2}},{"id":"b0074","type":"subheading","level":3,"text":"Điều trị triệu chứng bệnh Ménière","page":597,"printed_page":603,"column":0,"bbox":[35.43,427.42,166.11,440.06],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Điều trị triệu chứng bệnh Ménière","bbox":[35.43,427.42,166.11,440.06],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0075","type":"paragraph","text":"Uống mỗi lần 25 - 50 mg, ngày 3 lần để điều trị duy trì hoặc tiêm bắp 50 mg trong cơn cấp.","page":597,"printed_page":603,"column":0,"bbox":[35.43,439.39,289.77,464.32],"source":{"line_count":2}},{"id":"b0076","type":"paragraph","text":"Người suy gan, suy thận: Theo nhà sản xuất thì không cần điều chỉnh liều.","page":597,"printed_page":603,"column":0,"bbox":[35.43,463.66,289.76,488.58],"source":{"line_count":2}},{"id":"b0077","type":"heading","level":2,"text":"Tương tác thuốc","page":597,"printed_page":603,"column":0,"bbox":[35.43,490.77,102.34,503.92],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[35.43,490.77,102.34,503.92],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0078","type":"paragraph","text":"Thuốc ức chế TKTW (như rượu và barbiturat): Dimenhydrinat có thể làm tăng tác dụng của các thuốc ức chế TKTW. Nếu dùng đồng thời thì cần thận trọng để tránh quá liều.","page":597,"printed_page":603,"column":0,"bbox":[35.43,503.05,289.77,540.11],"source":{"line_count":3}},{"id":"b0079","type":"paragraph","text":"Thuốc kháng cholinergic: Làm tăng tác dụng của các thuốc kháng cholinergic.","page":597,"printed_page":603,"column":0,"bbox":[35.43,539.45,289.77,564.37],"source":{"line_count":2}},{"id":"b0080","type":"paragraph","text":"Kháng sinh nhóm aminoglycosid hoặc các thuốc độc đối với thính giác khác: Dimenhydrinat có thể che lấp các triệu chứng sớm của độc tính đối với thính giác.","page":597,"printed_page":603,"column":0,"bbox":[35.43,563.71,289.78,600.77],"source":{"line_count":3}},{"id":"b0081","type":"heading","level":2,"text":"Tương kỵ","page":597,"printed_page":603,"column":0,"bbox":[35.43,602.95,75.17,616.1],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương kỵ","bbox":[35.43,602.95,75.17,616.1],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0082","type":"paragraph","text":"Dạng dung dịch dimenhydrinat tương kỵ với nhiều thuốc, như aminophylin, glycopyronium bromid, hydrocortison natri succinat, hydroxyzin hydroclorid, meglumin adipiodon, một số phenothiazin và một số barbiturat. Những tương kỵ này phụ thuộc vào nhiều yếu tố (như nồng độ thuốc, dung môi, pH, nhiệt độ).","page":597,"printed_page":603,"column":0,"bbox":[35.43,615.23,289.77,676.56],"source":{"line_count":5}},{"id":"b0083","type":"heading","level":2,"text":"Quá liều và xử trí","page":597,"printed_page":603,"column":0,"bbox":[35.43,678.74,107.11,691.89],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[35.43,678.74,107.11,691.89],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0084","type":"paragraph","text":"Triệu chứng: Quá liều dimenhydrinat thường xảy ra ở trẻ em. Các triệu chứng độc của dimenhydrinat ở trẻ em tương tự như quá liều atropin, bao gồm giãn đồng tử, đỏ mặt, sốt cao, kích động, ảo giác, lú lẫn, mất điều hòa, co giật, hôn mê, suy hô hấp, trụy tim mạch và có thể tử vong. Các triệu chứng có thể chậm trễ tới 2 giờ sau dùng thuốc, tử vong có thể xảy ra trong vòng 18 giờ.","page":597,"printed_page":603,"column":0,"bbox":[35.43,691.02,289.77,764.48],"source":{"line_count":6}},{"id":"b0085","type":"paragraph","text":"Ở người lớn, liều 500 mg hoặc lớn hơn của dimenhydrinat có thể gây khó nói và khó nuốt, loạn tâm thần không thể phân biệt được với ngộ độc atropin.","page":597,"printed_page":603,"column":0,"bbox":[35.43,763.81,289.77,800.87],"source":{"line_count":3}},{"id":"b0086","type":"paragraph","text":"Xử trí: Không có thuốc giải độc đặc hiệu, điều trị triệu chứng và hỗ trợ.","page":597,"printed_page":603,"column":1,"bbox":[299.39,63.33,553.71,88.18],"source":{"line_count":2}},{"id":"b0087","type":"paragraph","text":"Giảm hấp thu: Gây nôn thường không có hiệu quả. Khi không có cơn co giật, có thể rửa dạ dày sớm (sử dụng ống đặt nội khí quản có nút bịt để đề phòng hít phải các chất chứa trong dạ dày). Để người bệnh nằm yên để giảm thiểu kích thích thần kinh trung ương cho người bệnh.","page":597,"printed_page":603,"column":1,"bbox":[299.39,87.44,553.74,148.45],"source":{"line_count":5}},{"id":"b0088","type":"paragraph","text":"Nếu co giật, điều trị bằng diazepam ở người lớn và phenobarbital ở trẻ em.","page":597,"printed_page":603,"column":1,"bbox":[299.39,147.7,553.72,172.55],"source":{"line_count":2}},{"id":"b0089","type":"paragraph","text":"Suy hô hấp: Dùng máy hỗ trợ hô hấp.","page":597,"printed_page":603,"column":1,"bbox":[299.39,171.81,442.42,184.61],"source":{"line_count":1},"spans":[{"text":"Suy hô hấp: Dùng máy hỗ trợ hô hấp.","bbox":[299.39,171.81,442.42,184.61],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0090","type":"paragraph","text":"Cập nhật lần cuối: 2021.","page":597,"printed_page":603,"column":1,"bbox":[299.39,189.43,394.65,202.06],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2021.","bbox":[299.39,189.43,394.65,202.06],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"dimenhydrinat","title":"DIMENHYDRINAT","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007","b0008","b0009","b0010"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0011","blocks":["b0012","b0013","b0014","b0015"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0016","blocks":["b0017","b0018","b0019"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0020","blocks":["b0021","b0022"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0023","blocks":["b0024","b0025","b0026","b0027","b0028","b0029","b0030","b0031","b0032"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0033","blocks":["b0034"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0035","blocks":["b0036"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0037","blocks":["b0038","b0039","b0040","b0041","b0042","b0043","b0044","b0045","b0046","b0047","b0048","b0049"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0050","blocks":["b0051","b0052","b0053"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0054","blocks":["b0055","b0056","b0057","b0058","b0059","b0060","b0061","b0062","b0063","b0064","b0065","b0066","b0067","b0068","b0069","b0070","b0071","b0072","b0073","b0074","b0075","b0076"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0077","blocks":["b0078","b0079","b0080"]},{"id":"tuong-ky","title":"Tương kỵ","heading_block":"b0081","blocks":["b0082"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0083","blocks":["b0084","b0085","b0086","b0087","b0088","b0089","b0090"]}],"quality":{"block_count":90,"heading_count":14,"subheading_count":7,"paragraph_count":68,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}