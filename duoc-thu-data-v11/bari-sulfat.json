{"schema_version":"11.0.0-alpha.1","id":"bari-sulfat","title":"Bari Sulfat","aliases":["bari sulfat","Bari Sulfate"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":264,"end":265},"printed_pages":{"start":270,"end":271},"extraction":{"start_title_pdf_page":264,"start_column":"right","start_y":218.095947265625,"next_title_pdf_page":265,"next_column":"right","next_y":62.82659912109375,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"BARI SULFAT","page":264,"printed_page":270,"column":1,"bbox":[400.72,218.1,466.19,231.94],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"BARI SULFAT","bbox":[400.72,218.1,466.19,231.94],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Barium sulfate.","page":264,"printed_page":270,"column":1,"bbox":[307.39,241.95,446.19,255.1],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[307.39,241.95,387.61,255.1],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Barium sulfate.","bbox":[387.62,242.1,446.19,254.9],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: V08BA01, V08BA02.","page":264,"printed_page":270,"column":1,"bbox":[307.39,256.77,432.91,269.92],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[307.39,256.77,347.84,269.92],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"V08BA01, V08BA02.","bbox":[347.84,256.93,432.91,269.72],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Thuốc cản quang (không phối hợp) đường tiêu hóa.","page":264,"printed_page":270,"column":1,"bbox":[307.39,271.6,552.41,284.75],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[307.39,271.6,356.47,284.75],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc cản quang (không phối hợp) đường tiêu hóa.","bbox":[356.47,271.75,552.41,284.55],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":264,"printed_page":270,"column":1,"bbox":[307.39,286.75,412.3,299.9],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[307.39,286.75,412.3,299.9],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Hỗn dịch uống: 96,25% (bình 300 ml), 100% (bình 300 ml).","page":264,"printed_page":270,"column":1,"bbox":[307.39,299.06,539.07,311.86],"source":{"line_count":1},"spans":[{"text":"Hỗn dịch uống: 96,25% (bình 300 ml), 100% (bình 300 ml). ","bbox":[307.39,299.06,539.07,311.86],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Bột nhão uống: Tuýp 150 g (70 g bari sulfat/100 g).","page":264,"printed_page":270,"column":1,"bbox":[307.39,311.21,506.36,324.01],"source":{"line_count":1},"spans":[{"text":"Bột nhão uống: Tuýp 150 g (70 g bari sulfat/100 g). ","bbox":[307.39,311.21,506.36,324.01],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Túi thụt trực tràng: 70% (400 ml) (cung cấp trong bộ thụt trực tràng).","page":264,"printed_page":270,"column":1,"bbox":[307.39,323.37,559.37,336.16],"source":{"line_count":1},"spans":[{"text":"Túi thụt trực tràng: 70% (400 ml) (cung cấp trong bộ thụt trực tràng).","bbox":[307.39,323.37,559.37,336.16],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0009","type":"paragraph","text":"Bột pha hỗn dịch: 140 g, 200 g.","page":264,"printed_page":270,"column":1,"bbox":[307.39,335.52,427.46,348.32],"source":{"line_count":1},"spans":[{"text":"Bột pha hỗn dịch: 140 g, 200 g.","bbox":[307.39,335.52,427.46,348.32],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Viên nén: 650 mg.","page":264,"printed_page":270,"column":1,"bbox":[307.39,347.68,377.53,360.47],"source":{"line_count":1},"spans":[{"text":"Viên nén: 650 mg.","bbox":[307.39,347.68,377.53,360.47],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0011","type":"heading","level":2,"text":"Dược lực học","page":264,"printed_page":270,"column":1,"bbox":[307.39,362.68,360.98,375.83],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[307.39,362.68,360.98,375.83],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0012","type":"paragraph","text":"Bari sulfat là một muối kim loại không hòa tan trong nước và trong các dung môi hữu cơ, rất ít tan trong acid và hydroxyd kiềm. Bari sulfat thường được dùng dưới dạng hỗn dịch uống hoặc thụt hậu môn, hoặc dưới dạng bột nhão uống để làm chất cản quang trong xét nghiệm X-quang đường tiêu hóa. Bari là một kim loại có khối lượng nguyên tử 137, có tính chất hấp thụ mạnh tia X. Hỗn dịch hoặc bột nhão bari sulfat tùy theo nồng độ được dùng theo đường uống hay đường trực tràng để bao phủ lên ống tiêu hóa làm rõ tổn thương trên phim X-quang, dùng trong kỹ thuật tương phản đơn hoặc kép hoặc chụp cắt lớp điện toán.","page":264,"printed_page":270,"column":1,"bbox":[307.39,374.98,561.72,497.17],"source":{"line_count":10}},{"id":"b0013","type":"paragraph","text":"Hỗn dịch bari sulfat ổn định, đồng nhất, có tỷ trọng 1,8 g/cm3 với nồng độ 1 g bari sulfat trong 1 ml và có độ nhớt 2 000 cP, ở nhiệt độ 25 °C.","page":264,"printed_page":270,"column":1,"bbox":[307.39,496.53,561.72,533.63],"source":{"line_count":3}},{"id":"b0014","type":"paragraph","text":"Vì bari sulfat không hòa tan trong nước nên không có độc tính nặng như ion bari. Tử vong đã xảy ra khi dùng nhầm bari sulfid là một chất hòa tan trong nước.","page":264,"printed_page":270,"column":1,"bbox":[307.39,532.99,561.72,570.09],"source":{"line_count":3}},{"id":"b0015","type":"heading","level":2,"text":"Dược động học","page":264,"printed_page":270,"column":1,"bbox":[307.39,572.3,368.49,585.45],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[307.39,572.3,368.49,585.45],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Do tính chất không hòa tan trong nước và trong các dung môi hữu cơ nên bari sulfat không hấp thu qua đường tiêu hóa.","page":264,"printed_page":270,"column":1,"bbox":[307.39,584.61,561.71,609.56],"source":{"line_count":2}},{"id":"b0017","type":"heading","level":2,"text":"Chỉ định","page":264,"printed_page":270,"column":1,"bbox":[307.39,611.76,343.03,624.91],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[307.39,611.76,343.03,624.91],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Thuốc cản quang dùng để thăm khám bằng X-quang toàn bộ đường tiêu hóa và theo dõi thời gian vận chuyển qua đường tiêu hóa.","page":264,"printed_page":270,"column":1,"bbox":[307.39,624.07,561.72,649.02],"source":{"line_count":2}},{"id":"b0019","type":"heading","level":2,"text":"Chống chỉ định","page":264,"printed_page":270,"column":1,"bbox":[307.39,651.22,369.69,664.37],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[307.39,651.22,369.69,664.37],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0020","type":"paragraph","text":"Tắc nghẽn hoặc thủng trên đường tiêu hóa.","page":264,"printed_page":270,"column":1,"bbox":[307.39,663.53,470.59,676.33],"source":{"line_count":1},"spans":[{"text":"Tắc nghẽn hoặc thủng trên đường tiêu hóa.","bbox":[307.39,663.53,470.59,676.33],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0021","type":"note","level":2,"text":"Thận trọng","page":264,"printed_page":270,"column":1,"bbox":[307.39,678.53,353.57,691.68],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[307.39,678.53,353.57,691.68],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0022","type":"paragraph","text":"Bari sulfat không được chỉ định cho người bệnh bị tắc ruột và phải thận trọng đối với người có chứng hẹp môn vị hoặc có tổn thương dễ dẫn đến tắc nghẽn ống tiêu hóa. Phải tránh dùng thuốc, nhất là cho qua đường hậu môn, ở những người có nguy cơ bị thủng như trong viêm đại tràng loét cấp hoặc viêm túi thừa Meckel, sau khi làm sinh thiết trực tràng hoặc đại tràng, soi đại tràng sigma hoặc quang tuyến liệu pháp.","page":264,"printed_page":270,"column":1,"bbox":[307.39,690.84,561.72,776.56],"source":{"line_count":7}},{"id":"b0023","type":"paragraph","text":"Thận trọng đối với người bị suy kiệt nặng. Để tránh táo bón sau khi dùng bari sulfat, cần cho người bệnh uống nước đủ.","page":264,"printed_page":270,"column":1,"bbox":[307.39,775.92,561.72,800.87],"source":{"line_count":2}},{"id":"b0024","type":"paragraph","text":"Vì bari sulfat có tính chất trơ nên những vết mờ còn để lại sẽ cản trở cho những lần chụp X-quang tiếp theo.","page":265,"printed_page":271,"column":0,"bbox":[35.43,63.32,289.76,88.97],"source":{"line_count":2}},{"id":"b0025","type":"heading","level":2,"text":"Thời kỳ mang thai","page":265,"printed_page":271,"column":0,"bbox":[35.43,91.87,110.64,105.02],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[35.43,91.87,110.64,105.02],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0026","type":"paragraph","text":"Chưa có tài liệu nghiên cứu cho thấy tai biến khi dùng bari sulfat cho người mang thai. Nói chung, nên tránh tất cả các loại thăm dò bằng X-quang ở người mang thai.","page":265,"printed_page":271,"column":0,"bbox":[35.43,104.87,289.76,143.37],"source":{"line_count":3}},{"id":"b0027","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":265,"printed_page":271,"column":0,"bbox":[35.43,146.27,113.55,159.42],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[35.43,146.27,113.55,159.42],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0028","type":"paragraph","text":"Chưa có tài liệu nghiên cứu cho thấy tai biến khi dùng bari sulfat cho người cho con bú. Nói chung, cần thận trọng khi dùng thuốc cho người mẹ đang cho con bú.","page":265,"printed_page":271,"column":0,"bbox":[35.43,159.27,289.77,197.77],"source":{"line_count":3}},{"id":"b0029","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":265,"printed_page":271,"column":0,"bbox":[35.43,200.67,181.38,213.82],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[35.43,200.67,181.38,213.82],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0030","type":"subheading","level":3,"text":"Thường gặp và rất thường gặp","page":265,"printed_page":271,"column":0,"bbox":[35.43,213.83,152.79,226.47],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp và rất thường gặp","bbox":[35.43,213.83,152.79,226.47],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0031","type":"paragraph","text":"Tiêu hóa: Táo bón (có thể ngăn ngừa táo bón bằng cách cho người bệnh dùng thuốc nhuận tràng nhẹ sau khi kiểm tra X-quang).","page":265,"printed_page":271,"column":0,"bbox":[35.43,226.52,289.79,252.17],"source":{"line_count":2}},{"id":"b0032","type":"subheading","level":3,"text":"Hiếm gặp và rất hiếm gặp","page":265,"printed_page":271,"column":0,"bbox":[35.43,252.38,134.91,265.02],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp và rất hiếm gặp","bbox":[35.43,252.38,134.91,265.02],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0033","type":"paragraph","text":"Toàn thân: dị ứng phản vệ (khi dùng hỗn dịch bari sulfat).","page":265,"printed_page":271,"column":0,"bbox":[35.43,265.07,255.23,277.87],"source":{"line_count":1},"spans":[{"text":"Toàn thân: dị ứng phản vệ (khi dùng hỗn dịch bari sulfat).","bbox":[35.43,265.07,255.23,277.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0034","type":"paragraph","text":"Da: nổi mày đay, phù mặt.","page":265,"printed_page":271,"column":0,"bbox":[35.43,277.92,135.87,290.72],"source":{"line_count":1},"spans":[{"text":"Da: nổi mày đay, phù mặt.","bbox":[35.43,277.92,135.87,290.72],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0035","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":265,"printed_page":271,"column":0,"bbox":[35.43,293.62,135.61,306.77],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[35.43,293.62,135.61,306.77],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0036","type":"paragraph","text":"Liều lượng bari sulfat phụ thuộc vào loại thăm khám và kỹ thuật dùng.","page":265,"printed_page":271,"column":0,"bbox":[35.43,306.62,289.77,332.27],"source":{"line_count":2}},{"id":"b0037","type":"paragraph","text":"Thực quản: Uống ≤ 150 ml hỗn dịch nồng độ 50 - 200% (khối lượng/thể tích).","page":265,"printed_page":271,"column":0,"bbox":[35.43,332.32,289.76,357.97],"source":{"line_count":2}},{"id":"b0038","type":"paragraph","text":"Dạ dày và tá tràng: Uống ≤ 300 ml hỗn dịch nồng độ 30 - 200%.","page":265,"printed_page":271,"column":0,"bbox":[35.43,358.02,280.76,370.82],"source":{"line_count":1},"spans":[{"text":"Dạ dày và tá tràng: Uống ≤ 300 ml hỗn dịch nồng độ 30 - 200%.","bbox":[35.43,358.02,280.76,370.82],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Tiểu tràng: Uống 100 - 300 ml hỗn dịch nồng độ 30 - 150%.","page":265,"printed_page":271,"column":0,"bbox":[35.43,370.87,264.67,383.67],"source":{"line_count":1},"spans":[{"text":"Tiểu tràng: Uống 100 - 300 ml hỗn dịch nồng độ 30 - 150%.","bbox":[35.43,370.87,264.67,383.67],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0040","type":"paragraph","text":"Đại tràng: Thụt 200 ml tới 2 lít hỗn dịch có nồng độ 20 - 130%.","page":265,"printed_page":271,"column":0,"bbox":[35.43,383.72,277.25,396.52],"source":{"line_count":1},"spans":[{"text":"Đại tràng: Thụt 200 ml tới 2 lít hỗn dịch có nồng độ 20 - 130%.","bbox":[35.43,383.72,277.25,396.52],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0041","type":"paragraph","text":"Phần trên ống tiêu hóa (hầu, hạ hầu, thực quản): Uống bột nhão 2 - 4 thìa canh tùy theo vị trí thăm khám. Để có các hình ảnh tốt nhất (không có bọt không khí), phải nuốt không nhai.","page":265,"printed_page":271,"column":0,"bbox":[35.43,396.57,289.77,435.07],"source":{"line_count":3}},{"id":"b0042","type":"paragraph","text":"Thăm khám X-quang phải thực hiện lúc đói đối với ống tiêu hóa phần trên. Đối với đường tiêu hóa dưới, phải thụt tháo buổi tối và ăn chế độ ít cặn bã 3 ngày trước khi xét nghiệm.","page":265,"printed_page":271,"column":0,"bbox":[35.43,435.12,289.77,473.62],"source":{"line_count":3}},{"id":"b0043","type":"paragraph","text":"Hỗn dịch có nồng độ 1,6 - 2,2% có thể dùng để chụp cắt lớp điện toán đường tiêu hóa.","page":265,"printed_page":271,"column":0,"bbox":[35.43,473.67,289.76,499.32],"source":{"line_count":2}},{"id":"b0044","type":"paragraph","text":"Để thực hiện tương phản kép, có thể đưa khí vào đường tiêu hóa bằng cách dùng các hỗn dịch bari sulfat chứa carbon dioxyd. Cũng có các chế phẩm có natri bicarbonat để tạo khí riêng. Không khí có thể đưa vào qua một ống để thay thế carbon dioxyd.","page":265,"printed_page":271,"column":0,"bbox":[35.43,499.37,289.77,550.72],"source":{"line_count":4}},{"id":"b0045","type":"paragraph","text":"Thuốc cản quang và siêu âm đều đã được dùng để chẩn đoán lồng ruột, nhưng siêu âm thường được đánh giá cao hơn trong chẩn đoán, còn thụt để dành cho tháo lồng ruột. Hỗn dịch bari sulfat đã được dùng từ nhiều năm để chẩn đoán lồng ruột và tháo lồng, nhưng hiện nay nhiều nơi đã thay thế hỗn dịch bari sulfat bằng thụt tháo lồng bằng không khí hoặc bằng thụt nước muối có siêu âm hướng dẫn để giảm nguy cơ viêm màng bụng do chất hóa học nếu xảy ra thủng ruột.","page":265,"printed_page":271,"column":0,"bbox":[35.43,550.77,289.77,653.52],"source":{"line_count":8}},{"id":"b0046","type":"heading","level":2,"text":"Quá liều và xử trí","page":265,"printed_page":271,"column":0,"bbox":[35.43,656.42,107.11,669.57],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[35.43,656.42,107.11,669.57],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0047","type":"paragraph","text":"Khi chỉ định nhầm hoặc do quá trình chụp gây thủng, sẽ dẫn đến tình trạng nhiễm khuẩn (do vi khuẩn trong ống tiêu hóa), làm nghẽn mạch (trong trường hợp xuất huyết).","page":265,"printed_page":271,"column":0,"bbox":[35.43,669.42,289.77,707.92],"source":{"line_count":3}},{"id":"b0048","type":"paragraph","text":"Cần phải mổ cấp cứu, làm sạch tại chỗ càng sớm càng tốt (trước 6 giờ).","page":265,"printed_page":271,"column":0,"bbox":[35.43,707.97,289.8,733.62],"source":{"line_count":2}},{"id":"b0049","type":"paragraph","text":"Cập nhật lần cuối: 2017.","page":265,"printed_page":271,"column":0,"bbox":[35.43,739.23,133.07,751.87],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2017.\n","bbox":[35.43,739.23,133.07,751.87],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"bari-sulfat","title":"BARI SULFAT","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007","b0008","b0009","b0010"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0011","blocks":["b0012","b0013","b0014"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0015","blocks":["b0016"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0017","blocks":["b0018"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0019","blocks":["b0020","b0021","b0022","b0023","b0024"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0025","blocks":["b0026"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0027","blocks":["b0028"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0029","blocks":["b0030","b0031","b0032","b0033","b0034"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0035","blocks":["b0036","b0037","b0038","b0039","b0040","b0041","b0042","b0043","b0044","b0045"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0046","blocks":["b0047","b0048","b0049"]}],"quality":{"block_count":49,"heading_count":11,"subheading_count":2,"paragraph_count":35,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}