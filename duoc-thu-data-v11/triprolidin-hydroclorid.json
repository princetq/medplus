{"schema_version":"11.0.0-alpha.1","id":"triprolidin-hydroclorid","title":"Triprolidin Hydroclorid","aliases":["triprolidin hydroclorid","Triprolidin Hydrochloride"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":1626,"end":1627},"printed_pages":{"start":1632,"end":1633},"extraction":{"start_title_pdf_page":1626,"start_column":"left","start_y":482.27252197265625,"next_title_pdf_page":1627,"next_column":"left","next_y":714.5394897460938,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"TRIPROLIDIN HYDROCLORID","page":1626,"printed_page":1632,"column":0,"bbox":[87.65,482.27,235.15,496.11],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"TRIPROLIDIN HYDROCLORID","bbox":[87.65,482.27,235.15,496.11],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Triprolidine hydrochloride.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,505.69,219.11,518.84],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế:","bbox":[35.43,505.69,113.29,518.84],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":" Triprolidine hydrochloride.","bbox":[113.29,505.84,219.11,518.64],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: R06AX07.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,517.25,117.32,530.39],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[35.43,517.25,75.89,530.39],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"R06AX07.","bbox":[75.89,517.4,117.32,530.19],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Kháng histamin thế hệ 1, chất đối kháng thụ thể H1.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,528.8,280.94,543.7],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[35.43,528.8,84.52,541.95],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Kháng histamin thế hệ 1, chất đối kháng thụ thể H","bbox":[84.52,528.95,275.82,541.75],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false},{"text":"1","bbox":[275.8,536.23,278.57,543.7],"font":"TimesNewRomanPSMT","fontsize":5.54,"flags":4,"bold":false,"italic":false},{"text":".","bbox":[278.57,528.95,280.94,541.75],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,543.85,140.35,557.0],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[35.43,543.85,140.35,557.0],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Viên nén: 2,5 mg.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,556.06,105.58,568.85],"source":{"line_count":1},"spans":[{"text":"Viên nén: 2,5 mg. ","bbox":[35.43,556.06,105.58,568.85],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Dung dịch uống: 1,25 mg/ml.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,568.11,147.86,580.91],"source":{"line_count":1},"spans":[{"text":"Dung dịch uống: 1,25 mg/ml.","bbox":[35.43,568.11,147.86,580.91],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Sirô: 0,25 mg/ml.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,580.17,102.47,592.96],"source":{"line_count":1},"spans":[{"text":"Sirô: 0,25 mg/ml.","bbox":[35.43,580.17,102.47,592.96],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0009","type":"paragraph","text":"Dạng kết hợp: Sirô triprolidin hydroclorid 1,25 mg + pseudoephedrin hydroclorid 30 mg/ml, dung dịch uống triprolidin hydroclorid 1,25 mg","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,592.22,289.79,617.07],"source":{"line_count":2}},{"id":"b0010","type":"list","text":"+ pseudoephedrin hydroclorid 45 mg/ml, viên nén triprolidin hydroclorid 2,5 mg + pseudoephedrin hydroclorid 60 mg.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,616.33,289.77,641.18],"source":{"line_count":2},"items":["pseudoephedrin hydroclorid 45 mg/ml, viên nén triprolidin","hydroclorid 2,5 mg + pseudoephedrin hydroclorid 60 mg."]},{"id":"b0011","type":"heading","level":2,"text":"Dược lực học","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,643.28,89.03,656.43],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[35.43,643.28,89.03,656.43],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0012","type":"paragraph","text":"Triprolidin hydroclorid, một dẫn chất của propylamin (alkylamin), là một thuốc kháng histamin thế hệ 1. Triprolidin ức chế tác dụng của histamin do ức chế thụ thể H1, cũng có tác dụng gây buồn ngủ nhẹ và kháng muscarin. Thuốc được coi là tương đối ít gây an thần (ngủ) hơn các kháng histamin truyền thống dẫn xuất từ ethanolamin, phenothiazin và ethylendiamin. Triprolidin có nửa đời thải trừ và thời gian tác dụng ngắn hơn so với đa số các kháng histamin alkylamin khác.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,655.49,289.77,752.66],"source":{"line_count":8}},{"id":"b0013","type":"paragraph","text":"Triprolidin được dùng theo đường uống để điều trị triệu chứng một số bệnh dị ứng và thường được phối hợp với một số thuốc khác để điều trị ho, cảm lạnh.","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,751.91,289.77,788.82],"source":{"line_count":3}},{"id":"b0014","type":"paragraph","text":"Ngoài ra triprolidin hydroclorid cũng được dùng bôi ngoài da, tuy","page":1626,"printed_page":1632,"column":0,"bbox":[35.43,788.07,289.76,800.87],"source":{"line_count":1},"spans":[{"text":"Ngoài ra triprolidin hydroclorid cũng được dùng bôi ngoài da, tuy ","bbox":[35.43,788.07,289.76,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0015","type":"paragraph","text":"nhiên có nguy cơ gây mẫn cảm.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,63.32,420.23,76.12],"source":{"line_count":1},"spans":[{"text":"nhiên có nguy cơ gây mẫn cảm.","bbox":[299.39,63.32,420.23,76.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0016","type":"heading","level":2,"text":"Dược động học","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,78.3,360.49,91.45],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[299.39,78.3,360.49,91.45],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0017","type":"paragraph","text":"Sau khi uống, thuốc được hấp thu tốt ở ống tiêu hóa. Thức ăn không ảnh hưởng đến sự hấp thu của thuốc. Thuốc được chuyển hóa ở gan. Tác dụng xuất hiện 15 - 60 phút sau khi uống thuốc và kéo dài từ 4 - 6 giờ. Một nửa liều uống được carboxyl hóa và được đào thải theo nước tiểu. Nửa đời của thuốc là 3 - 5 giờ hoặc hơn.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,90.59,553.72,151.92],"source":{"line_count":5}},{"id":"b0018","type":"paragraph","text":"Thuốc phân bố được vào sữa mẹ.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,151.26,425.78,164.05],"source":{"line_count":1},"spans":[{"text":"Thuốc phân bố được vào sữa mẹ.","bbox":[299.39,151.26,425.78,164.05],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0019","type":"heading","level":2,"text":"Chỉ định","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,166.24,335.03,179.39],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[299.39,166.24,335.03,179.39],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0020","type":"paragraph","text":"Điều trị các triệu chứng của dị ứng như mày đay, viêm mũi dị ứng, ngứa. Triprolidin và pseudoephedrin hydroclorid thường được kết hợp để điều trị viêm mũi. Triprolidin cũng có mặt trong nhiều chế phẩm chữa triệu chứng ho và cảm lạnh.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,178.52,553.72,227.72],"source":{"line_count":4}},{"id":"b0021","type":"heading","level":2,"text":"Chống chỉ định","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,229.91,361.69,243.05],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[299.39,229.91,361.69,243.05],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0022","type":"paragraph","text":"Dị ứng với triprolidin.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,242.19,383.98,254.99],"source":{"line_count":1},"spans":[{"text":"Dị ứng với triprolidin.","bbox":[299.39,242.19,383.98,254.99],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0023","type":"paragraph","text":"Cơn hen cấp.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,254.33,349.53,267.12],"source":{"line_count":1},"spans":[{"text":"Cơn hen cấp.","bbox":[299.39,254.33,349.53,267.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0024","type":"paragraph","text":"Glôcôm góc đóng.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,266.46,369.84,279.26],"source":{"line_count":1},"spans":[{"text":"Glôcôm góc đóng.","bbox":[299.39,266.46,369.84,279.26],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0025","type":"paragraph","text":"Đang được điều trị bằng thuốc ức chế monoaminoxydase hoặc mới ngừng dùng thuốc này chưa được hai tuần (nếu dùng triprolidin phối hợp với pseudoephedrin).","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,278.59,553.72,315.66],"source":{"line_count":3}},{"id":"b0026","type":"paragraph","text":"Trẻ em dưới 4 tháng tuổi.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,314.99,396.3,327.79],"source":{"line_count":1},"spans":[{"text":"Trẻ em dưới 4 tháng tuổi.","bbox":[299.39,314.99,396.3,327.79],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0027","type":"note","level":2,"text":"Thận trọng","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,329.98,345.57,343.12],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[299.39,329.98,345.57,343.12],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0028","type":"paragraph","text":"Tình trạng buồn ngủ là vấn đề chủ yếu khi dùng thuốc. Cần thận trọng khi dùng cho người điều khiển xe, vận hành máy…","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,342.26,553.72,367.19],"source":{"line_count":2}},{"id":"b0029","type":"paragraph","text":"Người bị suy gan nặng hoặc uống rượu khi dùng thuốc sẽ làm tăng nguy cơ gây buồn ngủ.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,366.53,553.72,391.46],"source":{"line_count":2}},{"id":"b0030","type":"paragraph","text":"Cần thận trọng khi dùng triprolidin cho người bị suy thận và phải giảm liều.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,390.8,553.72,415.73],"source":{"line_count":2}},{"id":"b0031","type":"paragraph","text":"Do có tác dụng kháng muscarin nên cần phải thận trọng khi dùng cho người bị phì đại tuyến tiền liệt, bí tiểu tiện, hẹp môn vị tá tràng.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,415.06,553.71,439.99],"source":{"line_count":2}},{"id":"b0032","type":"paragraph","text":"Cần thận trọng khi dùng thuốc cho người bị động kinh do đôi khi gây co giật.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,439.33,553.72,464.26],"source":{"line_count":2}},{"id":"b0033","type":"paragraph","text":"Trẻ nhỏ và người trên 60 tuổi dễ bị các tác dụng phụ của thuốc (ức chế TKTW và hạ huyết áp) và các triệu chứng thường nặng hơn nên khi dùng phải thận trọng.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,463.6,553.72,500.66],"source":{"line_count":3}},{"id":"b0034","type":"paragraph","text":"Cần thận trọng khi dùng dạng phối hợp triprolidin với pseudoephedrin cho người tăng huyết áp, có bệnh tim, cường giáp, đái tháo đường, gây mê bằng thuốc gây mê halogen bay hơi.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,500.0,553.72,537.06],"source":{"line_count":3}},{"id":"b0035","type":"paragraph","text":"Phải ngừng uống triprolidin 4 ngày trước khi làm phản ứng dị ứng bì.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,536.4,551.37,549.2],"source":{"line_count":1},"spans":[{"text":"Phải ngừng uống triprolidin 4 ngày trước khi làm phản ứng dị ứng bì.","bbox":[299.39,536.4,551.37,549.2],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0036","type":"heading","level":2,"text":"Thời kỳ mang thai","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,551.38,374.6,564.53],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[299.39,551.38,374.6,564.53],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0037","type":"paragraph","text":"Không thấy có dị dạng thai hoặc độc lên thai ở một số phụ nữ mang thai dùng triprolidin. Tuy nhiên dữ liệu về tác dụng của thuốc trên phụ nữ mang thai còn ít, chưa đủ để kết luận.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,563.67,553.72,600.73],"source":{"line_count":3}},{"id":"b0038","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,602.92,377.5,616.06],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[299.39,602.92,377.5,616.06],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Thuốc được bài tiết qua sữa mẹ. Chưa có số liệu ghi nhận có ADR đến trẻ bú mẹ khi người mẹ đang cho con bú dùng triprolidin hydroclorid. Có thể dùng thuốc cho mẹ trong thời kỳ cho con bú.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,615.2,553.72,652.27],"source":{"line_count":3}},{"id":"b0040","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,654.45,447.71,667.6],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR) ","bbox":[299.39,654.45,447.71,667.6],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0041","type":"subheading","level":3,"text":"Thường gặp hoặc rất thường gặp","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,666.9,426.24,679.53],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp hoặc rất thường gặp","bbox":[299.39,666.9,426.24,679.53],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0042","type":"paragraph","text":"Toàn thân: buồn ngủ, chóng mặt, mệt mỏi, phối hợp kém.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,678.87,518.02,691.67],"source":{"line_count":1},"spans":[{"text":"Toàn thân: buồn ngủ, chóng mặt, mệt mỏi, phối hợp kém.","bbox":[299.39,678.87,518.02,691.67],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0043","type":"subheading","level":3,"text":"Ít gặp","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,691.17,321.81,703.8],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Ít gặp","bbox":[299.39,691.17,321.81,703.8],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0044","type":"paragraph","text":"Mắt: nhìn mờ.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,703.14,353.76,715.93],"source":{"line_count":1},"spans":[{"text":"Mắt: nhìn mờ.","bbox":[299.39,703.14,353.76,715.93],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0045","type":"paragraph","text":"Tiết niệu: bí tiểu tiện, tiểu tiện ít.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,715.27,424.4,728.07],"source":{"line_count":1},"spans":[{"text":"Tiết niệu: bí tiểu tiện, tiểu tiện ít.","bbox":[299.39,715.27,424.4,728.07],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0046","type":"paragraph","text":"Tiêu hóa: khô miệng, mũi, họng.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,727.4,425.98,740.2],"source":{"line_count":1},"spans":[{"text":"Tiêu hóa: khô miệng, mũi, họng. ","bbox":[299.39,727.4,425.98,740.2],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0047","type":"paragraph","text":"Toàn thân: cảm giác tức ngực, đau đầu.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,739.54,448.58,752.33],"source":{"line_count":1},"spans":[{"text":"Toàn thân: cảm giác tức ngực, đau đầu.","bbox":[299.39,739.54,448.58,752.33],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0048","type":"paragraph","text":"Các tác dụng này là do tác dụng kháng muscarinic của thuốc.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,751.67,532.09,764.47],"source":{"line_count":1},"spans":[{"text":"Các tác dụng này là do tác dụng kháng muscarinic của thuốc.","bbox":[299.39,751.67,532.09,764.47],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0049","type":"subheading","level":3,"text":"Hiếm gặp hoặc rất hiếm gặp","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,763.97,408.36,776.6],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp hoặc rất hiếm gặp","bbox":[299.39,763.97,408.36,776.6],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0050","type":"paragraph","text":"Máu: giảm bạch cầu hạt, giảm bạch cầu trung tính, giảm tiểu cầu, thiếu máu tan huyết.","page":1626,"printed_page":1632,"column":1,"bbox":[299.39,775.94,553.72,800.87],"source":{"line_count":2}},{"id":"b0051","type":"paragraph","text":"Huyết áp: tụt huyết áp tư thế.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,63.32,154.39,76.12],"source":{"line_count":1},"spans":[{"text":"Huyết áp: tụt huyết áp tư thế.","bbox":[43.43,63.32,154.39,76.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0052","type":"paragraph","text":"Thính giác: ù tai.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,75.32,108.35,88.12],"source":{"line_count":1},"spans":[{"text":"Thính giác: ù tai.","bbox":[43.43,75.32,108.35,88.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0053","type":"paragraph","text":"Toàn thân: phản ứng dị ứng và miễn dịch chéo với các thuốc khác.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,87.33,297.77,100.12],"source":{"line_count":1},"spans":[{"text":"Toàn thân: phản ứng dị ứng và miễn dịch chéo với các thuốc khác. ","bbox":[43.43,87.33,297.77,100.12],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0054","type":"paragraph","text":"Hệ TKTW: hưng cảm, bị kích thích, nhất là ở trẻ nhỏ gây mất ngủ, quấy khóc, tim nhanh, run đầu chi, co giật. Làm xuất hiện cơn động kinh ở người có tổn thương khu trú trên vỏ não.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,99.33,297.76,136.13],"source":{"line_count":3}},{"id":"b0055","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,138.19,158.0,151.34],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[43.43,138.19,158.0,151.34],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0056","type":"paragraph","text":"Uống nhiều nước hoặc ngậm đá, ngậm kẹo, để làm giảm khô miệng. Cà phê hoặc chè làm giảm chứng buồn ngủ.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,150.34,297.76,175.14],"source":{"line_count":2}},{"id":"b0057","type":"paragraph","text":"Ngừng thuốc hoặc thay bằng các thuốc kháng histamin thế hệ 2 nếu các triệu chứng nặng và kéo dài.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,174.35,297.76,199.15],"source":{"line_count":2}},{"id":"b0058","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,201.2,143.61,214.35],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[43.43,201.2,143.61,214.35],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0059","type":"paragraph","text":"Cách dùng: Phải uống thuốc lúc no để giảm kích thích lên ống tiêu hóa.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,213.36,297.77,238.16],"source":{"line_count":2}},{"id":"b0060","type":"subheading","level":3,"text":"Liều lượng","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,237.52,85.09,250.16],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Liều lượng","bbox":[43.43,237.52,85.09,250.16],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0061","type":"paragraph","text":"Liều dùng tùy thuộc vào đáp ứng và dung nạp của người bệnh và nên hỏi ý kiến thầy thuốc khi dùng cho trẻ từ 4 tháng tuổi - 6 tuổi.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,249.37,297.77,274.17],"source":{"line_count":2}},{"id":"b0062","type":"paragraph","text":"Liều dùng thông thường như sau:","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,273.37,170.38,286.17],"source":{"line_count":1},"spans":[{"text":"Liều dùng thông thường như sau:","bbox":[43.43,273.37,170.38,286.17],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0063","type":"paragraph","text":"Người lớn và trẻ trên 12 tuổi (dùng dạng viên nén): 2,5 mg, 4 - 6 giờ một lần; tối đa 10 mg/ngày.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,285.37,297.77,310.17],"source":{"line_count":2}},{"id":"b0064","type":"paragraph","text":"Trẻ em 6 - 12 tuổi (dùng dạng sirô): 1,25 mg (1 thìa cà phê ), 4 - 6 giờ một lần; tối đa 5 mg/ngày.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,309.38,297.76,334.18],"source":{"line_count":2}},{"id":"b0065","type":"paragraph","text":"Trẻ em 4 - dưới 6 tuổi (dùng dạng sirô): 0,938 mg (3/4 thìa cà phê), 4 - 6 giờ một lần; tối đa là 3,744 mg/ngày.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,333.23,297.76,358.19],"source":{"line_count":2}},{"id":"b0066","type":"paragraph","text":"Trẻ em 2 - dưới 4 tuổi (dùng dạng sirô): 0,625 mg (1/2 thìa cà phê), 4 - 6 giờ một lần; tối đa là 2,5 mg/ngày.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,357.39,297.76,382.19],"source":{"line_count":2}},{"id":"b0067","type":"paragraph","text":"Trẻ em 4 tháng - dưới 2 tuổi (dùng dạng sirô): 0,313 mg (1/4 thìa cà phê), 4 - 6 giờ một lần; tối đa là 1,25 mg/ngày (5 ml).","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,381.4,297.76,406.2],"source":{"line_count":2}},{"id":"b0068","type":"paragraph","text":"Khi dùng chế phẩm phối hợp triprolidin hydroclorid với thuốc khác (ví dụ với pseudoephedrin hydroclorid) liều dùng được tính như khi dùng triprolidin hydroclorid đơn độc.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,405.4,297.76,442.21],"source":{"line_count":3}},{"id":"b0069","type":"heading","level":2,"text":"Tương tác thuốc","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,444.26,110.34,457.41],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[43.43,444.26,110.34,457.41],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0070","type":"paragraph","text":"Triprolidin cũng như các thuốc kháng histamin khác, đều làm tăng tác dụng của các thuốc ức chế hệ TKTW như rượu, các barbituric, thuốc ngủ, các opioid, các thuốc an thần và thuốc liệt thần kinh.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,456.42,297.77,493.22],"source":{"line_count":3}},{"id":"b0071","type":"paragraph","text":"Không dùng đồng thời các thuốc này với triprolidin.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,492.43,242.15,505.22],"source":{"line_count":1},"spans":[{"text":"Không dùng đồng thời các thuốc này với triprolidin.","bbox":[43.43,492.43,242.15,505.22],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0072","type":"paragraph","text":"Các thuốc ức chế monoaminoxydase (IMAO) có thể làm tăng tác dụng kháng muscarin của triprolidin và của thuốc kháng histamin khác.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,504.43,297.79,529.23],"source":{"line_count":2}},{"id":"b0073","type":"paragraph","text":"Thuốc kháng histamin như triprolidin có tác dụng hiệp đồng với các thuốc kháng muscarin như atropin, thuốc chống trầm cảm ba vòng và các hợp chất tương tự.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,528.43,297.77,565.24],"source":{"line_count":3}},{"id":"b0074","type":"paragraph","text":"5-HTP, GABA, lá Cỏ ban, melatonin, cây Nữ lang làm tăng tác dụng gây ngủ của triprolidin. Cần thận trọng khi dùng đồng thời các thuốc này.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,564.44,297.77,601.25],"source":{"line_count":3}},{"id":"b0075","type":"heading","level":2,"text":"Quá liều và xử trí","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,603.3,115.11,616.45],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[43.43,603.3,115.11,616.45],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0076","type":"paragraph","text":"Triệu chứng: Là các triệu chứng hệ TKTW bị ức chế hoặc bị kích thích, huyết áp hạ rất thấp, khó thở, co giật, mất ý thức, rất khô ở miệng, mũi, họng, sốt cao, co giật.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,615.46,297.76,652.26],"source":{"line_count":3}},{"id":"b0077","type":"paragraph","text":"Xử trí: Ngừng dùng thuốc ngay. Nếu có thể: Gây nôn, uống than hoạt.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,651.46,295.4,664.26],"source":{"line_count":1},"spans":[{"text":"Xử trí","bbox":[43.43,651.63,64.9,664.26],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":": Ngừng dùng thuốc ngay. Nếu có thể: Gây nôn, uống than hoạt.","bbox":[64.72,651.46,295.4,664.26],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0078","type":"paragraph","text":"Điều trị triệu chứng và hỗ trợ.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,663.47,157.3,676.26],"source":{"line_count":1},"spans":[{"text":"Điều trị triệu chứng và hỗ trợ.","bbox":[43.43,663.47,157.3,676.26],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0079","type":"paragraph","text":"Cập nhật lần cuối: 2019.","page":1627,"printed_page":1633,"column":0,"bbox":[43.43,677.87,141.07,690.5],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2019. ","bbox":[43.43,677.87,141.07,690.5],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"triprolidin-hydroclorid","title":"TRIPROLIDIN HYDROCLORID","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006","b0007","b0008","b0009","b0010"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0011","blocks":["b0012","b0013","b0014","b0015"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0016","blocks":["b0017","b0018"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0019","blocks":["b0020"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0021","blocks":["b0022","b0023","b0024","b0025","b0026","b0027","b0028","b0029","b0030","b0031","b0032","b0033","b0034","b0035"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0036","blocks":["b0037"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0038","blocks":["b0039"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0040","blocks":["b0041","b0042","b0043","b0044","b0045","b0046","b0047","b0048","b0049","b0050","b0051","b0052","b0053","b0054"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0055","blocks":["b0056","b0057"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0058","blocks":["b0059","b0060","b0061","b0062","b0063","b0064","b0065","b0066","b0067","b0068"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0069","blocks":["b0070","b0071","b0072","b0073","b0074"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0075","blocks":["b0076","b0077","b0078","b0079"]}],"quality":{"block_count":79,"heading_count":13,"subheading_count":4,"paragraph_count":60,"list_count":1,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}