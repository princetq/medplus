    },
    {
      "id": "b0012",
      "type": "paragraph",
      "text": "Thuốc hấp thu nhanh sau khi tiêm bắp, nồng độ đỉnh trong huyết tương đạt được sau 20 - 30 phút. Khi dùng với tác dụng cầm máu sau đẻ, tác dụng xuất hiện sau 45 phút.",
      "page": 366,
      "printed_page": 372,
      "column": 0,
      "bbox": [
        43.43,
        165.52,
        297.77,
        203.11
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0013",
      "type": "paragraph",
      "text": "Chuyển hóa chủ yếu qua con đường ω-oxi hóa.",
      "page": 366,
      "printed_page": 372,
      "column": 0,
      "bbox": [
        43.43,
