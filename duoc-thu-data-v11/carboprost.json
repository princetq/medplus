    },
    {
      "id": "b0016",
      "type": "paragraph",
      "text": "Chấm dứt thai kỳ: Trong vòng 3 tháng giữa thai kỳ (tuần 13 - 20).",
      "page": 366,
      "printed_page": 372,
      "column": 0,
      "bbox": [
        43.43,
        255.31,
        297.76,
        268.11
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Chấm dứt thai kỳ: Trong vòng 3 tháng giữa thai kỳ (tuần 13 - 20). ",
          "bbox": [
            43.43,
            255.31,
            297.76,
