      "type": "heading",
      "level": 2,
      "text": "Tương tác thuốc",
      "page": 366,
      "printed_page": 372,
      "column": 1,
      "bbox": [
        307.38,
        200.21,
        374.29,
        213.36
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
