    {
      "id": "b0008",
      "type": "paragraph",
      "text": "Carboprost là dẫn chất tổng hợp của prostaglandin có tác dụng kích",
      "page": 365,
      "printed_page": 371,
      "column": 1,
      "bbox": [
        299.39,
        788.07,
        553.72,
        800.87
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Carboprost là dẫn chất tổng hợp của prostaglandin có tác dụng kích ",
          "bbox": [
            299.39,
            788.07,
            553.72,
            800.87
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0009",
      "type": "paragraph",
      "text": "thích co cơ trơn tử cung, có tác dụng cầm máu sau đẻ hoặc gây sảy thai. Cơ chế phân tử chưa hoàn toàn được biết rõ.",
      "page": 366,
      "printed_page": 372,
      "column": 0,
      "bbox": [
        43.43,
        63.32,
        297.76,
        88.52
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0010",
      "type": "paragraph",
      "text": "Có tác dụng kích thích cơ trơn đường tiêu hóa, có thể dẫn đến nôn và/hoặc tiêu chảy. Trên động vật thí nghiệm, carboprost tromethamin với liều cao có thể gây tăng huyết áp, do co thắt cơ trơn mạch máu. Ở một số bệnh nhân, có thể gây co thắt phế quản thoáng qua.",
      "page": 366,
      "printed_page": 372,
      "column": 0,
      "bbox": [
        43.43,
        88.12,
        297.77,
        150.51
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0011",
      "type": "heading",
      "level": 2,
      "text": "Dược động học",
      "page": 366,
      "printed_page": 372,
      "column": 0,
      "bbox": [
        43.43,
        152.96,
        104.54,
        166.11
      ],
