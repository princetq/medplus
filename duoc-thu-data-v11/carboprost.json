    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Không nên dùng đồng thời với oxytocin, ergometrin vì có thể làm tăng tác động lên tử cung.",
      "page": 366,
      "printed_page": 372,
      "column": 1,
      "bbox": [
        307.38,
        212.56,
        561.71,
        237.56
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0046",
      "type": "heading",
      "level": 2,
      "text": "Quá liều và xử trí",
      "page": 366,
      "printed_page": 372,
      "column": 1,
      "bbox": [
        307.38,
        239.81,
        379.06,
        252.96
      ],
      "style": {
