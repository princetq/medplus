    {
      "id": "b0022",
      "type": "paragraph",
      "text": "Độc tính của natamycin có vẻ thấp khi dùng tại chỗ. Do kinh nghiệm lâm sàng còn hạn chế khi dùng hỗn dịch natamycin nhỏ mắt nên cần giám sát ADR trên người bệnh ít nhất 2 lần mỗi tuần.",
      "page": 1167,
      "printed_page": 1173,
      "column": 0,
      "bbox": [
        43.43,
        339.99,
        297.77,
        376.85
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0023",
      "type": "paragraph",
      "text": "Nếu có dấu hiệu nhiễm độc hoặc dị ứng, phải ngừng thuốc ngay.",
      "page": 1167,
      "printed_page": 1173,
      "column": 0,
      "bbox": [
        43.43,
        376.08,
        288.44,
        388.87
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Nếu có dấu hiệu nhiễm độc hoặc dị ứng, phải ngừng thuốc ngay.",
          "bbox": [
            43.43,
            376.08,
            288.44,
            388.87
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
