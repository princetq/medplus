          "italic": false
        }
      ]
    },
    {
      "id": "b0024",
      "type": "paragraph",
      "text": "Không được tiêm vào mắt.",
      "page": 1167,
      "printed_page": 1173,
      "column": 0,
      "bbox": [
        43.43,
        388.1,
        145.17,
        400.9
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Không được tiêm vào mắt.",
          "bbox": [
