      ]
    },
    {
      "id": "b0031",
      "type": "paragraph",
      "text": "Chưa có bằng chứng về sự an toàn khi sử dụng sản phẩm.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
