          "italic": false
        }
      ]
    },
    {
      "id": "b0035",
      "type": "paragraph",
      "text": "Dung dịch hydrogen peroxyd đậm đặc có thể gây tổn thương mô.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        179.71,
        535.84,
        192.51
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Dung dịch hydrogen peroxyd đậm đặc có thể gây tổn thương mô.",
          "bbox": [
            298.88,
            179.71,
            535.84,
            192.51
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0036",
      "type": "paragraph",
      "text": "Dung dịch hydrogen peroxyd có thể gây kích ứng, “bỏng” da và niêm mạc.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        192.01,
        553.23,
        217.11
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0037",
      "type": "paragraph",
      "text": "Khi sử dụng nhắc lại nhiều lần, đặc biệt trong thời gian dài làm thuốc súc miệng hoặc rửa miệng, hydrogen peroxyd có thể gây phì đại nhú lưỡi (có thể hồi phục được).",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        216.61,
        553.22,
        254.01
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Sẽ nguy hiểm khi tiêm hoặc nhỏ hydrogen peroxyd vào những khoang kín của cơ thể, do oxy giải phóng ra không có đường thoát.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        253.51,
        553.21,
        278.6
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0039",
      "type": "paragraph",
      "text": "Thụt đại tràng bằng dung dịch hydrogen peroxyd đã gây ra tắc mạch do khí, vỡ đại tràng, viêm trực tràng, viêm loét đại tràng và hoại tử ruột.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        278.11,
        553.22,
        315.5
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0040",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        320.85,
        399.06,
        334.0
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng và cách dùng",
          "bbox": [
            298.88,
            320.85,
            399.06,
            334.0
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0041",
      "type": "subheading",
      "level": 3,
      "text": "Cách dùng",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        333.38,
        341.91,
        346.1
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
        ]
      },
      "spans": [
        {
          "text": "Cách dùng",
          "bbox": [
            298.88,
            333.38,
            341.91,
            346.1
          ],
          "font": "TimesNewRomanPS-BoldItal",
          "fontsize": 9.5,
          "flags": 22,
          "bold": true,
          "italic": true
        }
      ]
    },
    {
      "id": "b0042",
      "type": "paragraph",
      "text": "Thuốc dùng ngoài. Không được tiêm hoặc uống. Dùng cho trẻ em dưới 12 tuổi phải có sự giám sát của người lớn.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        345.6,
        553.21,
        370.7
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0043",
      "type": "paragraph",
      "text": "Dùng ngoài: Bôi một lượng nhỏ thuốc lên vùng da bị bệnh. Để khô trước khi băng vết thương.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        370.2,
        553.21,
        395.3
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0044",
      "type": "paragraph",
      "text": "Dùng đường miệng: Không nên tự sử dụng hydrogen peroxyd để rửa hoặc súc miệng trong thời gian dài, không dùng quá 7 ngày nếu không có chỉ định của thầy thuốc. Không được nuốt thuốc.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        394.8,
        553.21,
        432.19
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0045",
      "type": "subheading",
      "level": 3,
      "text": "Liều dùng",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        431.77,
        339.27,
        444.49
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
        ]
      },
      "spans": [
        {
          "text": "Liều dùng",
          "bbox": [
            298.88,
            431.77,
            339.27,
            444.49
          ],
          "font": "TimesNewRomanPS-BoldItal",
          "fontsize": 9.5,
          "flags": 22,
          "bold": true,
          "italic": true
        }
      ]
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Để làm sạch vết thương hoặc vết loét trên da: Thường dùng dung dịch hydrogen peroxyd 3%, có thể dùng đến dung dịch 6%.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        444.0,
        553.21,
        469.09
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0047",
      "type": "paragraph",
      "text": "Kem 1% dùng cho nhiễm khuẩn da: Bôi 2 - 3 lần/ngày, trong thời gian đến 3 tuần.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        468.59,
        553.22,
        493.69
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0048",
      "type": "paragraph",
      "text": "Để súc miệng trong điều trị viêm miệng cấp hoặc khử mùi hôi của miệng:",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        493.19,
        553.24,
        518.29
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0049",
      "type": "paragraph",
      "text": "Dùng dung dịch hydrogen peroxyd 1,5% (không cần pha loãng), súc miệng về phía tổn thương khoảng 10 ml, để ít nhất 1 phút trước khi nhổ ra, có thể dùng tới 4 lần/ngày (sau khi ăn và lúc đi ngủ); hoặc pha loãng 15 ml dung dịch hydrogen peroxyd 6% với một nửa cốc nước ấm, súc miệng 2 - 3 lần/ngày, trong khoảng 2 - 3 phút.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        517.79,
        553.22,
        579.78
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0050",
      "type": "paragraph",
      "text": "Dùng cho trẻ dưới 2 tuổi phải có chỉ định của bác sĩ.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        579.29,
        498.24,
        592.08
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Dùng cho trẻ dưới 2 tuổi phải có chỉ định của bác sĩ.",
          "bbox": [
            298.88,
            579.29,
            498.24,
            592.08
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0051",
      "type": "paragraph",
      "text": "Gel hydrogen peroxyd 1,5% để làm sạch những vết thương nhỏ ở miệng hoặc lợi: Bôi một lượng nhỏ thuốc vào vùng bị bệnh, để yên ít nhất 1 phút, sau đó khạc nhổ ra. Có thể bôi đến 4 lần/ngày (sau khi ăn và lúc đi ngủ) hoặc theo chỉ dẫn của thầy thuốc.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        591.59,
        553.22,
        641.28
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0052",
      "type": "paragraph",
      "text": "Dung dịch hydrogen peroxyd nhỏ tai để lấy ráy tai, thường pha loãng 1 phần dung dịch hydrogen peroxyd 6% với 3 phần nước trước khi dùng.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        640.78,
        553.21,
        678.18
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0053",
      "type": "heading",
      "level": 2,
      "text": "Tương kỵ",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        683.53,
        338.62,
        696.68
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tương kỵ",
          "bbox": [
            298.88,
            683.53,
            338.62,
            696.68
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0054",
      "type": "paragraph",
      "text": "Dung dịch hydrogen peroxyd tương kỵ với các tác nhân khử, bao gồm các chất hữu cơ, các chất có khả năng oxy hóa và với một số kim loại, muối kim loại, kiềm, các iodid, các muối permanganat và chất oxy hóa mạnh hơn.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        695.98,
        553.21,
        745.67
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0055",
      "type": "heading",
      "level": 2,
      "text": "Quá liều và xử trí",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        751.02,
        370.56,
        764.17
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Quá liều và xử trí",
          "bbox": [
            298.88,
            751.02,
            370.56,
            764.17
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0056",
      "type": "paragraph",
      "text": "Triệu chứng: Nuốt phải một lượng nhỏ hydrogen peroxyd 3% thường chỉ gây rối loạn tiêu hóa nhẹ. Uống phải dung dịch 10% hoặc cao hơn hoặc một lượng lớn dung dịch 3% có thể thấy tai biến, thậm",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        763.47,
        553.21,
        800.87
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0057",
      "type": "paragraph",
      "text": "chí tử vong. Kích ứng đường tiêu hóa như nôn, buồn nôn, sùi bọt mép, nôn ra máu có thể xuất hiện. Mụn nước hoặc bỏng niêm mạc thường xuất hiện với dung dịch 30% hoặc cao hơn. Sự giải phóng một khối lượng lớn oxygen ở dạ dày có thể gây đau dạ đày, đầy bụng, ợ hơi. Ngừng thở, hôn mê, co giật, lú lẫn, xanh tím, ngủ lịm, thở rít, ngừng hô hấp, tuần hoàn đã được báo cáo. Tắc mạch do khí đặc biệt nguy hiểm khi dùng dung dịch đậm đặc. Tổn thương thần kinh ở trẻ em và người lớn có thể xảy ra ngay lập tức và gây tử vong sau khi uống dung dịch 35%. Bôi ngoài da dung dịch đậm đặc cũng có thể gây mụn nước, ban đỏ, hoại tử từng vùng trên da và ban xuất huyết. Nồng độ trên 10% có thể gây loét hoặc thủng giác mạc khi để tiếp xúc với mắt.",
      "page": 870,
      "printed_page": 876,
      "column": 0,
      "bbox": [
        43.94,
        63.32,
        298.27,
        212.58
      ],
