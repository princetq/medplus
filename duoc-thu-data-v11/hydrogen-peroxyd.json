        }
      ]
    },
    {
      "id": "b0033",
      "type": "paragraph",
      "text": "Chưa có bằng chứng về nguy cơ cho trẻ sơ sinh khi người mẹ sử dụng hydrogen peroxyd trong thời kỳ cho con bú. Cân nhắc các lợi ích và nguy cơ tiềm ẩn trước khi dùng thuốc.",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        124.52,
        553.21,
        161.91
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0034",
      "type": "heading",
      "level": 2,
      "text": "Tác dụng không mong muốn (ADR)",
      "page": 869,
      "printed_page": 875,
      "column": 1,
      "bbox": [
        298.88,
        167.26,
        444.83,
        180.41
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tác dụng không mong muốn (ADR)",
          "bbox": [
            298.88,
