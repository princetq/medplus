{"schema_version":"11.0.0-alpha.1","id":"proparacain-hydroclorid","title":"Proparacain Hydroclorid","aliases":["Proparacain Hydroclorid","Proparacain Hydrochloride"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":1369,"end":1370},"printed_pages":{"start":1375,"end":1376},"extraction":{"start_title_pdf_page":1369,"start_column":"right","start_y":187.4415283203125,"next_title_pdf_page":1370,"next_column":"left","next_y":367.0622253417969,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"PROPARACAIN HYDROCLORID","page":1369,"printed_page":1375,"column":1,"bbox":[356.65,187.44,510.06,201.28],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"PROPARACAIN HYDROCLORID","bbox":[356.65,187.44,510.06,201.28],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"heading","level":2,"text":"(Proxymetacain hydroclorid)","page":1369,"printed_page":1375,"column":1,"bbox":[372.57,201.85,494.15,215.69],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["MinionPro-Bold"]},"spans":[{"text":"(Proxymetacain hydroclorid)","bbox":[372.57,201.85,494.15,215.69],"font":"MinionPro-Bold","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Tên chung quốc tế: Proxymetacaine hydrochloride, Proparacaine hydrochloride.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,219.29,561.72,244.35],"source":{"line_count":2}},{"id":"b0004","type":"paragraph","text":"Mã ATC: S01HA04.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,243.0,388.22,256.14],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[307.39,243.0,347.84,256.14],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"S01HA04.","bbox":[347.84,243.15,388.22,255.94],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"paragraph","text":"Loại thuốc: Thuốc gây tê tại chỗ, thuốc nhãn khoa.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,254.58,503.96,267.73],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[307.39,254.58,356.47,267.73],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Thuốc gây tê tại chỗ, thuốc nhãn khoa.","bbox":[356.47,254.74,503.96,267.53],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0006","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,266.51,414.68,279.66],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng ","bbox":[307.39,266.51,414.68,279.66],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0007","type":"paragraph","text":"Dung dịch nhỏ mắt: 0,5%.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,278.75,407.66,291.55],"source":{"line_count":1},"spans":[{"text":"Dung dịch nhỏ mắt: 0,5%.","bbox":[307.39,278.75,407.66,291.55],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0008","type":"heading","level":2,"text":"Dược lực học","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,293.69,360.98,306.83],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[307.39,293.69,360.98,306.83],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0009","type":"paragraph","text":"Tương tự các thuốc gây tê tại chỗ khác, proparacain có tác dụng gây tê theo cơ chế giảm tính thấm trên màng tế bào thần kinh với ion Na+, do vậy ức chế có hồi phục việc khởi phát và dẫn truyền xung động thần kinh. Sau khi nhỏ mắt dung dịch proparacain 0,5% tác dụng gây tê xuất hiện trong vòng 20 giây, thời gian gây tê kéo dài 10 - 20 phút.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,305.93,561.72,374.17],"source":{"line_count":6}},{"id":"b0010","type":"heading","level":2,"text":"Dược động học","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,375.98,368.49,389.13],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[307.39,375.98,368.49,389.13],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0011","type":"paragraph","text":"Thuốc dễ bị hấp thu vào hệ thống tuần hoàn chung. Tương tự các thuốc gây tê tại chỗ có bản chất ester, thuốc bị thủy phân bởi esterase trong huyết tương. Thuốc cũng bị chuyển hóa tại gan.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,388.22,561.72,425.2],"source":{"line_count":3}},{"id":"b0012","type":"heading","level":2,"text":"Chỉ định","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,427.34,343.03,440.48],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[307.39,427.34,343.03,440.48],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0013","type":"paragraph","text":"Gây tê tại mắt để đo nhãn áp, soi góc tiền phòng, loại bỏ chỉ khâu, dị vật khỏi kết, giác mạc, phẫu thuật ngắn liên quan đến giác mạc và kết mạc.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,439.58,561.72,476.55],"source":{"line_count":3}},{"id":"b0014","type":"heading","level":2,"text":"Chống chỉ định","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,478.69,369.69,491.84],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[307.39,478.69,369.69,491.84],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0015","type":"paragraph","text":"Mẫn cảm với proparacain.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,490.93,407.38,503.73],"source":{"line_count":1},"spans":[{"text":"Mẫn cảm với proparacain.","bbox":[307.39,490.93,407.38,503.73],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Trẻ sinh non có hệ enzym chuyển hóa các thuốc gây tê tại chỗ loại ester chưa hoàn thiện.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,502.52,561.72,526.91],"source":{"line_count":2}},{"id":"b0017","type":"note","level":2,"text":"Thận trọng","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,531.55,353.57,544.7],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[307.39,531.55,353.57,544.7],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0018","type":"paragraph","text":"Thận trọng khi sử dụng thuốc trên các bệnh nhân có bệnh lí dị ứng, bệnh tim mạch hoặc cường giáp do thuốc có thể làm tăng nguy cơ phản ứng quá mẫn.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,543.29,561.72,579.27],"source":{"line_count":3}},{"id":"b0019","type":"paragraph","text":"Không sử dụng thuốc trong thời gian dài. Sử dụng thường xuyên và kéo dài các chế phẩm thuốc tê nhỏ mắt có thể dẫn đến làm chậm liền vết thương, làm mềm và lắng cặn trên giác mạc, đục giác mạc đi kèm giảm thị lực.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,578.06,561.72,625.62],"source":{"line_count":4}},{"id":"b0020","type":"paragraph","text":"Bảo vệ mắt khỏi sự cọ xát, hóa chất kích ứng và dị vật trong suốt quá trình gây tê. Tránh chạm vào mắt đến khi thuốc tê hết tác dụng.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,624.41,561.72,648.8],"source":{"line_count":2}},{"id":"b0021","type":"paragraph","text":"Để giảm lượng thuốc hấp thu toàn thân, cần dùng ngón tay ấn trên túi lệ trong 1 phút sau khi nhỏ thuốc.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,647.59,561.72,671.98],"source":{"line_count":2}},{"id":"b0022","type":"paragraph","text":"Thận trọng khi nhỏ thuốc trên các mắt bị viêm do tình trạng sung huyết có thể làm tăng tỷ lệ thuốc hấp thu toàn thân qua kết mạc.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,670.77,561.72,695.16],"source":{"line_count":2}},{"id":"b0023","type":"heading","level":2,"text":"Thời kỳ mang thai","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,699.8,382.6,712.95],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[307.39,699.8,382.6,712.95],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0024","type":"paragraph","text":"Chưa đủ dữ liệu chứng minh tính an toàn của thuốc trên phụ nữ mang thai. Không nên sử dụng thuốc trên phụ nữ mang thai trừ khi thật cần thiết.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,711.54,561.72,747.51],"source":{"line_count":3}},{"id":"b0025","type":"heading","level":2,"text":"Thời kỳ cho con bú","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,752.15,385.5,765.3],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ cho con bú","bbox":[307.39,752.15,385.5,765.3],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0026","type":"paragraph","text":"Chưa đủ dữ liệu chứng minh tính an toàn của thuốc trên phụ nữ cho con bú. Không nên sử dụng thuốc trên phụ nữ cho con bú trừ khi thật cần thiết.","page":1369,"printed_page":1375,"column":1,"bbox":[307.39,763.89,561.72,800.87],"source":{"line_count":3}},{"id":"b0027","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,63.02,181.38,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[35.43,63.02,181.38,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0028","type":"subheading","level":3,"text":"Hiếm gặp","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,75.5,72.64,88.13],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Hiếm gặp","bbox":[35.43,75.5,72.64,88.13],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0029","type":"paragraph","text":"Mắt: giãn đồng tử, liệt thể mi, kích ứng kết mạc, sung huyết kết mạc, lắng cặn trên giác mạc, phản ứng quá mẫn tức thì trên giác mạc bao gồm viêm giác mạc biểu mô lan tỏa cấp, vùng biểu mô hoại tử bong vảy diện tích lớn, các sợi trên giác mạc (corneal filaments) và đôi khi viêm mống mắt.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,87.5,289.77,148.96],"source":{"line_count":5}},{"id":"b0030","type":"paragraph","text":"Da: viêm da dị ứng do tiếp xúc với biểu hiện khô và nứt đầu ngón tay.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,148.33,287.42,161.13],"source":{"line_count":1},"spans":[{"text":"Da: viêm da dị ứng do tiếp xúc với biểu hiện khô và nứt đầu ngón tay.","bbox":[35.43,148.33,287.42,161.13],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0031","type":"paragraph","text":"TKTW: kích thích kèm theo trầm cảm.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,160.5,183.1,173.3],"source":{"line_count":1},"spans":[{"text":"TKTW: kích thích kèm theo trầm cảm.","bbox":[35.43,160.5,183.1,173.3],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0032","type":"heading","level":2,"text":"Hướng dẫn cách xử trí ADR","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,175.51,150.0,188.66],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Hướng dẫn cách xử trí ADR","bbox":[35.43,175.51,150.0,188.66],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0033","type":"paragraph","text":"Ngừng thuốc nếu xuất hiện các ADR nặng hoặc các triệu chứng trầm trọng hơn.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,187.83,289.76,212.8],"source":{"line_count":2}},{"id":"b0034","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,215.01,135.61,228.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[35.43,215.01,135.61,228.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0035","type":"paragraph","text":"Người lớn và trẻ em (0 - 18 tuổi):","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,227.33,163.04,240.13],"source":{"line_count":1},"spans":[{"text":"Người lớn và trẻ em (0 - 18 tuổi):","bbox":[35.43,227.33,163.04,240.13],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0036","type":"paragraph","text":"Phẫu thuật ngắn tại giác mạc và kết mạc: Nhỏ 1 giọt vào mắt mỗi 5 - 10 phút, 5 - 7 liều.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,239.5,289.76,264.46],"source":{"line_count":2}},{"id":"b0037","type":"paragraph","text":"Đo nhãn áp, soi góc tiền phòng, loại bỏ dị vật khỏi giác mạc: Nhỏ 1 - 2 giọt vào mắt ngay trước khi tiến hành các quá trình trên.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,263.83,289.76,288.79],"source":{"line_count":2}},{"id":"b0038","type":"paragraph","text":"Loại bỏ chỉ khâu khỏi giác mạc: Nhỏ 1 - 2 giọt vào mắt, 2 - 3 phút trước khi tiến hành.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,288.16,289.77,313.13],"source":{"line_count":2}},{"id":"b0039","type":"paragraph","text":"Bệnh nhân suy gan, suy thận: Không cần hiệu chỉnh liều.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,312.5,252.33,325.29],"source":{"line_count":1},"spans":[{"text":"Bệnh nhân suy gan, suy thận: Không cần hiệu chỉnh liều.","bbox":[35.43,312.5,252.33,325.29],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0040","type":"paragraph","text":"Cập nhật lần cuối: 2019.","page":1370,"printed_page":1376,"column":0,"bbox":[35.43,330.23,130.7,342.86],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2019.","bbox":[35.43,330.23,130.7,342.86],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"proparacain-hydroclorid","title":"PROPARACAIN HYDROCLORID","heading_block":"b0001","blocks":[]},{"id":"proxymetacain-hydroclorid","title":"(Proxymetacain hydroclorid)","heading_block":"b0002","blocks":["b0003","b0004","b0005"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0006","blocks":["b0007"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0008","blocks":["b0009"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0010","blocks":["b0011"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0012","blocks":["b0013"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0014","blocks":["b0015","b0016","b0017","b0018","b0019","b0020","b0021","b0022"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0023","blocks":["b0024"]},{"id":"thoi-ky-cho-con-bu","title":"Thời kỳ cho con bú","heading_block":"b0025","blocks":["b0026"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0027","blocks":["b0028","b0029","b0030","b0031"]},{"id":"huong-dan-cach-xu-tri-adr","title":"Hướng dẫn cách xử trí ADR","heading_block":"b0032","blocks":["b0033"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0034","blocks":["b0035","b0036","b0037","b0038","b0039","b0040"]}],"quality":{"block_count":40,"heading_count":12,"subheading_count":1,"paragraph_count":26,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}