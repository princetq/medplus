    {
      "id": "b0025",
      "type": "paragraph",
      "text": "Thận trọng dùng cho người hay bị sặc, người có rối loạn điện giải hay mất nước, huyết áp thấp. Không nên dùng than hoạt khi nhu động ruột giảm, có nguy cơ tắc ruột.",
      "page": 1556,
      "printed_page": 1562,
      "column": 0,
      "bbox": [
        35.43,
        214.93,
        289.77,
        251.99
      ],
      "source": {
