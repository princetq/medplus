      }
    },
    {
      "id": "b0017",
      "type": "paragraph",
      "text": "Không bôi lên da bị thương hoặc bị nhiễm trùng.",
      "page": 278,
      "printed_page": 284,
      "column": 0,
      "bbox": [
        43.43,
        451.88,
        229.35,
        464.67
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Không bôi lên da bị thương hoặc bị nhiễm trùng.",
          "bbox": [
            43.43,
            451.88,
            229.35,
            464.67
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0018",
      "type": "paragraph",
      "text": "Thường không khuyến cáo dùng thuốc cho trẻ em. Trường hợp phải dùng thuốc cho trẻ nhỏ và trẻ em nên hòa loãng thuốc để tránh kích ứng da (thường hòa loãng 60 ml hoặc 90 ml dạng nhũ tương dùng ngoài (lotion) 28% thành 120 ml hoặc 180 ml bằng nước sạch, lắc đều trước khi dùng).",
      "page": 278,
      "printed_page": 284,
      "column": 0,
      "bbox": [
        43.43,
        463.92,
        297.77,
        524.9
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0019",
      "type": "paragraph",
      "text": "Khi điều trị nhắc lại thường xuyên có thể gây viêm da tiếp xúc.",
      "page": 278,
      "printed_page": 284,
      "column": 0,
      "bbox": [
        43.43,
        524.14,
        283.69,
        536.94
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Khi điều trị nhắc lại thường xuyên có thể gây viêm da tiếp xúc.",
