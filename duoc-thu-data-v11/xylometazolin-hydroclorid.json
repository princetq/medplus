        297.76,
        318.66
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0035",
      "type": "heading",
      "level": 2,
      "text": "Tác dụng không mong muốn (ADR)",
      "page": 1711,
      "printed_page": 1717,
      "column": 0,
      "bbox": [
        43.43,
        320.84,
        189.38,
        333.99
      ],
      "style": {
