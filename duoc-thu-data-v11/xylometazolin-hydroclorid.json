          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Chưa rõ xylometazolin có tiết vào sữa mẹ không. Thận trọng khi dùng thuốc cho người mẹ đang cho con bú.",
      "page": 1711,
      "printed_page": 1717,
      "column": 0,
      "bbox": [
        43.43,
