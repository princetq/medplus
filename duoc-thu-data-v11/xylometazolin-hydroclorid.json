          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0032",
      "type": "paragraph",
      "text": "Chưa rõ ảnh hưởng của xylometazolin trên bào thai. Chỉ nên dùng thuốc này khi thật cần thiết.",
      "page": 1711,
      "printed_page": 1717,
      "column": 0,
      "bbox": [
        43.43,
        254.32,
        297.76,
        279.25
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0033",
      "type": "heading",
      "level": 2,
      "text": "Thời kỳ cho con bú",
      "page": 1711,
      "printed_page": 1717,
      "column": 0,
      "bbox": [
        43.43,
        281.44,
        121.55,
        294.59
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
