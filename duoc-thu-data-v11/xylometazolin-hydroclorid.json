        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Hướng dẫn cách xử trí ADR",
          "bbox": [
            43.43,
            505.85,
            158.0,
            518.99
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0043",
      "type": "paragraph",
      "text": "Với các triệu chứng nhẹ, chỉ cần theo dõi và thường tự hết. Đặc biệt chú ý khi xảy ra phản ứng do hấp thu toàn thân, chủ yếu là điều trị triệu chứng và hỗ trợ. Tiêm tĩnh mạch phentolamin có thể có hiệu quả trong điều trị ADR nặng do thuốc.",
      "page": 1711,
      "printed_page": 1717,
      "column": 0,
      "bbox": [
        43.43,
        518.13,
        297.77,
        567.33
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0044",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
