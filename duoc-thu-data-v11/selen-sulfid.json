        }
      ]
    },
    {
      "id": "b0027",
      "type": "paragraph",
      "text": "Thuốc bài tiết vào sữa mẹ. Ảnh hưởng của thuốc đến con còn chưa biết rõ.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        440.71,
        553.72,
        465.59
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0028",
      "type": "heading",
      "level": 2,
      "text": "Tác dụng không mong muốn (ADR)",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        467.72,
        445.33,
        480.87
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Tác dụng không mong muốn (ADR)",
          "bbox": [
            299.39,
            467.72,
            445.33,
            480.87
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0029",
      "type": "paragraph",
      "text": "Độc tính rất thấp nếu hạn chế được sự hấp thu vào cơ thể. Mức độ nặng theo trình tự giảm dần như sau: kích ứng da, đôi khi tăng rụng tóc; biến màu tóc (có thể tránh hoặc giảm thiểu bằng cách gội đầu thật kỹ sau điều trị). Có thể xảy ra nhờn hoặc khô tóc và da đầu.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        479.96,
        553.72,
        529.01
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0030",
      "type": "paragraph",
      "text": "Phát ban và nổi mề đay đã được báo cáo nhưng hiếm gặp.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        528.3,
        519.19,
        541.09
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Phát ban và nổi mề đay đã được báo cáo nhưng hiếm gặp.",
          "bbox": [
            299.39,
            528.3,
            519.19,
            541.09
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0031",
      "type": "heading",
      "level": 2,
      "text": "Hướng dẫn cách xử trí ADR",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        543.23,
        413.95,
        556.38
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Hướng dẫn cách xử trí ADR",
          "bbox": [
            299.39,
            543.23,
            413.95,
            556.38
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0032",
      "type": "paragraph",
      "text": "Nếu có dị ứng, phải ngừng thuốc ngay.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        555.47,
        447.05,
        568.26
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Nếu có dị ứng, phải ngừng thuốc ngay.",
          "bbox": [
            299.39,
            555.47,
            447.05,
            568.26
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0033",
      "type": "paragraph",
      "text": "Tránh thuốc tiếp xúc vào mắt hoặc với vùng sinh dục và các chỗ da có nếp gấp vì có thể gây kích ứng và nóng bừng. Khi xảy ra, cần rửa kỹ bằng nước.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        567.55,
        553.72,
        604.52
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0034",
      "type": "paragraph",
      "text": "Selen sulfid có độc tính rất cao khi uống. Vì vậy không được uống, mà chỉ dùng bôi ngoài da.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        603.8,
        553.71,
        628.69
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0035",
      "type": "heading",
      "level": 2,
      "text": "Liều lượng và cách dùng",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        630.82,
        399.56,
        643.97
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng và cách dùng",
          "bbox": [
            299.39,
            630.82,
            399.56,
            643.97
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0036",
      "type": "paragraph",
      "text": "Điều trị gầu hoặc viêm da tiết bã nhờn: Trẻ em ≥ 5 tuổi và người lớn: Xoa khoảng 5 - 10 ml nhũ dịch dùng ngoài hoặc dầu gội đầu 2,5% vào da đầu đã làm ẩm. Để 2 - 3 phút. Gội đầu thật sạch. Lại xoa thuốc rồi lại gội thật sạch. Sau khi điều trị, rửa tay thật sạch.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        643.06,
        553.73,
        692.11
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0037",
      "type": "paragraph",
      "text": "Tiếp tục điều trị như trên theo hướng dẫn của thầy thuốc. Thường dùng 2 lần/tuần, trong 2 tuần sẽ khống chế được bệnh. Sau đó có thể dùng thuốc thưa hơn, cụ thể là mỗi tuần 1 lần hoặc 2 tuần 1 lần, hoặc trong một số trường hợp cứ 3 tuần hoặc 4 tuần 1 lần, không nên dùng số lần quá mức độ cần thiết.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        691.4,
        553.72,
        752.53
      ],
      "source": {
        "line_count": 5
      }
    },
    {
      "id": "b0038",
      "type": "paragraph",
      "text": "Nhũ tương dùng ngoài hoặc dầu gội đầu 1% được tự dùng mà không cần kê đơn để kiểm soát gàu và/hoặc viêm da: Một lượng thuốc nhỏ được xát mạnh vào da đầu ướt, sau đó rửa kỹ bằng nước.",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        751.82,
        553.72,
        788.78
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0039",
      "type": "paragraph",
      "text": "Nên dùng lặp đi lặp lại. Nhũ dịch dùng ngoài hoặc dầu gội 1%",
      "page": 1470,
      "printed_page": 1476,
      "column": 1,
      "bbox": [
        299.39,
        788.07,
        553.71,
        800.87
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Nên dùng lặp đi lặp lại. Nhũ dịch dùng ngoài hoặc dầu gội 1% ",
          "bbox": [
            299.39,
            788.07,
            553.71,
            800.87
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0040",
      "type": "paragraph",
      "text": "thường được dùng một hoặc 2 lần/tuần hoặc theo chỉ dẫn của thầy thuốc. Để hiệu quả tối đa, dầu gội nên được sử dụng mỗi khi bệnh nhân gội đầu. Thuốc dạng 1% không dùng cho trẻ em dưới 2 tuổi trừ khi có yêu cầu của thầy thuốc.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        63.32,
        297.77,
        112.8
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0041",
      "type": "paragraph",
      "text": "Điều trị lang ben: Người lớn: Bôi nhũ tương dùng ngoài 2,5% vào vùng lang ben và xoa với một ít nước để tạo lớp mỏng. Để 10 phút, sau đó rửa sạch. Tiến hành như trên, mỗi ngày một lần trong 7 ngày.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        112.23,
        297.77,
        161.71
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0042",
      "type": "paragraph",
      "text": "Chú ý: Thuốc chỉ được dùng ngoài da. Lắc kỹ thuốc trước khi dùng.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        161.14,
        297.77,
        186.16
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0043",
      "type": "paragraph",
      "text": "Thuốc có thể làm hư đồ trang sức, vì vậy cần tháo ra trước khi dùng thuốc.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        185.59,
        297.76,
        210.62
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0044",
      "type": "heading",
      "level": 2,
      "text": "Quá liều và xử trí",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        212.9,
        115.11,
        226.04
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 0.0,
        "fonts": [
          "TimesNewRomanPS-BoldMT"
        ]
      },
      "spans": [
        {
          "text": "Quá liều và xử trí",
          "bbox": [
            43.43,
            212.9,
            115.11,
            226.04
          ],
          "font": "TimesNewRomanPS-BoldMT",
          "fontsize": 9.5,
          "flags": 20,
          "bold": true,
          "italic": false
        }
      ]
    },
    {
      "id": "b0045",
      "type": "paragraph",
      "text": "Bôi tại chỗ: Đã xảy ra nhiễm độc do bôi thuốc lâu dài trên da đầu bị tổn thương hở ở phụ nữ; các triệu chứng bao gồm: run, ra mồ hôi nhiều, hơi thở mùi tỏi, đau ở bụng dưới, yếu cơ, ngủ lịm, chán ăn, đôi khi nôn. Các triệu chứng hết sau 10 ngày ngừng thuốc.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        225.28,
        297.77,
        274.75
      ],
      "source": {
        "line_count": 4
      }
    },
    {
      "id": "b0046",
      "type": "paragraph",
      "text": "Lỡ uống thuốc: triệu chứng: buồn nôn, nôn.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        274.19,
        211.93,
        286.98
      ],
      "source": {
        "line_count": 1
      },
      "spans": [
        {
          "text": "Lỡ uống thuốc: triệu chứng: buồn nôn, nôn. ",
          "bbox": [
            43.43,
            274.19,
            211.93,
            286.98
          ],
          "font": "TimesNewRomanPSMT",
          "fontsize": 9.5,
          "flags": 4,
          "bold": false,
          "italic": false
        }
      ]
    },
    {
      "id": "b0047",
      "type": "paragraph",
      "text": "Xử trí: gây nôn hoặc rửa dạ dày. Áp dụng các biện pháp hỗ trợ chung. Có thể dùng thuốc tẩy để loại trừ thuốc được nhanh.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        286.41,
        297.77,
        311.44
      ],
      "source": {
        "line_count": 2
      }
    },
    {
      "id": "b0048",
      "type": "paragraph",
      "text": "Cập nhật lần cuối: 2018.",
      "page": 1471,
      "printed_page": 1477,
      "column": 0,
      "bbox": [
        43.43,
        316.43,
        138.7,
        329.06
      ],
      "source": {
