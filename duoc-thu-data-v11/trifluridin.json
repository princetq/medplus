    },
    {
      "id": "b0015",
      "type": "paragraph",
      "text": "Sau khi được nhỏ mắt, thuốc ngấm qua giác mạc và vào thủy dịch.",
      "page": 1620,
      "printed_page": 1626,
      "column": 0,
