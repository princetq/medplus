      "type": "subheading",
      "level": 3,
      "text": "Liều dùng",
      "page": 1620,
      "printed_page": 1626,
      "column": 1,
      "bbox": [
        299.39,
        596.72,
        339.77,
        609.44
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
