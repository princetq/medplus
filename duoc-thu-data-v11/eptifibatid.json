      }
    },
    {
      "id": "b0049",
      "type": "subheading",
      "level": 3,
      "text": "Liều lượng",
      "page": 671,
      "printed_page": 677,
      "column": 1,
      "bbox": [
        298.88,
        475.38,
        342.67,
        488.1
      ],
      "style": {
        "font_size": 9.5,
        "bold_ratio": 1.0,
        "italic_ratio": 1.0,
        "fonts": [
          "TimesNewRomanPS-BoldItal"
        ]
      },
      "spans": [
        {
          "text": "Liều lượng",
          "bbox": [
            298.88,
            475.38,
            342.67,
            488.1
          ],
          "font": "TimesNewRomanPS-BoldItal",
          "fontsize": 9.5,
          "flags": 22,
