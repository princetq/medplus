    },
    {
      "id": "b0017",
      "type": "paragraph",
      "text": "Dưới những dạng thuốc mỡ và hồ bôi dược dụng, kẽm oxyd được dùng rộng rãi trong điều trị da khô, các bệnh da và nhiễm khuẩn da như:",
      "page": 957,
      "printed_page": 963,
      "column": 0,
      "bbox": [
        43.94,
        531.99,
        298.27,
        568.6
      ],
      "source": {
        "line_count": 3
      }
    },
    {
      "id": "b0018",
      "type": "paragraph",
      "text": "Vùng da bị kích ứng do lỗ dò tiêu hóa, hậu môn nhân tạo, mở thông bàng quang.",
      "page": 957,
      "printed_page": 963,
