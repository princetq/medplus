{"schema_version":"11.0.0-alpha.1","id":"ether-me","title":"Ether Mê","aliases":["ether me"],"source":{"book":"Dược thư Quốc gia Việt Nam","edition":"Lần xuất bản thứ ba, 2023","pdf_pages":{"start":704,"end":705},"printed_pages":{"start":710,"end":711},"extraction":{"start_title_pdf_page":704,"start_column":"right","start_y":537.4451293945312,"next_title_pdf_page":705,"next_column":"right","next_y":675.5325317382812,"boundary_method":"physical-source-title-band"}},"parser":{"name":"medplus-duoc-thu-v11-structured-pdf-parser","method":"PyMuPDF span -> line -> block","content_source":"Duocthu2023.pdf","old_json_usage":"id/title/page-boundary metadata and existing table asset path only; old content is not used","column_order":"left column -> right column -> next page","block_model":["heading","subheading","paragraph","list","table","figure","note"],"table_policy":"no OCR; preserve existing duoc-thu-assets/<id>/pXXXX-tXX.png image_path"},"blocks":[{"id":"b0001","type":"heading","level":1,"text":"ETHER MÊ","page":704,"printed_page":710,"column":1,"bbox":[407.06,537.45,460.68,551.29],"style":{"font_size":10.0,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"ETHER MÊ","bbox":[407.06,537.45,460.68,551.29],"font":"TimesNewRomanPS-BoldMT","fontsize":10.0,"flags":20,"bold":true,"italic":false}]},{"id":"b0002","type":"paragraph","text":"Tên chung quốc tế: Diethylether, Ether mê.","page":704,"printed_page":710,"column":1,"bbox":[307.89,560.98,476.91,574.12],"source":{"line_count":1},"spans":[{"text":"Tên chung quốc tế: ","bbox":[307.89,560.98,388.12,574.12],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Diethylether, Ether mê.","bbox":[388.12,561.13,476.91,573.92],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0003","type":"paragraph","text":"Mã ATC: N01AA01.","page":704,"printed_page":710,"column":1,"bbox":[307.89,572.64,390.3,585.79],"source":{"line_count":1},"spans":[{"text":"Mã ATC: ","bbox":[307.89,572.64,348.35,585.79],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"N01AA01.","bbox":[348.35,572.79,390.3,585.59],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0004","type":"paragraph","text":"Loại thuốc: Gây mê.","page":704,"printed_page":710,"column":1,"bbox":[307.89,584.3,389.16,597.45],"source":{"line_count":1},"spans":[{"text":"Loại thuốc: ","bbox":[307.89,584.3,356.98,597.45],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false},{"text":"Gây mê.","bbox":[356.98,584.45,389.16,597.25],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0005","type":"heading","level":2,"text":"Dạng thuốc và hàm lượng","page":704,"printed_page":710,"column":1,"bbox":[307.89,599.47,412.81,612.61],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dạng thuốc và hàm lượng","bbox":[307.89,599.47,412.81,612.61],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0006","type":"paragraph","text":"Ether mê ở dạng chất lỏng không màu thường được đóng chai thủy tinh, nút bần chứa 120 ml. Ether có hàm lượng 96% đến 98% diethylether, còn lại là ethanol và nước, có pha thêm chất chống oxy hóa.","page":704,"printed_page":710,"column":1,"bbox":[307.89,611.78,562.22,661.07],"source":{"line_count":4}},{"id":"b0007","type":"heading","level":2,"text":"Dược lực học","page":704,"printed_page":710,"column":1,"bbox":[307.89,663.28,361.49,676.43],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược lực học","bbox":[307.89,663.28,361.49,676.43],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0008","type":"paragraph","text":"Ether là thuốc gây mê toàn thân theo đường thở. Ether cũng có tác dụng giảm đau và giãn cơ. Các thuốc gây mê ngăn cản dẫn truyền tại synap thần kinh (đặc biệt là tại vùng đồi thị) chủ yếu bằng cách ức chế giải phóng chất dẫn truyền thần kinh và ngăn cản tương tác của nó với các thụ thể sau synap.","page":704,"printed_page":710,"column":1,"bbox":[307.89,675.6,562.22,737.05],"source":{"line_count":5}},{"id":"b0009","type":"heading","level":2,"text":"Dược động học","page":704,"printed_page":710,"column":1,"bbox":[307.89,739.27,368.99,752.41],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Dược động học","bbox":[307.89,739.27,368.99,752.41],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0010","type":"paragraph","text":"Hấp thu: Ether tương đối dễ tan trong máu. Nồng độ ở phế nang sau khi hít vào đạt độ gây mê chậm, nên khởi mê chậm và tỉnh muộn. Nồng độ tối thiểu trong phế nang của ether là 1,92%.","page":704,"printed_page":710,"column":1,"bbox":[307.89,751.58,562.22,788.71],"source":{"line_count":3}},{"id":"b0011","type":"paragraph","text":"Phân bố: Thuốc phân bố trước hết vào các cơ quan có lưu lượng","page":704,"printed_page":710,"column":1,"bbox":[307.89,788.07,562.22,800.87],"source":{"line_count":1},"spans":[{"text":"Phân bố:","bbox":[307.89,788.23,343.49,800.87],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":" Thuốc phân bố trước hết vào các cơ quan có lưu lượng ","bbox":[343.49,788.07,562.22,800.87],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0012","type":"paragraph","text":"máu cao (não, tim, gan và thận) và sau đó vào các cơ quan ít được tưới máu hơn (cơ và mỡ).","page":705,"printed_page":711,"column":0,"bbox":[34.93,63.33,289.26,88.16],"source":{"line_count":2}},{"id":"b0013","type":"paragraph","text":"Chuyển hóa: 2 - 3% lượng thuốc được chuyển hóa trong gan thành acetaldehyd, alcol, acid acetic và carbon dioxyd.","page":705,"printed_page":711,"column":0,"bbox":[34.93,87.39,289.26,112.22],"source":{"line_count":2}},{"id":"b0014","type":"paragraph","text":"Thải trừ: 85 - 90% lượng hít vào vẫn ở dạng ban đầu khi thải qua phổi. Các chất chuyển hóa được thải ra theo nước tiểu.","page":705,"printed_page":711,"column":0,"bbox":[34.93,111.45,289.26,136.27],"source":{"line_count":2}},{"id":"b0015","type":"heading","level":2,"text":"Chỉ định","page":705,"printed_page":711,"column":0,"bbox":[34.93,138.36,70.57,151.5],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chỉ định","bbox":[34.93,138.36,70.57,151.5],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0016","type":"paragraph","text":"Khởi mê và duy trì mê trong phẫu thuật. Ý thức và phản xạ bị mất trong lúc mê sẽ được hồi phục.","page":705,"printed_page":711,"column":0,"bbox":[34.93,150.54,289.26,175.36],"source":{"line_count":2}},{"id":"b0017","type":"heading","level":2,"text":"Chống chỉ định","page":705,"printed_page":711,"column":0,"bbox":[34.93,177.44,97.23,190.59],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Chống chỉ định","bbox":[34.93,177.44,97.23,190.59],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0018","type":"paragraph","text":"Đái tháo đường, suy thận, các bệnh về gan nặng, tăng áp lực dịch não tủy.","page":705,"printed_page":711,"column":0,"bbox":[34.93,189.63,289.26,214.45],"source":{"line_count":2}},{"id":"b0019","type":"paragraph","text":"Trạng thái sốt (vì có thể gây co giật, đặc biệt ở trẻ em và người đã dùng atropin).","page":705,"printed_page":711,"column":0,"bbox":[34.93,213.68,289.26,238.51],"source":{"line_count":2}},{"id":"b0020","type":"paragraph","text":"Tăng áp lực nội sọ.","page":705,"printed_page":711,"column":0,"bbox":[34.93,237.74,107.89,250.54],"source":{"line_count":1},"spans":[{"text":"Tăng áp lực nội sọ.","bbox":[34.93,237.74,107.89,250.54],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0021","type":"note","level":2,"text":"Thận trọng","page":705,"printed_page":711,"column":0,"bbox":[34.93,252.62,81.12,265.77],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thận trọng","bbox":[34.93,252.62,81.12,265.77],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}],"note_role":"than trong"},{"id":"b0022","type":"paragraph","text":"Sử dụng ether cho trẻ em có sốt làm tăng nguy cơ co giật gây tử vong. Nếu bị co giật phải ngừng dùng ngay ether và đắp nước ấm để tránh giảm thân nhiệt của trẻ. Nên tiêm tĩnh mạch diazepam hoặc thiopental liều thấp cho đến khi ngừng cơn co giật.","page":705,"printed_page":711,"column":0,"bbox":[34.93,264.8,289.27,313.69],"source":{"line_count":4}},{"id":"b0023","type":"paragraph","text":"Ether rất dễ bay hơi và rất dễ cháy. Hỗn hợp hơi ether với oxygen hoặc không khí ở nồng độ nhất định tạo hỗn hợp nổ. Không được dùng ether khi có nguồn lửa hở hoặc dụng cụ điện tạo tia lửa điện.","page":705,"printed_page":711,"column":0,"bbox":[34.93,312.92,289.26,349.78],"source":{"line_count":3}},{"id":"b0024","type":"heading","level":2,"text":"Thời kỳ mang thai","page":705,"printed_page":711,"column":0,"bbox":[34.93,351.86,110.14,365.01],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Thời kỳ mang thai","bbox":[34.93,351.86,110.14,365.01],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0025","type":"paragraph","text":"Chỉ dùng ether trong thời kỳ mang thai khi thật cần.","page":705,"printed_page":711,"column":0,"bbox":[34.93,364.04,234.7,376.84],"source":{"line_count":1},"spans":[{"text":"Chỉ dùng ether trong thời kỳ mang thai khi thật cần. ","bbox":[34.93,364.04,234.7,376.84],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0026","type":"paragraph","text":"Trong các thủ thuật sản khoa, chỉ dùng liều thấp (không quá 4%) để tránh đờ tử cung, chảy máu quá mức sau đẻ, suy hô hấp ở trẻ sơ sinh.","page":705,"printed_page":711,"column":0,"bbox":[34.93,376.07,289.27,412.92],"source":{"line_count":3}},{"id":"b0027","type":"heading","level":2,"text":"Tác dụng không mong muốn (ADR)","page":705,"printed_page":711,"column":0,"bbox":[34.93,415.01,180.88,428.15],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tác dụng không mong muốn (ADR)","bbox":[34.93,415.01,180.88,428.15],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0028","type":"paragraph","text":"Sau phẫu thuật, nôn và buồn nôn (> 50%).","page":705,"printed_page":711,"column":0,"bbox":[34.93,427.19,195.96,439.98],"source":{"line_count":1},"spans":[{"text":"Sau phẫu thuật, nôn và buồn nôn (> 50%).","bbox":[34.93,427.19,195.96,439.98],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0029","type":"subheading","level":3,"text":"Thường gặp và rất thường gặp","page":705,"printed_page":711,"column":0,"bbox":[34.93,439.38,152.28,452.01],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Thường gặp và rất thường gặp","bbox":[34.93,439.38,152.28,452.01],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0030","type":"paragraph","text":"Tim mạch: Lưu lượng tim tăng 20%. Giãn mạch vành. Khi gây mê sâu, tác động lên trung tâm vận mạch, gây giãn mạch dẫn đến tụt huyết áp sâu, giảm lưu lượng thận.","page":705,"printed_page":711,"column":0,"bbox":[34.93,451.25,289.26,488.1],"source":{"line_count":3}},{"id":"b0031","type":"paragraph","text":"Hô hấp: kích thích niêm mạc đường hô hấp, gây tiết nhiều đờm rãi dễ gây biến chứng hô hấp. Thời gian khởi mê kéo dài, nên dễ có các biến chứng nguy hiểm, như co thắt thanh quản, thậm chí ngừng tim. Gây mê sâu gây ức chế hô hấp, gây mê nông có thể có ngừng thở và ho nếu hít vào quá nhanh.","page":705,"printed_page":711,"column":0,"bbox":[34.93,487.33,289.26,548.25],"source":{"line_count":5}},{"id":"b0032","type":"paragraph","text":"TKTW: kích thích lúc khởi mê, giãn mạch não, tăng lưu lượng máu não và áp suất nội sọ, giảm nhãn áp, giãn đồng tử, tăng bài tiết nước mắt.","page":705,"printed_page":711,"column":0,"bbox":[34.93,547.48,289.26,584.34],"source":{"line_count":3}},{"id":"b0033","type":"paragraph","text":"Tiêu hóa: giảm nhu động dạ dày - ruột, làm tăng tiết nước bọt.","page":705,"printed_page":711,"column":0,"bbox":[34.93,583.57,271.43,596.37],"source":{"line_count":1},"spans":[{"text":"Tiêu hóa: giảm nhu động dạ dày - ruột, làm tăng tiết nước bọt.","bbox":[34.93,583.57,271.43,596.37],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0034","type":"paragraph","text":"Tiết niệu - sinh dục: giảm dòng máu qua thận và mức lọc cầu thận, nước tiểu bị cô đặc gây albumin niệu. Giảm trương lực tử cung ở người mang thai.","page":705,"printed_page":711,"column":0,"bbox":[34.93,595.6,289.26,632.46],"source":{"line_count":3}},{"id":"b0035","type":"paragraph","text":"Chuyển hóa: Ether kích thích tân tạo glucose và có thể gây tăng đường huyết.","page":705,"printed_page":711,"column":0,"bbox":[34.93,631.69,289.27,656.52],"source":{"line_count":2}},{"id":"b0036","type":"subheading","level":3,"text":"Ít gặp","page":705,"printed_page":711,"column":0,"bbox":[34.93,655.91,57.36,668.54],"style":{"font_size":9.5,"bold_ratio":0.0,"italic_ratio":1.0,"fonts":["TimesNewRomanPS-ItalicMT"]},"spans":[{"text":"Ít gặp","bbox":[34.93,655.91,57.36,668.54],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]},{"id":"b0037","type":"paragraph","text":"Toàn thân: tăng tiết nước bọt, nên dùng chất chống tiết nước bọt trước đó. Co giật và run sau phẫu thuật.","page":705,"printed_page":711,"column":0,"bbox":[34.93,667.78,289.27,692.6],"source":{"line_count":2}},{"id":"b0038","type":"paragraph","text":"Tim mạch: loạn nhịp.","page":705,"printed_page":711,"column":0,"bbox":[34.93,691.84,116.4,704.63],"source":{"line_count":1},"spans":[{"text":"Tim mạch: loạn nhịp.","bbox":[34.93,691.84,116.4,704.63],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0039","type":"paragraph","text":"Hô hấp: giãn phế quản không tăng tiết dịch phế quản.","page":705,"printed_page":711,"column":0,"bbox":[34.93,703.87,238.36,716.66],"source":{"line_count":1},"spans":[{"text":"Hô hấp: giãn phế quản không tăng tiết dịch phế quản.","bbox":[34.93,703.87,238.36,716.66],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0040","type":"paragraph","text":"TKTW: giật rung, ức chế hành não nếu gây mê sâu.","page":705,"printed_page":711,"column":0,"bbox":[34.93,715.9,231.26,728.69],"source":{"line_count":1},"spans":[{"text":"TKTW: giật rung, ức chế hành não nếu gây mê sâu.","bbox":[34.93,715.9,231.26,728.69],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0041","type":"paragraph","text":"Máu: Thời gian prothrombin có thể kéo dài trong khi thời gian chảy máu bình thường.","page":705,"printed_page":711,"column":0,"bbox":[34.93,727.93,289.26,752.75],"source":{"line_count":2}},{"id":"b0042","type":"paragraph","text":"Tiêu hóa: Suy giảm nhất thời chức năng gan và tiết mật. Co bóp lách.","page":705,"printed_page":711,"column":0,"bbox":[34.93,751.98,289.26,776.81],"source":{"line_count":2}},{"id":"b0043","type":"paragraph","text":"Chuyển hóa: Nhiễm acid chuyển hóa ở trẻ nhỏ và ở người bệnh không chịu được tình trạng tăng lactat.","page":705,"printed_page":711,"column":0,"bbox":[34.93,776.04,289.26,800.87],"source":{"line_count":2}},{"id":"b0044","type":"heading","level":2,"text":"Liều lượng và cách dùng","page":705,"printed_page":711,"column":1,"bbox":[298.88,63.02,399.06,76.16],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Liều lượng và cách dùng","bbox":[298.88,63.02,399.06,76.16],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0045","type":"paragraph","text":"Dùng ether cần có bầu bốc hơi phù hợp. Đôi khi khẩn cấp, phải nhỏ giọt thẳng vào mặt nạ có phủ các lớp gạc. Trước đó, nên dùng atropin để giảm tiết nước bọt và dịch phế quản. Nồng độ khí hít vào không quá 15%. Gây mê nhẹ dùng nồng độ 3 - 5%. Gây mê sâu nồng độ tới 10% (nồng độ tối thiểu trong phế nang 1,92%).","page":705,"printed_page":711,"column":1,"bbox":[298.88,75.17,553.21,135.98],"source":{"line_count":5}},{"id":"b0046","type":"paragraph","text":"Da: Tiếp xúc với ether kéo dài có thể gây hoại tử mô.","page":705,"printed_page":711,"column":1,"bbox":[298.88,135.18,501.42,147.98],"source":{"line_count":1},"spans":[{"text":"Da: Tiếp xúc với ether kéo dài có thể gây hoại tử mô.","bbox":[298.88,135.18,501.42,147.98],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0047","type":"paragraph","text":"Lưu ý: Ở Anh, tiêu chuẩn nghề nghiệp qui định: Hơi ether mức dưới 1 500 mg/m3 không khí (tiếp xúc ngắn ngày) và dưới 1 200 mg/m3 không khí (tiếp xúc dài ngày).","page":705,"printed_page":711,"column":1,"bbox":[298.88,147.19,553.21,183.99],"source":{"line_count":3}},{"id":"b0048","type":"paragraph","text":"Ether rẻ và độ an toàn rộng, bởi vậy vẫn đóng vai trò quan trọng trong gây mê, nhất là ở các nước nghèo, các vùng mà ngành gây mê chưa phát triển.","page":705,"printed_page":711,"column":1,"bbox":[298.88,183.2,553.21,220.0],"source":{"line_count":3}},{"id":"b0049","type":"heading","level":2,"text":"Tương tác thuốc","page":705,"printed_page":711,"column":1,"bbox":[298.88,222.05,365.79,235.2],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Tương tác thuốc","bbox":[298.88,222.05,365.79,235.2],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0050","type":"paragraph","text":"Người bệnh gây mê bằng ether có thể bị loạn nhịp tim nếu dùng adrenalin và noradrenalin trừ khi dùng liều rất thấp. Trẻ em ít nhạy cảm hơn. Tuy nhiên, tác dụng làm tăng loạn nhịp tim của các thuốc cường giao cảm (kể cả adrenalin) của ether không mạnh bằng các thuốc gây mê khác theo đường hô hấp.","page":705,"printed_page":711,"column":1,"bbox":[298.88,234.21,553.21,295.01],"source":{"line_count":5}},{"id":"b0051","type":"paragraph","text":"Gây mê an toàn hơn nếu ngừng các thuốc chẹn beta trước khi gây mê. Dùng chất kháng muscarin (ví dụ atropin) để giảm hiện tượng tăng tiết nước bọt và tăng tiết ở phế quản, để phòng nhịp tim chậm.","page":705,"printed_page":711,"column":1,"bbox":[298.88,294.22,553.21,331.02],"source":{"line_count":3}},{"id":"b0052","type":"paragraph","text":"Ether làm tăng tác dụng của thuốc chẹn thần kinh - cơ mạnh hơn phần lớn các thuốc gây mê khác. Ether làm tăng tác dụng của các thuốc chẹn thần kinh cơ không khử cực. Ether có thể làm suy giảm cơ tim ở người bệnh đang dùng thuốc chẹn thụ thể beta-adrenergic như propranolol.","page":705,"printed_page":711,"column":1,"bbox":[298.88,330.23,553.22,391.04],"source":{"line_count":5}},{"id":"b0053","type":"paragraph","text":"Các thuốc làm tăng tác dụng giảm huyết áp của ether: Acetazolamid, amilorid, amitriptylin, atenolol, captopril, clomipramin, clorpromazin, fluphenazin, furosemid, glycerin trinitrat, haloperidol, hydralazin, hydroclorothiazid, isosorbid dinitrat, methyldopa, natri nitroprusiat, nifedipin, oxytocin, prazosin, spironolacton, timolol, verapramil.","page":705,"printed_page":711,"column":1,"bbox":[298.88,390.24,553.22,463.05],"source":{"line_count":6}},{"id":"b0054","type":"paragraph","text":"Các thuốc làm tăng nguy cơ loạn nhịp của ether: Amitriptylin, clomipramin, epinephrin, isoprenalin, levodopa, oxytocin, verapramil.","page":705,"printed_page":711,"column":1,"bbox":[298.88,462.26,553.22,499.06],"source":{"line_count":7}},{"id":"b0055","type":"paragraph","text":"Các thuốc làm tăng tác dụng an thần gây ngủ của ether:","page":705,"printed_page":711,"column":1,"bbox":[298.88,498.27,553.21,511.06],"source":{"line_count":1},"spans":[{"text":"Các thuốc làm tăng tác dụng an thần gây ngủ của ether","bbox":[298.88,498.43,548.2,511.06],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true},{"text":": ","bbox":[548.2,498.27,553.21,511.06],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0056","type":"paragraph","text":"Clonazepam, cloral hydrat, diazepam.","page":705,"printed_page":711,"column":1,"bbox":[298.88,510.27,442.93,523.07],"source":{"line_count":1},"spans":[{"text":"Clonazepam, cloral hydrat, diazepam.","bbox":[298.88,510.27,442.93,523.07],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0057","type":"paragraph","text":"Ether làm tăng độc tính của isoniazid đối với gan. Ether làm giảm tác dụng của oxytocin.","page":705,"printed_page":711,"column":1,"bbox":[298.88,522.27,553.22,547.07],"source":{"line_count":2}},{"id":"b0058","type":"paragraph","text":"Ether có thể gây ra phản ứng quá mẫn khi dùng đồng thời với vancomycin tiêm tĩnh mạch.","page":705,"printed_page":711,"column":1,"bbox":[298.88,546.28,553.22,571.08],"source":{"line_count":2}},{"id":"b0059","type":"heading","level":2,"text":"Quá liều và xử trí","page":705,"printed_page":711,"column":1,"bbox":[298.88,573.13,370.56,586.28],"style":{"font_size":9.5,"bold_ratio":1.0,"italic_ratio":0.0,"fonts":["TimesNewRomanPS-BoldMT"]},"spans":[{"text":"Quá liều và xử trí","bbox":[298.88,573.13,370.56,586.28],"font":"TimesNewRomanPS-BoldMT","fontsize":9.5,"flags":20,"bold":true,"italic":false}]},{"id":"b0060","type":"paragraph","text":"Triệu chứng quá liều cấp tính: Đầu tiên là suy hô hấp và sau đó ngừng tim. Phải ngừng dùng ether ngay; tiến hành ngay thông khí không liên tục dưới áp suất dương và có oxygen.","page":705,"printed_page":711,"column":1,"bbox":[298.88,585.29,553.21,622.09],"source":{"line_count":3}},{"id":"b0061","type":"paragraph","text":"Đã có báo cáo về hiện tượng phụ thuộc ether hoặc hơi ether.","page":705,"printed_page":711,"column":1,"bbox":[298.88,621.29,527.48,634.09],"source":{"line_count":1},"spans":[{"text":"Đã có báo cáo về hiện tượng phụ thuộc ether hoặc hơi ether.","bbox":[298.88,621.29,527.48,634.09],"font":"TimesNewRomanPSMT","fontsize":9.5,"flags":4,"bold":false,"italic":false}]},{"id":"b0062","type":"paragraph","text":"Cập nhật lần cuối: 2017.","page":705,"printed_page":711,"column":1,"bbox":[298.88,638.86,394.15,651.49],"source":{"line_count":1},"spans":[{"text":"Cập nhật lần cuối: 2017.","bbox":[298.88,638.86,394.15,651.49],"font":"TimesNewRomanPS-ItalicMT","fontsize":9.5,"flags":6,"bold":false,"italic":true}]}],"sections":[{"id":"ether-me","title":"ETHER MÊ","heading_block":"b0001","blocks":["b0002","b0003","b0004"]},{"id":"dang-thuoc-va-ham-luong","title":"Dạng thuốc và hàm lượng","heading_block":"b0005","blocks":["b0006"]},{"id":"duoc-luc-hoc","title":"Dược lực học","heading_block":"b0007","blocks":["b0008"]},{"id":"duoc-ong-hoc","title":"Dược động học","heading_block":"b0009","blocks":["b0010","b0011","b0012","b0013","b0014"]},{"id":"chi-inh","title":"Chỉ định","heading_block":"b0015","blocks":["b0016"]},{"id":"chong-chi-inh","title":"Chống chỉ định","heading_block":"b0017","blocks":["b0018","b0019","b0020","b0021","b0022","b0023"]},{"id":"thoi-ky-mang-thai","title":"Thời kỳ mang thai","heading_block":"b0024","blocks":["b0025","b0026"]},{"id":"tac-dung-khong-mong-muon-adr","title":"Tác dụng không mong muốn (ADR)","heading_block":"b0027","blocks":["b0028","b0029","b0030","b0031","b0032","b0033","b0034","b0035","b0036","b0037","b0038","b0039","b0040","b0041","b0042","b0043"]},{"id":"lieu-luong-va-cach-dung","title":"Liều lượng và cách dùng","heading_block":"b0044","blocks":["b0045","b0046","b0047","b0048"]},{"id":"tuong-tac-thuoc","title":"Tương tác thuốc","heading_block":"b0049","blocks":["b0050","b0051","b0052","b0053","b0054","b0055","b0056","b0057","b0058"]},{"id":"qua-lieu-va-xu-tri","title":"Quá liều và xử trí","heading_block":"b0059","blocks":["b0060","b0061","b0062"]}],"quality":{"block_count":62,"heading_count":11,"subheading_count":2,"paragraph_count":48,"list_count":0,"table_count":0,"figure_count":0,"note_count":1,"page_count":2}}