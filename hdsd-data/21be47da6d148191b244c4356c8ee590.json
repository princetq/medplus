b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Trong thuốc có hoạt chất có thể gây kết quả dương tính đối với các xét nghiệm tìm chất doping ở các vận động viên thể dục thể thao.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Trong thuốc có hoạt chất có thể gây kết quả dương tính đối với các xét nghiệm tìm chất doping ở các vận động viên thể dục thể thao.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"21be47da-6d14-8144-8c13-faebd2e08a63","parent":{"type":"block_id","block_id":"21be47da-6d14-81f2-927d-d432244a2e6b"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Nếu người bệnh có nhiều đờm thì phải điều trị trước khi dùng salbutamol dạng khí dung.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Nếu người bệnh có nhiều đờm thì phải điều trị trước khi dùng salbutamol dạng khí dung.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"21be47da-6d14-81a6-878c-f76d5b5bfabe","parent":{"type":"block_id","block_id":"21be47da-6d14-81f2-927d-d432244a2e6b"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false