ck_id":"21be47da-6d14-8127-b73c-e855abbbe9b3"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Ngăn ngừa cơn co thắt phế quản do gắng sức hay trước tiếp xúc với các dị nguyên đã biết trước nhưng không thể tránh được.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Ngăn ngừa cơn co thắt phế quản do gắng sức hay trước tiếp xúc với các dị nguyên đã biết trước nhưng không thể tránh được.","href":null}],"icon":null,"color":"default"},"archived":false}]},{"object":"block","id":"21be47da-6d14-8188-b678-f84de725fa42","parent":{"type":"page_id","page_id":"21be47da-6d14-8191-b244-c4356c8ee590"},"created_time":"2025-06-23T03:31:00.000Z","last_edited_time":"2025-06-23T03:31:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":true,"in_trash":false,"type":"toggle","toggle":{"rich_text":[{"type":"text","text":{"content":"LIỀU DÙNG ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"LIỀU DÙNG ","href":null}],"color":"default"},"archived":false,"_children":[{"object":"block","id":"21be47da-6d14-8197-88a1-da0b5310d5d7","parent":{"type":"block_id","block_id":"21be47da-6d14-8188-b678-f84de725fa42"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Người lớn: Để giảm co thắt phế quản cấp và các cơn hen, hít một liều duy nhất 100mcg. Nếu cần thiết có thể tăng lên 2 lần hít. Liều khuyến cáo tối đa là 2 lần hít, ba hoặc bốn lần một ngày. Để ngăn cơn co thắt phế quản do gắng sức hay trước tiếp xúc với các dị nguyên, hít một hoặc hai lần trước 10-15 phút.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Người lớn: Để giảm co thắt phế quản cấp và các cơn hen, hít một liều duy nhất 100mcg. Nếu cần thiết có thể tăng lên 2 lần hít. Liều khuyến cáo tối đa là 2 lần hít, ba hoặc bốn lần một ngày. Để ngăn cơn co thắt phế quản do gắng sức hay trước tiếp xúc với các dị nguyên, hít một hoặc hai lần trước 10-15 phút.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"21be47da-6d14-8181-8ee2-d604ba3d8809","parent":{"type":"block_id","block_id":"21be47da-6d14-8188-b678-f84de725fa42"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Trẻ em: Để làm giảm các triệu chứng hen suyễn cấp tính bao gồm co thắt phế quản hoặc trước khi tiếp xúc với dị nguyên hoặc gắng sức, hít một lần (100mcg). Tùy vào đáp ứng của bệnh nhân, có thể phải thăng lên 2 lần hít. Liều tối đa hằng ngày là 100mcg, bốn lần một ngày.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Trẻ em: Để làm giảm các triệu chứng hen suyễn cấp tính bao gồm co thắt phế quản hoặc trước khi tiếp xúc với dị nguyên hoặc gắng sức, hít một lần (100mcg). Tùy vào đáp ứng của bệnh nhân, có thể phải thăng lên 2 lần hít. Liều tối đa hằng ngày là 100mcg, bốn lần một ngày.","href":null}],"icon":null,"color":"default"},"archived":false}]},{"object":"block","id":"21be47da-6d14-814d-bbce-fbb32b1912c7","parent":{"type":"page_id","page_id":"21be47da-6d14-8191-b244-c4356c8ee590"},"created_time":"2025-06-23T03:31:00.000Z","last_edited_time":"2025-06-23T03:31:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":true,"in_trash":false,"type":"toggle","toggle":{"rich_text":[{"type":"text","text":{"content":"CÁCH DÙNG","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"CÁCH DÙNG","href":null}],"color":"default"},"archived":false,"_children":[{"object":"block","id":"21be47da-6d14-8106-a406-f01184d8dffe","parent":{"type":"block_id","block_id":"21be47da-6d14-814d-bbce-fbb32b1912c7"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Hít qua miệng. Chỉ mở nắp bảo vệ của bình xịt ngay trước khi dùng.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Hít qua miệng. Chỉ mở nắp bảo vệ của bình xịt ngay trước khi dùng.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"21be47da-6d14-8130-a308-cb486922e6f5","parent":{"type":"block_id","block_id":"21be47da-6d14-814d-bbce-fbb32b1912c7"},"created_time":"2025-06-23T03:33:00.000Z","last_edited_time":"2025-06-23T03:33:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-000