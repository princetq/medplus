9d-c1933340a32b"},"created_time":"2025-07-10T02:48:00.000Z","last_edited_time":"2025-07-10T02:48:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Xử trí:","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Xử trí:","href":null},{"type":"text","text":{"content":" Các triệu chứng tăng tiết tuyến thượng thận thường là có hồi phục. Điều trị mất cân bằng điện giải nếu cần thiết. Trong trường hợp ngộ độc mãn, nên ngưng thuốc từ từ. Việc điều trị ngộ độc Acid salicylic là điều trị triệu chứng. Nên áp dụng các biện pháp để loại Salicylate nhanh chóng khỏi cơ thể. Uống Natri bicarbonat để kiềm hóa nước tiểu và gây lợi tiểu.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":" Các triệu chứng tăng tiết tuyến thượng thận thường là có hồi phục. Điều trị mất cân bằng điện giải nếu cần thiết. Trong trường hợp ngộ độc mãn, nên ngưng thuốc từ từ. Việc điều trị ngộ độc Acid salicylic là điều trị triệu chứng. Nên áp dụng các biện pháp để loại Salicylate nhanh chóng khỏi cơ thể. Uống Natri bicarbonat để kiềm hóa nước tiểu và gây lợi tiểu.","href":null}],"icon":null,"color":"default"},"archived":false}]},{"object":"block","id":"22ce47da-6d14-809d-af28-c62351f4c15d","parent":{"type":"page_id","page_id":"22ce47da-6d14-80ad-94fb-e89fc93d2829"},"created_time":"2025-07-10T02:40:00.000Z","last_edited_time":"2025-07-10T02:49:00.000Z","created_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"last_edited_by":{"object":"user","id":"1fcd872b-594c-819f-ae6e-0002511134e7"},"has_children":true,"in_trash":false,"type":"toggle","toggle":{"rich_text":[{"type":"text","text":{"conte